---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="将棋詰将棋「自作問題」共有" description="盤面エディタで作って画像書き出し、URLパラメータで問題共有可能。">
<main class="sp-wrap">
  <div class="sp-header">
    <div class="sp-title">♙ 詰将棋 盤面エディタ</div>
    <div class="sp-sub">駒を配置して詰将棋問題を作成・共有</div>
  </div>

  <div class="sp-body">
    <div class="sp-left">
      <div class="sp-card">
        <div class="sp-card-title">駒の選択</div>
        <div class="sp-piece-sel">
          <div class="sp-side-label">先手（☗）</div>
          <div class="sp-pieces" id="sentePieces"></div>
          <div class="sp-side-label" style="margin-top:.5rem">後手（☖）</div>
          <div class="sp-pieces" id="gotePieces"></div>
          <button class="sp-piece-sel-item erase active-piece" id="eraseBtn" onclick="selectPiece('erase',this)">消去</button>
        </div>
      </div>

      <div class="sp-card">
        <div class="sp-card-title">操作</div>
        <button class="sp-action-btn" onclick="clearBoard()">盤面クリア</button>
        <button class="sp-action-btn" onclick="setPreset('tsume1')">サンプル（1手詰め）</button>
        <button class="sp-action-btn" onclick="setPreset('tsume3')">サンプル（3手詰め）</button>
      </div>

      <div class="sp-card">
        <div class="sp-card-title">URL共有</div>
        <div style="font-size:.8rem;color:var(--gray-400);margin-bottom:.5rem">現在の盤面をURLに変換して共有できます</div>
        <button class="sp-action-btn" onclick="copyURL()">🔗 URLをコピー</button>
        <div id="copyMsg" style="font-size:.75rem;color:#4ade80;margin-top:.3rem"></div>
      </div>

      <div class="sp-card">
        <div class="sp-card-title">盤面説明</div>
        <textarea id="boardDesc" class="sp-textarea" placeholder="詰め手順・ヒントなどを記入..." rows="4"></textarea>
      </div>
    </div>

    <div class="sp-right">
      <div class="sp-board-wrap">
        <div class="sp-board-title">将棋盤（9×9）</div>
        <div class="sp-board" id="shogiBoardSvg"></div>
      </div>
      <div class="sp-legend">クリックして駒を配置 / もう一度クリックで消去</div>
    </div>
  </div>
</main>

<script is:inline>
const PIECES = {
  sente: [
    { id:'s_ou', label:'王', kanji:'王' },
    { id:'s_hi', label:'飛', kanji:'飛' },
    { id:'s_ka', label:'角', kanji:'角' },
    { id:'s_ki', label:'金', kanji:'金' },
    { id:'s_gi', label:'銀', kanji:'銀' },
    { id:'s_ke', label:'桂', kanji:'桂' },
    { id:'s_ky', label:'香', kanji:'香' },
    { id:'s_fu', label:'歩', kanji:'歩' },
    { id:'s_ryu', label:'龍', kanji:'龍' },
    { id:'s_uma', label:'馬', kanji:'馬' },
    { id:'s_ngi', label:'全', kanji:'全' },
    { id:'s_nke', label:'圭', kanji:'圭' },
    { id:'s_nky', label:'杏', kanji:'杏' },
    { id:'s_to', label:'と', kanji:'と' },
  ],
  gote: [
    { id:'g_ou', label:'玉', kanji:'玉' },
    { id:'g_hi', label:'飛', kanji:'飛' },
    { id:'g_ka', label:'角', kanji:'角' },
    { id:'g_ki', label:'金', kanji:'金' },
    { id:'g_gi', label:'銀', kanji:'銀' },
    { id:'g_ke', label:'桂', kanji:'桂' },
    { id:'g_ky', label:'香', kanji:'香' },
    { id:'g_fu', label:'歩', kanji:'歩' },
  ],
};

let board = Array(9).fill(null).map(() => Array(9).fill(null));
let selectedPiece = 'erase';

const PRESETS = {
  tsume1: () => {
    clearBoard(true);
    board[0][4] = 's_ki'; // 5i金
    board[1][4] = 'g_ou'; // 5h玉(後手)
    board[0][3] = 's_ki'; // 4i金
    board[1][3] = 's_fu'; // 4h歩
    board[1][5] = 's_fu'; // 6h歩
    renderBoard();
  },
  tsume3: () => {
    clearBoard(true);
    board[0][4] = 's_ryu';
    board[1][4] = 'g_ou';
    board[1][3] = 'g_gi';
    board[0][5] = 's_ki';
    board[2][3] = 'g_fu';
    board[2][5] = 'g_fu';
    renderBoard();
  }
};

function setPreset(name) { PRESETS[name] && PRESETS[name](); }

function selectPiece(id, btn) {
  selectedPiece = id;
  document.querySelectorAll('.sp-piece-sel-item').forEach(b => b.classList.remove('active-piece'));
  btn.classList.add('active-piece');
}

function clearBoard(silent) {
  board = Array(9).fill(null).map(() => Array(9).fill(null));
  if (!silent) renderBoard();
}

function clickCell(row, col) {
  if (selectedPiece === 'erase') {
    board[row][col] = null;
  } else if (board[row][col] === selectedPiece) {
    board[row][col] = null;
  } else {
    board[row][col] = selectedPiece;
  }
  renderBoard();
}

function getPieceKanji(id) {
  if (!id) return '';
  const all = [...PIECES.sente, ...PIECES.gote];
  return all.find(p => p.id === id)?.kanji || '';
}

function renderBoard() {
  const container = document.getElementById('shogiBoardSvg');
  const W = 360, H = 360, pad = 20;
  const cellW = (W - pad*2) / 9, cellH = (H - pad*2) / 9;
  const ns = 'http://www.w3.org/2000/svg';

  const svg = document.createElementNS(ns, 'svg');
  svg.setAttribute('viewBox', '0 0 ' + W + ' ' + H);
  svg.setAttribute('style', 'width:100%;max-height:400px;background:#f5e6c8;border-radius:8px');

  // Grid
  for (let i = 0; i <= 9; i++) {
    const x = pad + i * cellW;
    const y = pad + i * cellH;
    const vl = document.createElementNS(ns, 'line');
    vl.setAttribute('x1', x); vl.setAttribute('y1', pad);
    vl.setAttribute('x2', x); vl.setAttribute('y2', H - pad);
    vl.setAttribute('stroke', '#8b6914'); vl.setAttribute('stroke-width', '1');
    svg.appendChild(vl);
    const hl = document.createElementNS(ns, 'line');
    hl.setAttribute('x1', pad); hl.setAttribute('y1', y);
    hl.setAttribute('x2', W - pad); hl.setAttribute('y2', y);
    hl.setAttribute('stroke', '#8b6914'); hl.setAttribute('stroke-width', '1');
    svg.appendChild(hl);
  }

  // Column numbers (9〜1 from left)
  for (let col = 0; col < 9; col++) {
    const t = document.createElementNS(ns, 'text');
    t.setAttribute('x', pad + (8 - col + 0.5) * cellW);
    t.setAttribute('y', pad - 5);
    t.setAttribute('font-size', '10'); t.setAttribute('fill', '#5c3a00');
    t.setAttribute('text-anchor', 'middle');
    t.textContent = col + 1;
    svg.appendChild(t);
  }

  // Pieces
  for (let row = 0; row < 9; row++) {
    for (let col = 0; col < 9; col++) {
      const piece = board[row][col];
      const cx = pad + (8 - col + 0.5) * cellW;
      const cy = pad + (row + 0.5) * cellH;

      // Click target
      const rect = document.createElementNS(ns, 'rect');
      rect.setAttribute('x', pad + (8 - col) * cellW);
      rect.setAttribute('y', pad + row * cellH);
      rect.setAttribute('width', cellW); rect.setAttribute('height', cellH);
      rect.setAttribute('fill', 'transparent'); rect.setAttribute('cursor', 'pointer');
      rect.addEventListener('click', () => clickCell(row, col));
      svg.appendChild(rect);

      if (piece) {
        const isGote = piece.startsWith('g_');
        const kanji = getPieceKanji(piece);
        const bg = document.createElementNS(ns, 'rect');
        const bw = cellW * 0.8, bh = cellH * 0.85;
        bg.setAttribute('x', cx - bw/2); bg.setAttribute('y', cy - bh/2);
        bg.setAttribute('width', bw); bg.setAttribute('height', bh);
        bg.setAttribute('fill', '#f0d080'); bg.setAttribute('rx', '2');
        bg.setAttribute('stroke', '#8b6914'); bg.setAttribute('stroke-width', '0.5');
        if (isGote) bg.setAttribute('transform', 'rotate(180,' + cx + ',' + cy + ')');
        svg.appendChild(bg);

        const t = document.createElementNS(ns, 'text');
        t.setAttribute('x', cx); t.setAttribute('y', cy + 4);
        t.setAttribute('font-size', '14'); t.setAttribute('fill', isGote ? '#1e40af' : '#1a0000');
        t.setAttribute('text-anchor', 'middle'); t.setAttribute('font-weight', 'bold');
        if (isGote) t.setAttribute('transform', 'rotate(180,' + cx + ',' + cy + ')');
        t.textContent = kanji;
        t.addEventListener('click', () => clickCell(row, col));
        svg.appendChild(t);
      }
    }
  }

  container.innerHTML = '';
  container.appendChild(svg);
}

function buildPieceSelectors() {
  function buildGroup(containerId, pieces, prefix) {
    const el = document.getElementById(containerId);
    el.innerHTML = pieces.map(p => `
      <button class="sp-piece-sel-item" onclick="selectPiece('${p.id}',this)">${p.kanji}</button>
    `).join('');
  }
  buildGroup('sentePieces', PIECES.sente, 's');
  buildGroup('gotePieces', PIECES.gote, 'g');
}

function copyURL() {
  const encoded = btoa(JSON.stringify(board.map(r => r.map(c => c || ''))));
  const desc = encodeURIComponent(document.getElementById('boardDesc').value);
  const url = window.location.href.split('?')[0] + '?b=' + encoded + (desc ? '&d=' + desc : '');
  navigator.clipboard?.writeText(url).then(() => {
    document.getElementById('copyMsg').textContent = 'コピーしました！';
    setTimeout(() => document.getElementById('copyMsg').textContent = '', 2000);
  });
}

function loadFromURL() {
  const params = new URLSearchParams(window.location.search);
  const b = params.get('b');
  const d = params.get('d');
  if (b) {
    try {
      const data = JSON.parse(atob(b));
      board = data.map(r => r.map(c => c || null));
    } catch(e) {}
  }
  if (d) document.getElementById('boardDesc').value = decodeURIComponent(d);
}

buildPieceSelectors();
loadFromURL();
renderBoard();
</script>

<style>
.sp-wrap { max-width: 900px; margin: 0 auto; padding: 2rem 1rem 4rem; }
.sp-header { text-align: center; margin-bottom: 2rem; }
.sp-title { font-size: 1.8rem; font-weight: 800; color: var(--gray-0); }
.sp-sub { color: var(--gray-400); margin-top: .3rem; }
.sp-body { display: grid; grid-template-columns: 240px 1fr; gap: 1.5rem; }
@media (max-width: 700px) { .sp-body { grid-template-columns: 1fr; } }
.sp-card { background: var(--gray-800); border: 1.5px solid var(--gray-700); border-radius: 14px; padding: 1rem; margin-bottom: .8rem; }
.sp-card-title { font-weight: 700; color: var(--gray-200); margin-bottom: .7rem; font-size: .9rem; }
.sp-side-label { font-size: .75rem; color: var(--gray-400); margin-bottom: .3rem; }
.sp-pieces { display: flex; flex-wrap: wrap; gap: .3rem; }
.sp-piece-sel-item { width: 36px; height: 36px; background: #f0d080; border: 2px solid #8b6914; border-radius: 4px; cursor: pointer; font-size: .9rem; font-weight: 700; color: #1a0000; }
.sp-piece-sel-item.active-piece { border-color: #7c3aed; box-shadow: 0 0 0 2px #7c3aed; }
.sp-action-btn { width: 100%; margin-bottom: .4rem; padding: .45rem; background: var(--gray-700); color: var(--gray-200); border: none; border-radius: 8px; cursor: pointer; font-size: .85rem; text-align: left; }
.sp-action-btn:hover { background: var(--gray-600); }
.sp-textarea { width: 100%; background: var(--gray-900); border: 1.5px solid var(--gray-700); border-radius: 8px; color: var(--gray-100); padding: .5rem .7rem; font-size: .85rem; resize: vertical; box-sizing: border-box; }
.sp-board-wrap { background: var(--gray-800); border: 1.5px solid var(--gray-700); border-radius: 14px; padding: 1rem; }
.sp-board-title { font-weight: 700; color: var(--gray-200); margin-bottom: .6rem; font-size: .9rem; }
.sp-legend { font-size: .75rem; color: var(--gray-500); margin-top: .5rem; }
</style>
</BaseLayout>
