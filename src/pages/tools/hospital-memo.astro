---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="病院問診メモ自動生成 — yumi-Labs"
  description="症状・期間・薬を入力するだけで、医師に伝わる順序で整形された問診メモをAIが生成。お薬手帳連携プロンプト付き。"
>
  <div class="wrapper page-wrap">
    <nav class="breadcrumb"><a href="/">← ツール一覧</a></nav>

    <header class="tool-header">
      <span class="tool-icon">🏥</span>
      <div>
        <h1 class="tool-title">病院問診メモ自動生成</h1>
        <p class="tool-sub">症状を入力するだけで、医師に伝わる問診メモをAIが整形します</p>
      </div>
    </header>

    <div class="main-layout">

      <!-- INPUT -->
      <section class="card input-card">
        <h2 class="card-title">📋 症状を入力</h2>

        <!-- 受診科 -->
        <div class="field-group">
          <label class="field-label" for="doctor-type">受診する科・医師タイプ</label>
          <div class="select-wrap">
            <select id="doctor-type" class="select-input">
              <option value="内科（一般）">内科（一般・発熱・倦怠感など）</option>
              <option value="消化器内科">消化器内科（胃・腸・腹痛）</option>
              <option value="循環器内科">循環器内科（動悸・息切れ・胸痛）</option>
              <option value="整形外科">整形外科（腰痛・関節・骨折）</option>
              <option value="皮膚科">皮膚科（湿疹・かぶれ・できもの）</option>
              <option value="耳鼻咽喉科">耳鼻咽喉科（喉・鼻・耳）</option>
              <option value="眼科">眼科（目の症状）</option>
              <option value="婦人科">婦人科（生理・ホルモン関連）</option>
              <option value="精神科・心療内科">精神科・心療内科（ストレス・不眠・うつ）</option>
              <option value="泌尿器科">泌尿器科（排尿・腎臓関連）</option>
            </select>
          </div>
        </div>

        <!-- 主な症状 -->
        <div class="field-group required-field">
          <label class="field-label" for="symptoms">
            主な症状 <span class="required">必須</span>
          </label>
          <textarea
            id="symptoms"
            class="textarea-input"
            placeholder="例：3日前から頭が痛い。特に右側こめかみあたりがズキズキする。市販の鎮痛剤を飲んでも2時間くらいしか効かない。"
            rows="4"
            maxlength="500"
          ></textarea>
          <p class="char-hint">思ったままの言葉でOKです。AIが医師向けに整形します。</p>
        </div>

        <!-- 期間・経過 -->
        <div class="field-group">
          <label class="field-label" for="duration">いつから・どんな経過か</label>
          <textarea
            id="duration"
            class="textarea-input"
            placeholder="例：1週間前から。最初は軽かったが3日前から悪化。熱は37.2℃が続いている。"
            rows="2"
            maxlength="300"
          ></textarea>
        </div>

        <!-- 薬・サプリ -->
        <div class="field-group">
          <label class="field-label" for="medicines">
            現在飲んでいる薬・サプリ
            <span class="badge-tip">お薬手帳があれば薬名をメモ</span>
          </label>
          <textarea
            id="medicines"
            class="textarea-input"
            placeholder="例：ロキソプロフェン（市販）、マルチビタミン、血圧の薬（名前不明）"
            rows="2"
            maxlength="300"
          ></textarea>
        </div>

        <!-- アレルギー -->
        <div class="field-group">
          <label class="field-label" for="allergy">アレルギー・薬の副作用歴</label>
          <input
            type="text"
            id="allergy"
            class="text-input"
            placeholder="例：ペニシリン系でじんましん、造影剤でアレルギー反応あり"
            maxlength="200"
          />
        </div>

        <!-- 既往歴 -->
        <div class="field-group">
          <label class="field-label" for="history">既往歴・持病（あれば）</label>
          <input
            type="text"
            id="history"
            class="text-input"
            placeholder="例：高血圧（治療中）、5年前に胆石の手術"
            maxlength="200"
          />
        </div>

        <button class="generate-btn" id="generate-btn" onclick="generate()">
          <span id="btn-text">📝 問診メモを生成する</span>
          <span id="btn-loader" class="loader" hidden></span>
        </button>

        <p class="privacy-note">※ 入力内容はサーバーに保存されません</p>
      </section>

      <!-- RESULT -->
      <div class="result-col">
        <div id="error-banner" class="error-banner" hidden></div>

        <div id="result-area" hidden>

          <!-- 問診メモ本文 -->
          <section class="card memo-card">
            <div class="card-header-row">
              <h3 class="card-title">📄 問診メモ</h3>
              <button class="copy-btn" onclick="copyMemo()">コピー</button>
            </div>
            <p class="memo-hint">このメモを受付で渡す・または診察室で見せてください</p>
            <div id="memo-text" class="memo-body"></div>
          </section>

          <!-- 重要ポイント -->
          <section class="card points-card">
            <h3 class="card-title">🔴 必ず口頭でも伝えること</h3>
            <ul id="key-points" class="points-list"></ul>
          </section>

          <!-- 質問リスト -->
          <section class="card questions-card">
            <h3 class="card-title">💬 医師への確認事項</h3>
            <p class="questions-hint">診察中に聞き忘れないようにチェックしてください</p>
            <div id="questions-list" class="questions-list"></div>
          </section>

          <!-- お薬手帳プロンプト -->
          <section class="card medicine-card">
            <div class="medicine-header">
              <span class="medicine-icon">📘</span>
              <h3 class="card-title">お薬手帳を持参する方へ</h3>
            </div>
            <p id="medicine-prompt" class="medicine-text"></p>
          </section>

        </div>

        <!-- 初期状態 -->
        <div id="result-empty" class="result-empty">
          <div class="empty-icon">🏥</div>
          <p>症状を入力して「問診メモを生成する」を押すと<br />ここに結果が表示されます</p>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<script is:inline>
async function generate() {
  const symptoms   = document.getElementById('symptoms').value.trim();
  const duration   = document.getElementById('duration').value.trim();
  const medicines  = document.getElementById('medicines').value.trim();
  const allergy    = document.getElementById('allergy').value.trim();
  const history    = document.getElementById('history').value.trim();
  const doctorType = document.getElementById('doctor-type').value;

  document.getElementById('error-banner').hidden = true;

  if (!symptoms) {
    showError('主な症状を入力してください。');
    document.getElementById('symptoms').focus();
    return;
  }

  setLoading(true);

  try {
    const res = await fetch('/api/hospital-memo', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ symptoms, duration, medicines, allergy, history, doctorType }),
    });
    const data = await res.json();
    if (!res.ok || data.error) { showError(data.error || '生成に失敗しました'); return; }
    renderResult(data);
  } catch {
    showError('通信エラーが発生しました。');
  } finally {
    setLoading(false);
  }
}

function renderResult(d) {
  // メモ本文
  const memoEl = document.getElementById('memo-text');
  memoEl.innerHTML = '';
  const lines = (d.memo || '').split('\n');
  lines.forEach((line, i) => {
    if (line.startsWith('**') && line.endsWith('**')) {
      const h = document.createElement('p');
      h.className = 'memo-section-title';
      h.textContent = line.replace(/\*\*/g, '');
      memoEl.appendChild(h);
    } else if (line.startsWith('- ') || line.startsWith('・')) {
      const li = document.createElement('p');
      li.className = 'memo-item';
      li.textContent = line;
      memoEl.appendChild(li);
    } else if (line.trim()) {
      const p = document.createElement('p');
      p.className = 'memo-line';
      p.textContent = line;
      memoEl.appendChild(p);
    } else if (i > 0) {
      memoEl.appendChild(document.createElement('br'));
    }
  });

  // 重要ポイント
  const pointsEl = document.getElementById('key-points');
  pointsEl.innerHTML = '';
  (d.keyPoints || []).forEach(pt => {
    const li = document.createElement('li');
    li.textContent = pt;
    pointsEl.appendChild(li);
  });

  // 質問リスト（チェックボックス）
  const questionsEl = document.getElementById('questions-list');
  questionsEl.innerHTML = '';
  (d.questions || []).forEach((q, i) => {
    const label = document.createElement('label');
    label.className = 'question-item';
    label.innerHTML = `
      <input type="checkbox" id="q${i}" />
      <span>${escHtml(q)}</span>
    `;
    questionsEl.appendChild(label);
  });

  // お薬手帳
  document.getElementById('medicine-prompt').textContent = d.medicinePrompt || '';

  document.getElementById('result-empty').hidden = true;
  document.getElementById('result-area').hidden = false;
  document.getElementById('result-area').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function copyMemo() {
  const text = document.getElementById('memo-text').innerText || '';
  navigator.clipboard.writeText(text.trim()).then(() => {
    const btn = document.querySelector('.copy-btn');
    btn.textContent = '✓ コピー完了';
    setTimeout(() => btn.textContent = 'コピー', 1800);
  });
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function showError(msg) {
  const el = document.getElementById('error-banner');
  el.textContent = msg;
  el.hidden = false;
}

function setLoading(on) {
  document.getElementById('generate-btn').disabled = on;
  document.getElementById('btn-text').hidden = on;
  document.getElementById('btn-loader').hidden = !on;
}
</script>

<style>
  .page-wrap {
    max-width: 980px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
    overflow-x: hidden;
    box-sizing: border-box;
  }

  .breadcrumb { margin-bottom: 1.5rem; font-size: .875rem; }
  .breadcrumb a { color: var(--accent-regular); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .tool-header {
    display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap;
  }
  .tool-icon { font-size: 2.5rem; line-height: 1; flex-shrink: 0; }
  .tool-title { font-size: clamp(1.1rem, 4vw, 1.5rem); font-weight: 700; margin: 0 0 .25rem; word-break: break-word; }
  .tool-sub { margin: 0; color: var(--gray-400); font-size: .9rem; }

  .main-layout {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 760px) { .main-layout { grid-template-columns: 1fr; } }

  .card {
    background: var(--gray-999);
    border: 1px solid var(--gray-800);
    border-radius: 1rem;
    padding: 1.25rem 1.5rem;
    box-sizing: border-box; min-width: 0;
  }
  .card-title { font-size: .95rem; font-weight: 700; margin: 0; }

  /* Fields */
  .field-group { margin-bottom: 1rem; }
  .required-field {}
  .field-label { display: block; font-size: .82rem; font-weight: 600; color: var(--gray-300); margin-bottom: .4rem; }
  .required {
    display: inline-block; background: var(--accent-regular); color: #fff;
    font-size: .68rem; padding: .05rem .4rem; border-radius: .25rem;
    margin-left: .3rem; vertical-align: middle;
  }
  .badge-tip {
    display: inline-block; background: color-mix(in srgb, #f59e0b 20%, transparent);
    color: #f59e0b; font-size: .68rem; padding: .05rem .45rem;
    border-radius: .25rem; margin-left: .3rem; vertical-align: middle;
    border: 1px solid color-mix(in srgb, #f59e0b 40%, transparent);
  }
  .char-hint { font-size: .74rem; color: var(--gray-500); margin: .3rem 0 0; }

  .select-wrap { position: relative; }
  .select-input {
    width: 100%; box-sizing: border-box;
    padding: .6rem 2rem .6rem .875rem;
    font-size: .875rem;
    border: 2px solid var(--gray-700); border-radius: .625rem;
    background: var(--gray-950); color: var(--gray-0);
    font-family: inherit; appearance: none; cursor: pointer;
    transition: border-color .2s;
  }
  .select-input:focus { outline: none; border-color: var(--accent-regular); }
  .select-wrap::after {
    content: '▾'; position: absolute; right: .75rem; top: 50%;
    transform: translateY(-50%); pointer-events: none; color: var(--gray-400);
  }

  .textarea-input, .text-input {
    width: 100%; box-sizing: border-box;
    padding: .65rem .875rem; font-size: .875rem;
    border: 2px solid var(--gray-700); border-radius: .625rem;
    background: var(--gray-950); color: var(--gray-0);
    font-family: inherit; transition: border-color .2s;
  }
  .textarea-input { resize: vertical; min-height: 64px; line-height: 1.65; }
  .textarea-input:focus, .text-input:focus { outline: none; border-color: var(--accent-regular); }

  .generate-btn {
    width: 100%; padding: .875rem;
    background: var(--accent-regular); color: #fff;
    font-size: 1rem; font-weight: 700;
    border: none; border-radius: .75rem;
    cursor: pointer; font-family: inherit;
    display: flex; align-items: center; justify-content: center; gap: .5rem;
    transition: opacity .2s; box-sizing: border-box; margin-top: .5rem;
  }
  .generate-btn:hover { opacity: .88; }
  .generate-btn:disabled { opacity: .55; cursor: not-allowed; }

  .privacy-note { font-size: .72rem; color: var(--gray-600); text-align: center; margin: .5rem 0 0; }

  .loader {
    width: 1.1rem; height: 1.1rem;
    border: 3px solid rgba(255,255,255,.35);
    border-top-color: #fff; border-radius: 50%;
    animation: spin .7s linear infinite; display: inline-block;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Error */
  .error-banner {
    background: color-mix(in srgb, #ef4444 15%, transparent);
    border: 1px solid #ef4444; color: #fca5a5;
    padding: .75rem 1rem; border-radius: .75rem;
    font-size: .875rem; margin-bottom: 1rem;
  }

  /* Result col */
  .result-col { display: flex; flex-direction: column; gap: 1rem; }

  /* Empty state */
  .result-empty {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 1rem; padding: 3rem 1rem;
    background: var(--gray-999); border: 1px dashed var(--gray-700);
    border-radius: 1rem; text-align: center;
    color: var(--gray-500); font-size: .875rem; line-height: 1.7;
  }
  .empty-icon { font-size: 2.5rem; }

  /* Memo card */
  .card-header-row {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: .5rem; flex-wrap: wrap; gap: .5rem;
  }
  .memo-hint { font-size: .75rem; color: var(--gray-500); margin: 0 0 1rem; }

  .copy-btn {
    padding: .25rem .75rem;
    border: 1px solid var(--gray-600); border-radius: 2rem;
    background: transparent; color: var(--gray-300);
    font-size: .78rem; cursor: pointer; font-family: inherit;
    transition: all .15s; flex-shrink: 0;
  }
  .copy-btn:hover { border-color: var(--accent-regular); color: var(--accent-regular); }

  .memo-body { font-size: .875rem; line-height: 1.8; color: var(--gray-100); }
  .memo-section-title { font-weight: 700; color: var(--gray-0); margin: .75rem 0 .25rem; font-size: .875rem; }
  .memo-section-title:first-child { margin-top: 0; }
  .memo-item { margin: .2rem 0; color: var(--gray-200); }
  .memo-line { margin: .2rem 0; }

  /* Key points */
  .points-list {
    list-style: none; padding: 0; margin: .75rem 0 0;
    display: flex; flex-direction: column; gap: .5rem;
  }
  .points-list li {
    display: flex; align-items: flex-start; gap: .5rem;
    padding: .6rem .875rem;
    background: color-mix(in srgb, #ef4444 10%, transparent);
    border: 1px solid color-mix(in srgb, #ef4444 30%, transparent);
    border-radius: .625rem;
    font-size: .82rem; color: var(--gray-100); line-height: 1.6;
  }
  .points-list li::before { content: '●'; color: #f87171; flex-shrink: 0; font-size: .6rem; margin-top: .35rem; }

  /* Questions */
  .questions-hint { font-size: .75rem; color: var(--gray-500); margin: 0 0 .75rem; }
  .questions-list { display: flex; flex-direction: column; gap: .5rem; }
  .question-item {
    display: flex; align-items: flex-start; gap: .625rem;
    padding: .6rem .875rem;
    background: var(--gray-950); border: 1px solid var(--gray-800);
    border-radius: .625rem; cursor: pointer; font-size: .82rem;
    color: var(--gray-200); line-height: 1.6;
    transition: background .15s;
  }
  .question-item:hover { background: var(--gray-900); }
  .question-item input[type=checkbox] { margin-top: .15rem; flex-shrink: 0; accent-color: var(--accent-regular); }
  .question-item:has(input:checked) { color: var(--gray-500); text-decoration: line-through; }

  /* Medicine card */
  .medicine-header {
    display: flex; align-items: center; gap: .5rem; margin-bottom: .75rem;
  }
  .medicine-icon { font-size: 1.25rem; flex-shrink: 0; }
  .medicine-text {
    font-size: .875rem; color: var(--gray-200); line-height: 1.75; margin: 0;
    padding: .75rem 1rem;
    background: color-mix(in srgb, #f59e0b 10%, transparent);
    border: 1px solid color-mix(in srgb, #f59e0b 30%, transparent);
    border-radius: .625rem;
  }
</style>
