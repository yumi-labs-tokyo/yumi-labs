  // ---- State ----
  const STORAGE_KEY = 'hello_world_tour_v1';
  let learned = new Set();
  let currentFilter = 'all';
  let currentLangId = null;

  function loadState() {
    try {
      const s = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      learned = new Set(s);
    } catch { learned = new Set(); }
  }
  function saveState() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify([...learned]));
  }

  // ---- Grid ----
  function setFilter(f) {
    currentFilter = f;
    document.querySelectorAll('.filter-btn').forEach(b => {
      const active = b.dataset.f === f;
      b.style.borderColor = active ? 'rgba(147,51,234,0.6)' : 'rgba(255,255,255,0.1)';
      b.style.background  = active ? 'rgba(147,51,234,0.2)' : 'rgba(255,255,255,0.05)';
      b.style.color = active ? 'white' : 'rgb(156,163,175)';
    });
    renderGrid();
  }

  function renderGrid() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    const filtered = LANGS.filter(l => {
      const matchQ = !q || l.name.toLowerCase().includes(q) || l.tags.join(' ').toLowerCase().includes(q) || l.desc.toLowerCase().includes(q);
      const matchF = currentFilter === 'all' || (currentFilter === 'done' && learned.has(l.id)) || (currentFilter === 'todo' && !learned.has(l.id));
      return matchQ && matchF;
    });

    document.getElementById('langGrid').innerHTML = filtered.map(l => {
      const isLearned = learned.has(l.id);
      return `<div class="lang-card bg-white/5 rounded-2xl p-3 border ${isLearned ? 'border-green-400/30' : 'border-white/5'} text-center"
        onclick="openDetail('${l.id}')">
        <div class="text-3xl mb-1">${l.emoji}</div>
        <div class="text-sm font-bold text-white leading-tight">${l.name}</div>
        <div class="text-xs text-gray-500 mt-0.5">${l.year}</div>
        ${isLearned ? '<div class="mt-1.5 text-xs text-green-400">✓ 学習済み</div>' : '<div class="mt-1.5 text-xs text-gray-600">未学習</div>'}
      </div>`;
    }).join('');

    updateProgress();
  }

  function updateProgress() {
    const count = learned.size;
    document.getElementById('learnedCount').textContent = count;
    document.getElementById('progressRingText').textContent = count;
    const circ = 2 * Math.PI * 22;
    const offset = circ - (count / 50) * circ;
    document.getElementById('progressRing').style.strokeDashoffset = offset;
  }

  // ---- Detail ----
  function openDetail(id) {
    const lang = LANGS.find(l => l.id === id);
    if (!lang) return;
    currentLangId = id;

    document.getElementById('detailEmoji').textContent = lang.emoji;
    document.getElementById('detailName').textContent = lang.name;
    document.getElementById('detailYear').textContent = `${lang.year}年 生まれ`;
    document.getElementById('detailDesc').textContent = lang.desc;
    document.getElementById('detailLangLabel').textContent = lang.name;
    document.getElementById('detailTags').innerHTML = lang.tags.map(t =>
      `<span class="px-2 py-0.5 rounded-lg text-xs bg-purple-500/20 text-purple-300 border border-purple-400/20">${t}</span>`
    ).join('');

    // Syntax highlight (simple)
    document.getElementById('detailCode').innerHTML = highlight(lang.code);

    document.getElementById('detailFactList').innerHTML = lang.facts.map(f =>
      `<li class="text-xs text-gray-300 flex gap-2"><span class="text-purple-400 flex-shrink-0">•</span><span>${f}</span></li>`
    ).join('');

    // Learn button state
    const isLearned = learned.has(id);
    const btn = document.getElementById('learnBtn');
    btn.textContent = isLearned ? '✅ 学習済み（クリックで取り消し）' : '✅ 学習済みにする';
    btn.style.background = isLearned
      ? 'linear-gradient(135deg,#059669,#10b981)'
      : 'linear-gradient(135deg,#9333ea,#ec4899)';

    document.getElementById('transcribeArea').value = '';
    document.getElementById('transcribeMsg').classList.add('hidden');

    const panel = document.getElementById('detailPanel');
    panel.classList.remove('hidden');
    panel.classList.add('slide-in');
    panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    setTimeout(() => panel.classList.remove('slide-in'), 300);
  }

  function closeDetail() {
    document.getElementById('detailPanel').classList.add('hidden');
    currentLangId = null;
  }

  function navLang(dir) {
    const idx = LANGS.findIndex(l => l.id === currentLangId);
    const next = (idx + dir + LANGS.length) % LANGS.length;
    openDetail(LANGS[next].id);
  }

  function markLearned() {
    if (!currentLangId) return;
    if (learned.has(currentLangId)) {
      learned.delete(currentLangId);
    } else {
      learned.add(currentLangId);
    }
    saveState();
    openDetail(currentLangId);
    renderGrid();
  }

  function copyCode() {
    const lang = LANGS.find(l => l.id === currentLangId);
    if (!lang) return;
    navigator.clipboard.writeText(lang.code);
    const btn = document.getElementById('copyBtn');
    btn.textContent = '✅ コピー済み';
    setTimeout(() => btn.textContent = '📋 コピー', 1500);
    document.getElementById('detailCode').classList.add('copy-flash');
    setTimeout(() => document.getElementById('detailCode').classList.remove('copy-flash'), 300);
  }

  function checkTranscription() {
    const lang = LANGS.find(l => l.id === currentLangId);
    if (!lang) return;
    const input = document.getElementById('transcribeArea').value;
    const target = lang.code.replace(/\r\n/g, '\n').trim();
    const typed = input.replace(/\r\n/g, '\n').trim();
    const msgEl = document.getElementById('transcribeMsg');
    if (typed === target) {
      msgEl.textContent = '🎉 完璧！写経完了！「学習済み」ボタンを押してチェックしよう';
      msgEl.className = 'mt-1 text-xs text-center text-green-400';
      msgEl.classList.remove('hidden');
    } else if (target.startsWith(typed) && typed.length > 0) {
      msgEl.textContent = `✏️ ${Math.round(typed.length / target.length * 100)}% 入力中...`;
      msgEl.className = 'mt-1 text-xs text-center text-purple-300';
      msgEl.classList.remove('hidden');
    } else {
      msgEl.classList.add('hidden');
    }
  }

  // ---- Syntax highlighter (simple keyword-based) ----
  function highlight(code) {
    const esc = code.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    return esc
      .replace(/(\/\/[^\n]*)/g, '<span class="syntax-comment">$1</span>')
      .replace(/(#[^\n!{]+)/g, '<span class="syntax-comment">$1</span>')
      .replace(/\b(fn|fun|func|def|public|private|static|void|int|string|let|const|var|class|module|import|from|return|use|pub|async|await|new|extends|implements|interface|abstract|override|struct|enum|type|match|if|else|for|while|in|do|end|then|of|with|where|true|false|null|nil|None|Some|Ok|Err)\b/g, '<span class="syntax-keyword">$1</span>')
      .replace(/("(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*'|`(?:[^`\\]|\\.)*`)/g, '<span class="syntax-string">$1</span>')
      .replace(/\b(\d+\.?\d*)\b/g, '<span class="syntax-num">$1</span>');
  }

  // ---- Init ----
  loadState();
  renderGrid();

  document.getElementById('searchInput').addEventListener('keydown', e => {
    if (e.key === 'Escape') { e.target.value = ''; renderGrid(); }
  });
</script>
