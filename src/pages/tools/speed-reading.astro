---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="速読トレーニング" description="テキストを貼り付けて表示速度を調整。1分間に何文字読めるか測定する速読トレーニングツール。">
<style>
  .container { max-width: 860px; margin: 0 auto; padding: 24px 16px; }
  .hero { text-align: center; margin-bottom: 28px; }
  .hero-title { font-size: 2rem; font-weight: 800; color: var(--gray-0); margin-bottom: 6px; }
  .hero-sub { color: #94a3b8; font-size: 0.92rem; }

  /* tabs */
  .tab-row { display: flex; gap: 4px; background: #0f172a; border-radius: 12px; padding: 4px; margin-bottom: 24px; width: fit-content; }
  .tab-btn {
    padding: 8px 20px; border-radius: 8px; border: none; cursor: pointer;
    font-size: 0.88rem; font-weight: 700; color: #64748b; background: transparent; transition: all .2s;
  }
  .tab-btn.active { background: #1e293b; color: var(--gray-0); }

  /* stats row */
  .stats-row { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; margin-bottom: 20px; }
  .stat-box { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 12px 18px; text-align: center; min-width: 90px; }
  .stat-val { font-size: 1.7rem; font-weight: 800; color: #22d3ee; }
  .stat-label { font-size: 0.72rem; color: #64748b; margin-top: 2px; }

  /* reading display */
  .reader-card {
    background: #0f172a; border: 2px solid #334155; border-radius: 16px;
    padding: 32px 28px; margin-bottom: 20px; min-height: 160px;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  /* mode: rsvp */
  .rsvp-word {
    font-size: 2.8rem; font-weight: 800; color: var(--gray-0);
    text-align: center; line-height: 1.2; transition: opacity .05s;
    max-width: 100%;
  }
  .rsvp-word .pivot { color: #22d3ee; }
  .rsvp-progress {
    position: absolute; bottom: 0; left: 0; height: 3px;
    background: linear-gradient(90deg,#22d3ee,#6366f1); transition: width .1s linear;
  }
  /* mode: scroll */
  .scroll-text {
    font-size: 1.1rem; color: var(--gray-0); line-height: 2; text-align: left;
    width: 100%; max-height: 300px; overflow: hidden; position: relative;
  }
  .scroll-text .current-chunk { background: rgba(34,211,238,.15); border-radius: 4px; color: #67e8f9; }
  /* mode: chunk */
  .chunk-text {
    font-size: 1.4rem; font-weight: 600; color: var(--gray-0);
    text-align: center; line-height: 1.6;
  }

  /* controls */
  .controls { background: #1e293b; border: 1px solid #334155; border-radius: 14px; padding: 18px 20px; margin-bottom: 20px; }
  .ctrl-row { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; margin-bottom: 12px; }
  .ctrl-label { font-size: 0.8rem; color: #64748b; white-space: nowrap; }
  .ctrl-val { font-size: 0.85rem; color: #22d3ee; font-weight: 700; min-width: 50px; }
  input[type=range] { flex: 1; min-width: 120px; accent-color: #22d3ee; }
  .btn-row { display: flex; gap: 8px; flex-wrap: wrap; }
  .btn {
    padding: 10px 22px; border-radius: 10px; border: none; cursor: pointer;
    font-size: 0.9rem; font-weight: 700; transition: all .2s;
  }
  .btn-start { background: linear-gradient(135deg,#22d3ee,#6366f1); color: #fff; }
  .btn-start:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(34,211,238,.35); }
  .btn-stop  { background: #7f1d1d; color: #fca5a5; border: 1px solid #b91c1c; }
  .btn-stop:hover { background: #991b1b; }
  .btn-reset { background: #1e293b; border: 1px solid #334155; color: #94a3b8; }

  /* text input */
  .text-input-card { background: #1e293b; border: 1px solid #334155; border-radius: 14px; padding: 18px; margin-bottom: 20px; }
  .section-label { font-size: 0.82rem; font-weight: 700; color: #94a3b8; margin-bottom: 10px; }
  .text-area {
    width: 100%; box-sizing: border-box; background: #0f172a; border: 2px solid #334155;
    border-radius: 10px; color: var(--gray-0); font-size: 0.95rem; padding: 12px 14px;
    outline: none; resize: vertical; min-height: 120px; font-family: inherit;
    line-height: 1.7; transition: border-color .2s;
  }
  .text-area:focus { border-color: #22d3ee; }
  .text-meta { font-size: 0.75rem; color: #64748b; margin-top: 6px; }
  .sample-row { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; }
  .sample-btn {
    padding: 4px 10px; border-radius: 6px; border: 1px solid #334155;
    background: #0f172a; color: #64748b; cursor: pointer; font-size: 0.75rem;
    transition: all .15s;
  }
  .sample-btn:hover { border-color: #22d3ee; color: #22d3ee; }

  /* result */
  .result-card {
    background: #1e293b; border: 2px solid #22d3ee; border-radius: 16px;
    padding: 28px; text-align: center; display: none; margin-bottom: 20px;
  }
  .result-card.show { display: block; }
  .result-emoji { font-size: 3rem; margin-bottom: 8px; }
  .result-main { font-size: 2.5rem; font-weight: 800; color: #22d3ee; margin-bottom: 4px; }
  .result-sub { color: #94a3b8; font-size: 0.9rem; margin-bottom: 20px; }
  .result-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(110px,1fr)); gap: 10px; margin-bottom: 20px; }
  .result-item { background: #0f172a; border-radius: 10px; padding: 10px; }
  .result-item .val { font-size: 1.3rem; font-weight: 800; color: #6366f1; }
  .result-item .lbl { font-size: 0.7rem; color: #64748b; }

  /* history */
  .history-section { background: #1e293b; border: 1px solid #334155; border-radius: 14px; padding: 18px; }
  .history-title { font-size: 0.85rem; font-weight: 700; color: #94a3b8; margin-bottom: 10px; }
  .history-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .history-table th { color: #64748b; text-align: left; padding: 5px 8px; border-bottom: 1px solid #334155; }
  .history-table td { color: var(--gray-0); padding: 6px 8px; border-bottom: 1px solid #0f172a; }

  /* countdown */
  .countdown-overlay {
    display: none; position: absolute; inset: 0; background: rgba(0,0,0,.7);
    align-items: center; justify-content: center; border-radius: 14px;
    font-size: 5rem; font-weight: 900; color: #22d3ee; z-index: 10;
  }
  .countdown-overlay.show { display: flex; }
</style>

<div class="container">
  <div class="hero">
    <div class="hero-title">📰 速読トレーニング</div>
    <div class="hero-sub">テキストを貼り付け → 速度調整 → 1分間に何文字読めるか測定</div>
  </div>

  <!-- mode tabs -->
  <div class="tab-row">
    <button class="tab-btn active" onclick="setMode('rsvp')" id="tab-rsvp">RSVP（1語ずつ）</button>
    <button class="tab-btn" onclick="setMode('chunk')" id="tab-chunk">チャンク（まとめ読み）</button>
    <button class="tab-btn" onclick="setMode('scroll')" id="tab-scroll">スクロール</button>
  </div>

  <!-- stats -->
  <div class="stats-row">
    <div class="stat-box"><div class="stat-val" id="stat-cpm">--</div><div class="stat-label">CPM（文字/分）</div></div>
    <div class="stat-box"><div class="stat-val" id="stat-wpm">--</div><div class="stat-label">WPM（語/分）</div></div>
    <div class="stat-box"><div class="stat-val" id="stat-elapsed">0</div><div class="stat-label">経過秒</div></div>
    <div class="stat-box"><div class="stat-val" id="stat-progress">0%</div><div class="stat-label">進捗</div></div>
  </div>

  <!-- reader -->
  <div class="reader-card" id="reader-card">
    <div class="countdown-overlay" id="countdown-overlay">3</div>
    <div id="display-area" style="width:100%;text-align:center;color:#475569;font-size:1rem">
      テキストを入力してスタートを押してください
    </div>
    <div class="rsvp-progress" id="rsvp-progress" style="width:0%"></div>
  </div>

  <!-- controls -->
  <div class="controls">
    <div class="ctrl-row">
      <span class="ctrl-label">速度</span>
      <input type="range" id="speed-slider" min="60" max="800" step="10" value="200" oninput="onSpeedChange()" />
      <span class="ctrl-val" id="speed-val">200 CPM</span>
    </div>
    <div class="ctrl-row">
      <span class="ctrl-label">チャンクサイズ</span>
      <input type="range" id="chunk-slider" min="1" max="6" step="1" value="2" oninput="onChunkChange()" />
      <span class="ctrl-val" id="chunk-val">2語</span>
    </div>
    <div class="ctrl-row">
      <span class="ctrl-label">測定時間</span>
      <input type="range" id="time-slider" min="30" max="300" step="30" value="60" oninput="onTimeChange()" />
      <span class="ctrl-val" id="time-val">60秒</span>
    </div>
    <div class="btn-row">
      <button class="btn btn-start" onclick="startReading()" id="btn-start">▶ スタート</button>
      <button class="btn btn-stop"  onclick="stopReading()"  id="btn-stop" style="display:none">⏹ 停止</button>
      <button class="btn btn-reset" onclick="resetReading()">↺ リセット</button>
    </div>
  </div>

  <!-- result -->
  <div class="result-card" id="result-card">
    <div class="result-emoji" id="result-emoji">📊</div>
    <div class="result-main" id="result-main">-- CPM</div>
    <div class="result-sub" id="result-sub"></div>
    <div class="result-grid">
      <div class="result-item"><div class="val" id="r-cpm">--</div><div class="lbl">CPM</div></div>
      <div class="result-item"><div class="val" id="r-wpm">--</div><div class="lbl">WPM</div></div>
      <div class="result-item"><div class="val" id="r-chars">--</div><div class="lbl">読んだ文字数</div></div>
      <div class="result-item"><div class="val" id="r-time">--</div><div class="lbl">秒</div></div>
    </div>
    <button class="btn btn-start" onclick="startReading()">もう一度</button>
  </div>

  <!-- text input -->
  <div class="text-input-card">
    <div class="section-label">📝 テキスト入力</div>
    <textarea class="text-area" id="text-area" placeholder="読みたいテキストをここに貼り付けてください..."></textarea>
    <div class="text-meta" id="text-meta">0 文字 / 0 語</div>
    <div class="sample-row">
      <span style="font-size:.75rem;color:#64748b">サンプル：</span>
      <button class="sample-btn" onclick="loadSample(0)">日本語文章</button>
      <button class="sample-btn" onclick="loadSample(1)">技術記事風</button>
      <button class="sample-btn" onclick="loadSample(2)">小説風</button>
    </div>
  </div>

  <!-- history -->
  <div class="history-section" id="history-section" style="display:none">
    <div class="history-title">📈 記録履歴</div>
    <table class="history-table">
      <thead><tr><th>日時</th><th>モード</th><th>CPM</th><th>WPM</th><th>時間</th></tr></thead>
      <tbody id="history-body"></tbody>
    </table>
  </div>
</div>

<script is:inline>
// ======= SAMPLES =======
const SAMPLES = [
  `速読とは、文章を素早く読み取る技術のことです。一般的な読書速度は1分間に400〜600文字程度といわれていますが、訓練によって2000文字以上読める人もいます。速読の基本は、1文字ずつ音読するのをやめ、意味のかたまりとして文章を視覚的に捉えることです。眼球の動きを最小限にし、視野を広げることで、より多くの情報を一度に処理できるようになります。毎日の練習が大切で、慣れてくると自然と速度が上がっていきます。`,

  `プログラミングにおいて、アルゴリズムとデータ構造の理解は非常に重要です。特にビッグO記法による計算量の評価は、効率的なコードを書くための基礎となります。配列の検索にはO(n)、ハッシュマップの検索にはO(1)、二分探索にはO(log n)の計算量がかかります。実際のシステム開発では、要件に応じて適切なデータ構造を選択することが、パフォーマンスに大きな影響を与えます。また、メモリ使用量と処理速度のトレードオフを考慮することも重要です。`,

  `夕暮れ時、彼女は古い図書館の前に立っていた。重厚な木製の扉が、長い年月を経た風合いを醸し出している。中に入ると、古本特有の甘い香りが鼻をくすぐった。高い天井まで届く本棚が左右に並び、まるで知識の迷宮のようだ。窓から差し込む橙色の光が、埃の粒子を金色に輝かせている。彼女はそっと一冊の本を手に取った。表紙には見慣れない文字が刻まれていた。これが、彼女の長い旅の始まりだった。`,
];

// ======= STATE =======
let mode = 'rsvp';
let speed = 200;       // CPM
let chunkSize = 2;
let duration = 60;     // seconds
let running = false;
let words = [];
let charTokens = [];
let wordIdx = 0;
let charIdx = 0;
let startTime = null;
let elapsed = 0;
let tickTimer = null;
let displayTimer = null;
let charsRead = 0;
let history = JSON.parse(localStorage.getItem('speed_reading_v1') || '[]');

// ======= UTILS =======
function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function tokenize(text) {
  // Split into words (support Japanese: each char = 1 word, English: space-split)
  const tokens = [];
  let buf = '';
  for (const ch of text) {
    const isJa = /[　-鿿豈-﫿]/.test(ch);
    if (isJa) {
      if (buf) { tokens.push(buf); buf = ''; }
      tokens.push(ch);
    } else if (/\s/.test(ch)) {
      if (buf) { tokens.push(buf); buf = ''; }
    } else {
      buf += ch;
    }
  }
  if (buf) tokens.push(buf);
  return tokens.filter(t => t.trim());
}

function getCharCount(tokens, from, to) {
  return tokens.slice(from, to).join('').length;
}

// ======= TEXT AREA =======
function updateTextMeta() {
  const text = document.getElementById('text-area').value;
  const chars = text.replace(/\s/g,'').length;
  const ws = tokenize(text).length;
  document.getElementById('text-meta').textContent = `${chars} 文字 / ${ws} 語`;
}
document.getElementById('text-area').addEventListener('input', updateTextMeta);

function loadSample(i) {
  document.getElementById('text-area').value = SAMPLES[i];
  updateTextMeta();
}

// ======= MODE =======
function setMode(m) {
  mode = m;
  ['rsvp','chunk','scroll'].forEach(id => {
    document.getElementById('tab-' + id).classList.toggle('active', id === m);
  });
  resetReading();
}

// ======= SPEED / CHUNK / TIME =======
function onSpeedChange() {
  speed = +document.getElementById('speed-slider').value;
  document.getElementById('speed-val').textContent = speed + ' CPM';
}
function onChunkChange() {
  chunkSize = +document.getElementById('chunk-slider').value;
  document.getElementById('chunk-val').textContent = chunkSize + '語';
}
function onTimeChange() {
  duration = +document.getElementById('time-slider').value;
  document.getElementById('time-val').textContent = duration + '秒';
}

// ======= COUNTDOWN =======
function runCountdown(cb) {
  const el = document.getElementById('countdown-overlay');
  el.classList.add('show');
  let n = 3;
  el.textContent = n;
  const iv = setInterval(() => {
    n--;
    if (n <= 0) { clearInterval(iv); el.classList.remove('show'); cb(); }
    else el.textContent = n;
  }, 700);
}

// ======= START =======
function startReading() {
  const text = document.getElementById('text-area').value.trim();
  if (!text) { alert('テキストを入力してください'); return; }
  words = tokenize(text);
  if (words.length === 0) return;
  charTokens = words;
  wordIdx = 0;
  charsRead = 0;
  elapsed = 0;
  running = false;
  document.getElementById('result-card').classList.remove('show');
  document.getElementById('btn-start').style.display = 'none';
  document.getElementById('btn-stop').style.display = '';
  updateStats(0, 0, 0);

  runCountdown(() => {
    running = true;
    startTime = Date.now();
    tickTimer = setInterval(onTick, 200);
    scheduleNext();
  });
}

// ======= TICK =======
function onTick() {
  if (!running) return;
  elapsed = (Date.now() - startTime) / 1000;
  document.getElementById('stat-elapsed').textContent = Math.floor(elapsed);
  const pct = Math.min(100, Math.round(elapsed / duration * 100));
  document.getElementById('stat-progress').textContent = pct + '%';
  document.getElementById('rsvp-progress').style.width = pct + '%';

  const cpm = elapsed > 0 ? Math.round(charsRead / elapsed * 60) : 0;
  const wpm = Math.round(cpm / 3);
  document.getElementById('stat-cpm').textContent = cpm;
  document.getElementById('stat-wpm').textContent = wpm;

  if (elapsed >= duration) finishReading();
}

// ======= DISPLAY SCHEDULER =======
function scheduleNext() {
  if (!running) return;
  const msPerChar = 60000 / speed;

  if (mode === 'rsvp') {
    if (wordIdx >= words.length) { finishReading(); return; }
    const w = words[wordIdx];
    showRsvp(w);
    charsRead += w.length;
    wordIdx++;
    const delay = w.length * msPerChar;
    displayTimer = setTimeout(scheduleNext, Math.max(delay, 60));

  } else if (mode === 'chunk') {
    if (wordIdx >= words.length) { finishReading(); return; }
    const chunk = words.slice(wordIdx, wordIdx + chunkSize);
    const text = chunk.join('　');
    showChunk(text);
    const chars = chunk.join('').length;
    charsRead += chars;
    wordIdx += chunkSize;
    const delay = chars * msPerChar;
    displayTimer = setTimeout(scheduleNext, Math.max(delay, 150));

  } else if (mode === 'scroll') {
    showScroll(wordIdx, chunkSize * 4);
    const chunk = words.slice(wordIdx, wordIdx + chunkSize * 4);
    const chars = chunk.join('').length;
    charsRead += chars;
    wordIdx += chunkSize * 4;
    if (wordIdx >= words.length) { finishReading(); return; }
    const delay = chars * msPerChar;
    displayTimer = setTimeout(scheduleNext, Math.max(delay, 200));
  }
}

// ======= DISPLAY MODES =======
function showRsvp(word) {
  // find pivot letter (usually 1/3 from start)
  const pi = Math.max(0, Math.floor(word.length / 3));
  const before = escHtml(word.slice(0, pi));
  const pivot  = escHtml(word[pi] || '');
  const after  = escHtml(word.slice(pi + 1));
  document.getElementById('display-area').innerHTML =
    `<div class="rsvp-word">${before}<span class="pivot">${pivot}</span>${after}</div>`;
}

function showChunk(text) {
  document.getElementById('display-area').innerHTML =
    `<div class="chunk-text">${escHtml(text)}</div>`;
}

function showScroll(from, size) {
  const before = words.slice(Math.max(0, from - size * 2), from).join('');
  const current = words.slice(from, from + size).join('');
  const after = words.slice(from + size, from + size * 3).join('');
  document.getElementById('display-area').innerHTML =
    `<div class="scroll-text">
      <span style="color:#475569">${escHtml(before)}</span>
      <span class="current-chunk">${escHtml(current)}</span>
      <span style="color:#334155">${escHtml(after)}</span>
    </div>`;
}

// ======= STOP / FINISH =======
function stopReading() {
  if (!running) return;
  running = false;
  clearInterval(tickTimer);
  clearTimeout(displayTimer);
  finishReading();
}

function finishReading() {
  running = false;
  clearInterval(tickTimer);
  clearTimeout(displayTimer);
  document.getElementById('btn-start').style.display = '';
  document.getElementById('btn-stop').style.display = 'none';

  const secs = elapsed || 1;
  const cpm = Math.round(charsRead / secs * 60);
  const wpm = Math.round(cpm / 3);

  let emoji = '📗', comment = 'よいペースです！';
  if (cpm >= 1500) { emoji = '🚀'; comment = '超高速！プロレベル！'; }
  else if (cpm >= 800) { emoji = '⭐'; comment = '高速読書レベル！'; }
  else if (cpm >= 500) { emoji = '📘'; comment = '平均以上のペース！'; }
  else if (cpm >= 300) { emoji = '📗'; comment = '平均的なペースです'; }
  else { emoji = '🐢'; comment = 'ゆっくり丁寧なペース'; }

  document.getElementById('result-emoji').textContent = emoji;
  document.getElementById('result-main').textContent = `${cpm} CPM`;
  document.getElementById('result-sub').textContent = comment;
  document.getElementById('r-cpm').textContent = cpm;
  document.getElementById('r-wpm').textContent = wpm;
  document.getElementById('r-chars').textContent = charsRead;
  document.getElementById('r-time').textContent = Math.round(secs);
  document.getElementById('result-card').classList.add('show');

  // save
  const MODE_LABEL = { rsvp: 'RSVP', chunk: 'チャンク', scroll: 'スクロール' };
  const rec = { date: new Date().toLocaleString('ja-JP'), mode: MODE_LABEL[mode], cpm, wpm, time: Math.round(secs) };
  history.unshift(rec);
  if (history.length > 20) history = history.slice(0,20);
  localStorage.setItem('speed_reading_v1', JSON.stringify(history));
  renderHistory();
}

function resetReading() {
  running = false;
  clearInterval(tickTimer);
  clearTimeout(displayTimer);
  wordIdx = 0; charsRead = 0; elapsed = 0;
  document.getElementById('btn-start').style.display = '';
  document.getElementById('btn-stop').style.display = 'none';
  document.getElementById('result-card').classList.remove('show');
  document.getElementById('countdown-overlay').classList.remove('show');
  document.getElementById('display-area').innerHTML = '<span style="color:#475569">テキストを入力してスタートを押してください</span>';
  document.getElementById('rsvp-progress').style.width = '0%';
  updateStats(0, 0, 0);
}

function updateStats(cpm, wpm, pct) {
  document.getElementById('stat-cpm').textContent = cpm || '--';
  document.getElementById('stat-wpm').textContent = wpm || '--';
  document.getElementById('stat-elapsed').textContent = '0';
  document.getElementById('stat-progress').textContent = pct + '%';
}

function renderHistory() {
  if (history.length === 0) { document.getElementById('history-section').style.display = 'none'; return; }
  document.getElementById('history-section').style.display = '';
  document.getElementById('history-body').innerHTML = history.slice(0,10).map(r =>
    `<tr><td>${r.date}</td><td>${r.mode}</td><td>${r.cpm}</td><td>${r.wpm}</td><td>${r.time}秒</td></tr>`
  ).join('');
}

// init
loadSample(0);
renderHistory();
</script>

