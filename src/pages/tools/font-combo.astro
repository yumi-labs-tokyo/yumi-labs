  const CARD_GRADIENTS = [
    'from-purple-600 to-pink-500',
    'from-blue-600 to-purple-600',
    'from-teal-600 to-blue-600',
    'from-orange-600 to-pink-600',
    'from-green-600 to-teal-600',
  ];

  // ── State ──────────────────────────────────────────────────────────────────
  let currentIndustry = null;
  let loadedFontKeys = new Set();

  // ── Init ───────────────────────────────────────────────────────────────────
  function init() {
    const grid = document.getElementById('industryGrid');
    INDUSTRIES.forEach(ind => {
      const btn = document.createElement('button');
      btn.id = 'ind_' + ind.id;
      btn.className = 'ind-btn py-2.5 px-2 rounded-xl text-xs font-medium border-2 border-white/10 text-gray-400 hover:border-purple-500/50 hover:text-gray-300 transition-all flex flex-col items-center gap-1';
      btn.innerHTML = `<span class="text-lg">${ind.emoji}</span><span>${ind.label}</span>`;
      btn.onclick = () => selectIndustry(ind.id);
      grid.appendChild(btn);
    });

    ['inLogo','inTagline'].forEach(id => {
      document.getElementById(id).addEventListener('input', () => {
        if (currentIndustry) reRender();
      });
    });
  }

  function selectIndustry(id) {
    currentIndustry = id;
    INDUSTRIES.forEach(ind => {
      const b = document.getElementById('ind_' + ind.id);
      if (ind.id === id) {
        b.className = 'ind-btn py-2.5 px-2 rounded-xl text-xs font-medium border-2 border-purple-500 bg-purple-500/20 text-purple-300 transition-all flex flex-col items-center gap-1';
      } else {
        b.className = 'ind-btn py-2.5 px-2 rounded-xl text-xs font-medium border-2 border-white/10 text-gray-400 hover:border-purple-500/50 hover:text-gray-300 transition-all flex flex-col items-center gap-1';
      }
    });

    // Japanese defaults
    const isJa = id === 'japanese';
    const logoInput = document.getElementById('inLogo');
    const tagInput  = document.getElementById('inTagline');
    if (isJa && logoInput.value === 'Brand Name') {
      logoInput.value = 'ブランド名';
      tagInput.value  = 'あなたのスローガン';
    } else if (!isJa && logoInput.value === 'ブランド名') {
      logoInput.value = 'Brand Name';
      tagInput.value  = 'Your slogan here.';
    }

    loadAndRender(id);
  }

  function loadAndRender(industryId) {
    const combos = COMBOS[industryId] || [];
    const key = industryId;

    document.getElementById('placeholder').classList.add('hidden');
    document.getElementById('results').classList.add('hidden');

    if (loadedFontKeys.has(key)) {
      reRender();
      return;
    }

    document.getElementById('loading').classList.remove('hidden');

    // Build Google Fonts URL with all fonts for this industry
    const families = [];
    combos.forEach(c => {
      families.push(`family=${encodeURIComponent(c.main)}:wght@${c.mw}`);
      families.push(`family=${encodeURIComponent(c.sub)}:wght@${c.sw}`);
    });
    const url = `https://fonts.googleapis.com/css2?${families.join('&')}&display=swap`;

    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = url;
    link.onload = () => {
      loadedFontKeys.add(key);
      document.getElementById('loading').classList.add('hidden');
      reRender();
    };
    link.onerror = () => {
      loadedFontKeys.add(key);
      document.getElementById('loading').classList.add('hidden');
      reRender();
    };
    document.head.appendChild(link);

    // Fallback timeout
    setTimeout(() => {
      if (!loadedFontKeys.has(key)) {
        loadedFontKeys.add(key);
        document.getElementById('loading').classList.add('hidden');
        reRender();
      }
    }, 5000);
  }

  function reRender() {
    if (!currentIndustry) return;
    const combos = COMBOS[currentIndustry] || [];
    const logoText   = document.getElementById('inLogo').value || 'Brand Name';
    const taglineText = document.getElementById('inTagline').value || 'Your slogan here.';

    const container = document.getElementById('results');
    container.innerHTML = '';

    combos.forEach((c, i) => {
      const card = buildCard(c, i, logoText, taglineText);
      container.appendChild(card);
    });

    container.classList.remove('hidden');
  }

  function buildCard(c, i, logoText, taglineText) {
    const grad = CARD_GRADIENTS[i % CARD_GRADIENTS.length];
    const importUrl = `https://fonts.googleapis.com/css2?family=${c.main.replace(/ /g,'+')}:wght@${c.mw}&family=${c.sub.replace(/ /g,'+')}:wght@${c.sw}&display=swap`;
    const css = `@import url('${importUrl}');\n\n.logo-main {\n  font-family: '${c.main}', sans-serif;\n  font-weight: ${c.mw};\n}\n.logo-sub {\n  font-family: '${c.sub}', sans-serif;\n  font-weight: ${c.sw};\n}`;

    const card = document.createElement('div');
    card.className = 'bg-white/5 rounded-2xl overflow-hidden border border-white/5 hover:border-purple-500/20 transition-all';
    card.innerHTML = `
      <div class="flex items-center justify-between px-5 pt-4 pb-3">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold text-white bg-gradient-to-br ${grad}">
            ${i + 1}
          </div>
          <div class="text-sm font-semibold text-white">${escHtml(c.name)}</div>
        </div>
        <button onclick="copyCSS(${i})" id="copyBtn${i}"
          class="px-3 py-1.5 rounded-lg text-xs font-medium bg-white/10 text-gray-300 hover:bg-white/20 transition-all">
          CSS コピー
        </button>
      </div>

      <!-- Preview area -->
      <div class="mx-5 mb-4 bg-black/30 rounded-xl p-6 text-center min-h-[120px] flex flex-col items-center justify-center gap-2">
        <div style="font-family:'${c.main}',sans-serif;font-weight:${c.mw};font-size:clamp(1.4rem,4vw,2.2rem);color:#fff;line-height:1.2;word-break:break-all;"
          class="logo-preview-main">${escHtml(logoText)}</div>
        <div style="font-family:'${c.sub}',sans-serif;font-weight:${c.sw};font-size:clamp(0.7rem,2vw,0.95rem);color:#a0a0a0;letter-spacing:0.08em;"
          class="logo-preview-sub">${escHtml(taglineText)}</div>
      </div>

      <!-- Font info -->
      <div class="px-5 pb-4 space-y-3">
        <div class="grid grid-cols-2 gap-3">
          <div class="bg-white/5 rounded-lg p-3">
            <div class="text-xs text-gray-500 mb-1">メインフォント</div>
            <div class="text-sm font-medium text-white" style="font-family:'${c.main}',sans-serif;">${escHtml(c.main)}</div>
            <div class="text-xs text-gray-500 mt-0.5">weight: ${c.mw}</div>
          </div>
          <div class="bg-white/5 rounded-lg p-3">
            <div class="text-xs text-gray-500 mb-1">サブフォント</div>
            <div class="text-sm font-medium text-white" style="font-family:'${c.sub}',sans-serif;">${escHtml(c.sub)}</div>
            <div class="text-xs text-gray-500 mt-0.5">weight: ${c.sw}</div>
          </div>
        </div>
        <div class="flex flex-wrap gap-1.5">
          ${c.tags.map(t => `<span class="px-2 py-0.5 rounded-full text-xs bg-purple-500/15 text-purple-300 border border-purple-500/25">${escHtml(t)}</span>`).join('')}
        </div>
        <div class="text-xs text-gray-400 leading-relaxed">${escHtml(c.desc)}</div>
      </div>
    `;
    // Store CSS for copy
    card.dataset.css = css;
    card.dataset.idx = i;
    return card;
  }

  // Store combo data globally for copy
  window._comboCSSData = {};
  function copyCSS(i) {
    const combos = COMBOS[currentIndustry] || [];
    const c = combos[i];
    if (!c) return;
    const importUrl = `https://fonts.googleapis.com/css2?family=${c.main.replace(/ /g,'+')}:wght@${c.mw}&family=${c.sub.replace(/ /g,'+')}:wght@${c.sw}&display=swap`;
    const text = `/* ${c.name} */\n@import url('${importUrl}');\n\n.logo-main {\n  font-family: '${c.main}', sans-serif;\n  font-weight: ${c.mw};\n}\n.logo-sub {\n  font-family: '${c.sub}', sans-serif;\n  font-weight: ${c.sw};\n}`;
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copyBtn' + i);
      if (!btn) return;
      const orig = btn.textContent;
      btn.textContent = 'コピー済み ✓';
      btn.style.color = '#a78bfa';
      setTimeout(() => { btn.textContent = orig; btn.style.color = ''; }, 1800);
    });
  }

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  init();
</script>
