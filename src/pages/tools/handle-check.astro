---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="SNSハンドルネーム空き確認 | yumi Labs">
  <div class="max-w-3xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="text-center mb-8">
      <div class="text-5xl mb-3">🔍</div>
      <div style="font-size:1.8rem;font-weight:800;color:var(--gray-0);margin-bottom:0.3rem">SNSハンドルネーム空き確認</div>
      <div class="text-gray-400 text-sm">IDを入力するとX / Instagram / TikTok / YouTube / GitHub / Threads の空き状況を一括チェック</div>
    </div>

    <!-- Input -->
    <div class="bg-white/5 rounded-2xl p-5 mb-6">
      <div class="text-xs text-purple-400 font-semibold uppercase tracking-wider mb-3">チェックするユーザー名</div>
      <div class="flex gap-3">
        <div class="relative flex-1">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm font-mono select-none">@</span>
          <input id="inUsername" type="text" placeholder="yourname" maxlength="39"
            class="w-full bg-white/10 rounded-xl pl-8 pr-4 py-3 text-white placeholder-gray-500 border border-white/10 focus:border-purple-400 focus:outline-none font-mono text-sm" />
        </div>
        <button onclick="runCheck()" id="checkBtn"
          class="px-5 py-3 rounded-xl font-bold text-white text-sm transition-all flex-shrink-0"
          style="background: linear-gradient(135deg, #9333ea, #ec4899);">
          チェック
        </button>
      </div>
      <div id="inputHint" class="mt-2 text-xs text-gray-500">英数字・記号は半角で入力。@ は不要です。</div>
    </div>

    <!-- Placeholder -->
    <div id="placeholder" class="bg-white/5 rounded-2xl p-10 text-center">
      <div class="text-4xl mb-3">💡</div>
      <div class="text-gray-400 text-sm mb-1">チェックしたいIDを入力して「チェック」を押してください</div>
      <div class="text-gray-600 text-xs mt-3">GitHub は API で確実に確認。他のプラットフォームはフォーマット検証＋直接リンクで確認できます。</div>
    </div>

    <!-- Loading -->
    <div id="loading" class="hidden bg-white/5 rounded-2xl p-10 text-center">
      <div class="text-4xl mb-3 animate-pulse">⏳</div>
      <div class="text-gray-400 text-sm">確認中...</div>
    </div>

    <!-- Error -->
    <div id="errorBox" class="hidden bg-red-500/10 border border-red-500/30 rounded-2xl p-5 text-red-400 text-sm"></div>

    <!-- Results -->
    <div id="results" class="hidden">
      <div class="flex items-center justify-between mb-4">
        <div class="text-sm text-gray-400">
          <span class="font-mono text-white" id="resultUsername"></span> の確認結果
        </div>
        <button onclick="copyAllUrls()" class="px-3 py-1.5 rounded-lg text-xs bg-white/10 text-gray-300 hover:bg-white/20 transition-all">
          全リンクをコピー
        </button>
      </div>
      <div id="cardsGrid" class="grid grid-cols-1 sm:grid-cols-2 gap-4"></div>

      <!-- Note -->
      <div class="mt-5 bg-yellow-500/10 border border-yellow-500/20 rounded-xl p-4 text-xs text-yellow-300/80 leading-relaxed">
        <span class="font-semibold">ご注意：</span>
        GitHubのみAPIによる確実な確認を行っています。その他のプラットフォームはセキュリティ上の理由により自動確認が困難なため、「開いて確認」ボタンから直接プロフィールページにアクセスして確認してください。
        404ページが表示されれば空き、プロフィールページが表示されれば使用中です。
      </div>
    </div>

  </div>

<section class="tool-seo">
  <div class="seo-inner">
    <div class="seo-block">
      <div class="seo-h2">📌 ツールの概要・特徴</div>
      <p class="seo-p">このツールは、SNS・ゲーム・フォーラムで使いたいハンドルネーム（ユーザー名）が既に使われていないかを複数サービスで一括チェックできる無料Webアプリです。Twitter/X・Instagram・GitHub・TikTokなど主要プラットフォームの名前使用状況を素早く確認できます。</p>
    </div>
    <div class="seo-block">
      <div class="seo-h2">📖 詳しい使い方・手順</div>
      <ol class="seo-ol">
        <li>チェックしたいハンドルネームを入力します。</li>
        <li>確認したいプラットフォームを選択します（デフォルトは主要SNS全て）。</li>
        <li>「チェック開始」ボタンを押すと各サービスの確認が始まります。</li>
        <li>利用可能なサービスは緑、使用済みは赤でリスト表示されます。</li>
        <li>結果を一覧でコピーして記録に残せます。</li>
      </ol>
    </div>
    <div class="seo-block">
      <div class="seo-h2">👤 こんな人におすすめ</div>
      <p class="seo-p">新しいSNSアカウントを作成する際に統一したハンドルネームを使いたい方に最適です。ブランド名・ビジネス名でアカウントを取得したい起業家、クリエイターとして複数SNSで同じ名前を使いたい方、ゲームやフォーラムの登録前に名前の空き状況を確認したい方にもおすすめです。</p>
    </div>
    <div class="seo-block">
      <div class="seo-h2">🛠️ 制作の背景・こだわり</div>
      <p class="seo-p">新しいサービスに登録するたびに「このユーザー名は使えません」と弾かれる経験から開発しました。ハンドルネームの統一はブランディング上重要で、バラバラになると自分でも管理が煩雑になります。主要サービスを一括チェックすることで、登録前に「全サービスで使える名前」を見つけられる設計にしました。</p>
    </div>
  </div>
</section>
</BaseLayout>

<script is:inline>
  const PLATFORMS = {
    twitter:   { label: 'X (Twitter)',  color: '#000',    bg: '#1a1a1a', emoji: '✕' },
    instagram: { label: 'Instagram',    color: '#E1306C', bg: '#1a0d12', emoji: '📸' },
    tiktok:    { label: 'TikTok',       color: '#FF0050', bg: '#1a000a', emoji: '🎵' },
    youtube:   { label: 'YouTube',      color: '#FF0000', bg: '#1a0000', emoji: '▶' },
    github:    { label: 'GitHub',       color: '#6e40c9', bg: '#0d1117', emoji: '🐙' },
    threads:   { label: 'Threads',      color: '#a0a0a0', bg: '#111',    emoji: '🧵' },
  };

  const FORMAT_RULES = {
    twitter:   { min: 1,  max: 15, pattern: /^[a-zA-Z0-9_]+$/,    hint: '1〜15文字・英数字と_のみ' },
    instagram: { min: 1,  max: 30, pattern: /^[a-zA-Z0-9._]+$/,   hint: '1〜30文字・英数字 / . / _' },
    tiktok:    { min: 2,  max: 24, pattern: /^[a-zA-Z0-9._]+$/,   hint: '2〜24文字・英数字 / . / _' },
    youtube:   { min: 3,  max: 30, pattern: /^[a-zA-Z0-9_.-]+$/,  hint: '3〜30文字・英数字 / _ / . / -' },
    github:    { min: 1,  max: 39, pattern: /^[a-zA-Z0-9-]+$/,    hint: '1〜39文字・英数字とハイフン' },
    threads:   { min: 1,  max: 30, pattern: /^[a-zA-Z0-9._]+$/,   hint: '1〜30文字・英数字 / . / _' },
  };

  let lastResults = null;

  // Real-time format hint
  document.getElementById('inUsername').addEventListener('input', function () {
    const v = this.value.trim().replace(/^@/, '');
    if (!v) {
      document.getElementById('inputHint').textContent = '英数字・記号は半角で入力。@ は不要です。';
      return;
    }
    const issues = [];
    Object.entries(FORMAT_RULES).forEach(([p, r]) => {
      if (v.length > r.max) issues.push(`${PLATFORMS[p].label}: ${r.max}文字以内`);
      if (!r.pattern.test(v)) issues.push(`${PLATFORMS[p].label}: 使えない文字が含まれます`);
    });
    const hint = document.getElementById('inputHint');
    if (issues.length > 0) {
      hint.textContent = '⚠ ' + issues.slice(0, 2).join(' / ');
      hint.style.color = '#f97316';
    } else {
      hint.textContent = '✓ 形式OK';
      hint.style.color = '#4ade80';
    }
  });

  document.getElementById('inUsername').addEventListener('keydown', e => {
    if (e.key === 'Enter') runCheck();
  });

  async function runCheck() {
    const raw = document.getElementById('inUsername').value.trim().replace(/^@/, '');
    if (!raw) return;

    setUI('loading');

    try {
      const resp = await fetch('/api/handle-check', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ username: raw }),
      });
      const data = await resp.json();
      if (!resp.ok || data.error) { showError(data.error || 'エラーが発生しました'); return; }

      lastResults = data;
      renderResults(data);
      setUI('results');
    } catch (e) {
      showError('通信エラーが発生しました。再試行してください。');
    }
  }

  function renderResults(data) {
    document.getElementById('resultUsername').textContent = '@' + data.username;
    const grid = document.getElementById('cardsGrid');
    grid.innerHTML = '';

    Object.entries(data.results).forEach(([pid, info]) => {
      const p = PLATFORMS[pid];
      const card = document.createElement('div');
      card.className = 'rounded-2xl p-4 border border-white/10 flex flex-col gap-3';
      card.style.background = p.bg || '#111';

      const { badge, badgeClass } = getStatusBadge(info);

      card.innerHTML = `
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="text-lg">${p.emoji}</span>
            <div>
              <div class="text-sm font-semibold text-white">${escHtml(p.label)}</div>
              <div class="text-xs text-gray-500 font-mono">@${escHtml(data.username)}</div>
            </div>
          </div>
          <span class="${badgeClass} px-2 py-0.5 rounded-full text-xs font-bold">${badge}</span>
        </div>

        ${info.status === 'invalid'
          ? `<div class="text-xs text-orange-400 leading-relaxed">⚠ 形式エラー: ${escHtml(info.hint)}</div>`
          : info.apiChecked
            ? `<div class="text-xs text-purple-300">✓ GitHub API で確認済み</div>`
            : `<div class="text-xs text-gray-500">${escHtml(info.hint)}</div>`
        }

        ${info.status !== 'invalid'
          ? `<a href="${escHtml(info.url)}" target="_blank" rel="noopener noreferrer"
               class="w-full py-2 rounded-lg text-xs font-medium text-center transition-all border border-white/10 text-gray-300 hover:border-purple-400 hover:text-purple-300 block">
               開いて確認 →
             </a>`
          : ''
        }
      `;
      grid.appendChild(card);
    });
  }

  function getStatusBadge(info) {
    if (info.status === 'available')
      return { badge: '✅ 空き', badgeClass: 'bg-green-500/20 text-green-300 border border-green-500/30' };
    if (info.status === 'taken')
      return { badge: '❌ 使用中', badgeClass: 'bg-red-500/20 text-red-300 border border-red-500/30' };
    if (info.status === 'invalid')
      return { badge: '⚠ 形式NG', badgeClass: 'bg-orange-500/20 text-orange-300 border border-orange-500/30' };
    return { badge: '🔗 要確認', badgeClass: 'bg-white/10 text-gray-300 border border-white/20' };
  }

  function copyAllUrls() {
    if (!lastResults) return;
    const lines = Object.entries(lastResults.results)
      .filter(([, info]) => info.status !== 'invalid')
      .map(([pid, info]) => `${PLATFORMS[pid].label}: ${info.url}`);
    navigator.clipboard.writeText(lines.join('\n')).then(() => {
      const btn = document.querySelector('[onclick="copyAllUrls()"]');
      if (!btn) return;
      const orig = btn.textContent;
      btn.textContent = 'コピーしました！';
      setTimeout(() => { btn.textContent = orig; }, 1500);
    });
  }

  function showError(msg) {
    document.getElementById('errorBox').textContent = '⚠ ' + msg;
    setUI('error');
  }

  function setUI(state) {
    ['placeholder','loading','errorBox','results'].forEach(id => {
      document.getElementById(id).classList.add('hidden');
    });
    const btn = document.getElementById('checkBtn');
    if (state === 'loading') {
      document.getElementById('loading').classList.remove('hidden');
      btn.disabled = true; btn.style.opacity = '0.6';
    } else {
      btn.disabled = false; btn.style.opacity = '1';
      if (state === 'results')  document.getElementById('results').classList.remove('hidden');
      else if (state === 'error') document.getElementById('errorBox').classList.remove('hidden');
      else document.getElementById('placeholder').classList.remove('hidden');
    }
  }

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
</script>
