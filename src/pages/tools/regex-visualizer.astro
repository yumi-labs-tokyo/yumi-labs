---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="正規表現ビジュアライザ" description="正規表現を入力すると状態遷移図SVGで表示。マッチ箇所をリアルタイムハイライト。">
<style>
  .container { max-width: 900px; margin: 0 auto; padding: 24px 16px; }
  .hero { text-align: center; margin-bottom: 28px; }
  .hero-title { font-size: 2rem; font-weight: 800; color: var(--gray-0); margin-bottom: 6px; }
  .hero-sub { color: #94a3b8; font-size: 0.92rem; }

  /* input area */
  .input-card { background: #1e293b; border: 1px solid #334155; border-radius: 16px; padding: 20px; margin-bottom: 20px; }
  .input-row { display: flex; gap: 8px; align-items: center; margin-bottom: 12px; flex-wrap: wrap; }
  .regex-prefix { font-family: 'Courier New', monospace; color: #f472b6; font-size: 1.3rem; font-weight: 700; }
  .regex-input {
    flex: 1; min-width: 200px; background: #0f172a; border: 2px solid #334155; border-radius: 10px;
    color: #f472b6; font-family: 'Courier New', monospace; font-size: 1.1rem;
    padding: 10px 14px; outline: none; transition: border-color .2s; caret-color: #f472b6;
  }
  .regex-input:focus { border-color: #f472b6; }
  .regex-input.error { border-color: #f87171; color: #f87171; }
  .flags-input {
    width: 80px; background: #0f172a; border: 2px solid #334155; border-radius: 10px;
    color: #fb923c; font-family: 'Courier New', monospace; font-size: 1.1rem;
    padding: 10px 12px; outline: none; transition: border-color .2s;
  }
  .flags-input:focus { border-color: #fb923c; }
  .error-msg { color: #f87171; font-size: 0.8rem; min-height: 18px; margin-bottom: 8px; }

  /* quick patterns */
  .quick-label { font-size: 0.75rem; color: #64748b; margin-bottom: 8px; }
  .quick-row { display: flex; gap: 6px; flex-wrap: wrap; }
  .quick-btn {
    padding: 4px 10px; border-radius: 6px; border: 1px solid #334155;
    background: #0f172a; color: #94a3b8; cursor: pointer; font-family: 'Courier New', monospace;
    font-size: 0.78rem; transition: all .15s;
  }
  .quick-btn:hover { border-color: #f472b6; color: #f472b6; }

  /* test area */
  .test-card { background: #1e293b; border: 1px solid #334155; border-radius: 16px; padding: 20px; margin-bottom: 20px; }
  .section-title { font-size: 0.85rem; font-weight: 700; color: #94a3b8; margin-bottom: 10px; }
  .test-input {
    width: 100%; box-sizing: border-box; background: #0f172a; border: 2px solid #334155;
    border-radius: 10px; color: var(--gray-0); font-size: 1rem; padding: 12px 14px;
    outline: none; resize: vertical; min-height: 80px; font-family: inherit;
    transition: border-color .2s;
  }
  .test-input:focus { border-color: #6366f1; }
  .highlight-area {
    background: #0f172a; border: 2px solid #334155; border-radius: 10px;
    padding: 12px 14px; font-size: 1rem; line-height: 1.8; min-height: 80px;
    word-break: break-all; margin-top: 10px; color: var(--gray-0);
    font-family: 'Courier New', monospace;
  }
  .match-hl { background: rgba(244,114,182,.25); color: #f9a8d4; border-radius: 3px; border-bottom: 2px solid #f472b6; }
  .match-hl.first { background: rgba(244,114,182,.45); color: #fce7f3; }

  /* stats */
  .match-stats { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 12px; }
  .stat-chip {
    padding: 4px 12px; border-radius: 99px; font-size: 0.78rem; font-weight: 700;
    background: #0f172a; border: 1px solid #334155; color: #94a3b8;
  }
  .stat-chip.found { border-color: #f472b6; color: #f472b6; }

  /* diagram */
  .diagram-card { background: #1e293b; border: 1px solid #334155; border-radius: 16px; padding: 20px; margin-bottom: 20px; overflow: hidden; }
  .diagram-scroll { overflow-x: auto; }
  #svg-container { min-height: 120px; }

  /* token breakdown */
  .breakdown-card { background: #1e293b; border: 1px solid #334155; border-radius: 16px; padding: 20px; margin-bottom: 20px; }
  .token-list { display: flex; gap: 6px; flex-wrap: wrap; }
  .token {
    padding: 6px 12px; border-radius: 8px; font-family: 'Courier New', monospace;
    font-size: 0.85rem; font-weight: 700; border: 1px solid;
  }
  .token-literal  { background: #0c1a2e; border-color: #1d4ed8; color: #93c5fd; }
  .token-meta     { background: #1c0533; border-color: #7c3aed; color: #c4b5fd; }
  .token-class    { background: #0f2810; border-color: #16a34a; color: #86efac; }
  .token-quant    { background: #1c1407; border-color: #d97706; color: #fcd34d; }
  .token-anchor   { background: #0c1e1e; border-color: #0891b2; color: #67e8f9; }
  .token-group    { background: #1c0a0a; border-color: #dc2626; color: #fca5a5; }
  .token-alt      { background: #1c1407; border-color: #ca8a04; color: #fde047; }
  .token-desc     { font-size: 0.72rem; font-weight: 400; color: inherit; opacity: .7; display: block; margin-top: 2px; }

  /* legend */
  .legend { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 14px; }
  .legend-item { display: flex; align-items: center; gap: 5px; font-size: 0.75rem; color: #64748b; }
  .legend-dot { width: 10px; height: 10px; border-radius: 2px; }
</style>

<div class="container">
  <div class="hero">
    <div class="hero-title">🔢 正規表現ビジュアライザ</div>
    <div class="hero-sub">正規表現をリアルタイム解析・状態遷移図表示・マッチハイライト</div>
  </div>

  <!-- regex input -->
  <div class="input-card">
    <div class="input-row">
      <span class="regex-prefix">/</span>
      <input type="text" class="regex-input" id="regex-input" value="(hello|world)\s+\w+" placeholder="正規表現を入力..." autocomplete="off" spellcheck="false" />
      <span class="regex-prefix">/</span>
      <input type="text" class="flags-input" id="flags-input" value="gi" placeholder="gim" autocomplete="off" spellcheck="false" maxlength="6" />
    </div>
    <div class="error-msg" id="error-msg"></div>
    <div class="quick-label">よく使うパターン：</div>
    <div class="quick-row" id="quick-row"></div>
  </div>

  <!-- test string -->
  <div class="test-card">
    <div class="section-title">テスト文字列</div>
    <textarea class="test-input" id="test-input" placeholder="マッチ対象の文字列を入力...">Hello world today, hello WORLD tomorrow! foo@bar.com 123-456-7890</textarea>
    <div class="section-title" style="margin-top:14px">マッチ結果</div>
    <div class="highlight-area" id="highlight-area"></div>
    <div class="match-stats" id="match-stats"></div>
  </div>

  <!-- diagram -->
  <div class="diagram-card">
    <div class="section-title">状態遷移図（NFA構造）</div>
    <div class="diagram-scroll"><div id="svg-container"></div></div>
  </div>

  <!-- breakdown -->
  <div class="breakdown-card">
    <div class="section-title">トークン解析</div>
    <div class="token-list" id="token-list"></div>
    <div class="legend" id="legend"></div>
  </div>
</div>

<script is:inline>
// ======= QUICK PATTERNS =======
const QUICK = [
  { label: 'メール', pattern: '[\\w.+]+@[\\w.]+\\.[a-z]{2,}', flags: 'gi' },
  { label: 'URL', pattern: 'https?:\\/\\/[\\w./\\-?=&%#]+', flags: 'gi' },
  { label: '日本語', pattern: '[\\u3040-\\u309F\\u30A0-\\u30FF\\u4E00-\\u9FFF]+', flags: 'g' },
  { label: '電話番号', pattern: '\\d{2,4}[-−]\\d{2,4}[-−]\\d{4}', flags: 'g' },
  { label: '郵便番号', pattern: '\\d{3}-?\\d{4}', flags: 'g' },
  { label: 'IPアドレス', pattern: '\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b', flags: 'g' },
  { label: '16進数', pattern: '#[0-9a-fA-F]{3,6}\\b', flags: 'g' },
  { label: '数字列', pattern: '\\d+', flags: 'g' },
  { label: '英単語', pattern: '\\b[a-zA-Z]+\\b', flags: 'g' },
  { label: '空白', pattern: '\\s+', flags: 'g' },
];

// ======= TOKEN TYPES =======
const TOKEN_COLORS = {
  literal:  { cls: 'token-literal',  label: 'リテラル' },
  meta:     { cls: 'token-meta',     label: 'メタ文字' },
  class:    { cls: 'token-class',    label: '文字クラス' },
  quant:    { cls: 'token-quant',    label: '量指定子' },
  anchor:   { cls: 'token-anchor',   label: 'アンカー' },
  group:    { cls: 'token-group',    label: 'グループ' },
  alt:      { cls: 'token-alt',      label: '選択' },
};

// ======= TOKENIZER =======
function tokenize(pattern) {
  const tokens = [];
  let i = 0;
  while (i < pattern.length) {
    const ch = pattern[i];

    // escape sequence
    if (ch === '\\' && i + 1 < pattern.length) {
      const next = pattern[i+1];
      let desc = '';
      if (next === 'd') desc = '数字 [0-9]';
      else if (next === 'D') desc = '非数字';
      else if (next === 'w') desc = '単語文字 [a-zA-Z0-9_]';
      else if (next === 'W') desc = '非単語文字';
      else if (next === 's') desc = '空白文字';
      else if (next === 'S') desc = '非空白文字';
      else if (next === 'b') desc = '単語境界';
      else if (next === 'B') desc = '非単語境界';
      else if (next === 'n') desc = '改行';
      else if (next === 't') desc = 'タブ';
      else if (next === 'r') desc = 'CR';
      else desc = `\\${next} をエスケープ`;
      tokens.push({ text: '\\' + next, type: next === 'b' || next === 'B' ? 'anchor' : 'meta', desc });
      i += 2;
      continue;
    }

    // character class
    if (ch === '[') {
      let j = i + 1;
      if (j < pattern.length && pattern[j] === '^') j++;
      while (j < pattern.length && pattern[j] !== ']') {
        if (pattern[j] === '\\') j++;
        j++;
      }
      const raw = pattern.slice(i, j + 1);
      tokens.push({ text: raw, type: 'class', desc: '文字クラス' });
      i = j + 1;
      continue;
    }

    // group
    if (ch === '(') {
      let desc = 'キャプチャグループ';
      if (pattern.slice(i, i+3) === '(?:') desc = '非キャプチャグループ';
      else if (pattern.slice(i, i+3) === '(?=') desc = '先読みアサーション';
      else if (pattern.slice(i, i+4) === '(?!=') desc = '否定先読み';
      else if (pattern.slice(i, i+3) === '(?<') desc = '後読みアサーション';
      tokens.push({ text: '(', type: 'group', desc });
      i++;
      continue;
    }
    if (ch === ')') {
      tokens.push({ text: ')', type: 'group', desc: 'グループ終端' });
      i++; continue;
    }

    // alternation
    if (ch === '|') {
      tokens.push({ text: '|', type: 'alt', desc: '選択（OR）' });
      i++; continue;
    }

    // anchors
    if (ch === '^') { tokens.push({ text: '^', type: 'anchor', desc: '行頭' }); i++; continue; }
    if (ch === '$') { tokens.push({ text: '$', type: 'anchor', desc: '行末' }); i++; continue; }

    // quantifiers
    if ('*+?'.includes(ch)) {
      let text = ch;
      let desc = ch === '*' ? '0回以上' : ch === '+' ? '1回以上' : '0または1回';
      if (pattern[i+1] === '?') { text += '?'; desc += '（最短一致）'; i++; }
      tokens.push({ text, type: 'quant', desc });
      i++; continue;
    }
    if (ch === '{') {
      let j = i + 1;
      while (j < pattern.length && pattern[j] !== '}') j++;
      const raw = pattern.slice(i, j + 1);
      const inner = pattern.slice(i+1, j);
      let desc = '';
      if (inner.includes(',')) {
        const [a, b] = inner.split(',');
        desc = b ? `${a}〜${b}回` : `${a}回以上`;
      } else {
        desc = `ちょうど${inner}回`;
      }
      tokens.push({ text: raw, type: 'quant', desc });
      i = j + 1; continue;
    }

    // dot
    if (ch === '.') {
      tokens.push({ text: '.', type: 'meta', desc: '任意の1文字（改行以外）' });
      i++; continue;
    }

    // literal
    tokens.push({ text: ch, type: 'literal', desc: `文字 "${ch}"` });
    i++;
  }
  return tokens;
}

// ======= NFA BUILDER FOR VISUALIZATION =======
// Builds a simple NFA-like node graph from tokens
function buildNFAGraph(tokens) {
  // Simplified structural graph (not full NFA, but visually informative)
  const nodes = [];
  const edges = [];
  let idCounter = 0;
  const newNode = (label, kind) => {
    const n = { id: idCounter++, label, kind };
    nodes.push(n);
    return n;
  };

  const start = newNode('START', 'start');
  let prev = [start];

  let depth = 0;
  const groupStarts = [];

  const connect = (froms, to, label = '') => {
    froms.forEach(f => edges.push({ from: f.id, to: to.id, label }));
  };

  let i = 0;
  while (i < tokens.length) {
    const tok = tokens[i];

    if (tok.type === 'group' && tok.text === '(') {
      const gs = newNode('(', 'group-open');
      connect(prev, gs, '');
      groupStarts.push({ node: gs, prevs: prev });
      prev = [gs];
      i++; continue;
    }
    if (tok.type === 'group' && tok.text === ')') {
      const ge = newNode(')', 'group-close');
      connect(prev, ge, '');
      if (groupStarts.length) groupStarts.pop();
      prev = [ge];
      i++; continue;
    }
    if (tok.type === 'alt') {
      // Save current branch end, go back to last group start
      const altNode = newNode('|', 'alt');
      if (groupStarts.length) {
        const gs = groupStarts[groupStarts.length - 1];
        connect(prev, altNode, '');
        connect([gs.node], altNode, 'alt');
        prev = [altNode];
      } else {
        connect(prev, altNode, '');
        connect([start], altNode, 'alt');
        prev = [altNode];
      }
      i++; continue;
    }

    // normal token
    let label = tok.text;
    if (label.length > 12) label = label.slice(0, 10) + '…';
    const n = newNode(label, tok.type);
    connect(prev, n, tok.type === 'quant' ? tok.text : '');
    prev = [n];

    // if next token is quantifier, mark the node
    if (i + 1 < tokens.length && tokens[i+1].type === 'quant') {
      n.quant = tokens[i+1].text;
      i += 2;
    } else {
      i++;
    }
    continue;
  }

  const end = newNode('END', 'end');
  connect(prev, end, '');
  return { nodes, edges };
}

// ======= SVG RENDERER =======
function renderSVG(nodes, edges) {
  if (nodes.length === 0) return '';

  const NODE_W = 80, NODE_H = 36, H_GAP = 30, V_GAP = 60;
  // Layout: simple left-to-right chain
  const cols = [];
  let col = 0;
  nodes.forEach((n, i) => {
    n.col = i;
    n.row = 0;
  });

  // Simple sequential layout
  const totalW = nodes.length * (NODE_W + H_GAP) + 40;
  const totalH = 120;

  const nx = i => 20 + i * (NODE_W + H_GAP);
  const ny = () => 40;

  const escSvg = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

  const nodeColor = {
    start:       { fill: '#1a2e1a', stroke: '#4ade80' },
    end:         { fill: '#1a2e1a', stroke: '#4ade80' },
    literal:     { fill: '#0c1a2e', stroke: '#1d4ed8' },
    meta:        { fill: '#1c0533', stroke: '#7c3aed' },
    class:       { fill: '#0f2810', stroke: '#16a34a' },
    quant:       { fill: '#1c1407', stroke: '#d97706' },
    anchor:      { fill: '#0c1e1e', stroke: '#0891b2' },
    'group-open':  { fill: '#1c0a0a', stroke: '#dc2626' },
    'group-close': { fill: '#1c0a0a', stroke: '#dc2626' },
    alt:         { fill: '#1c1407', stroke: '#ca8a04' },
  };

  let edgeSvg = '';
  edges.forEach(e => {
    const fn = nodes[e.from], tn = nodes[e.to];
    if (!fn || !tn) return;
    const x1 = nx(fn.col) + NODE_W;
    const y1 = ny() + NODE_H / 2;
    const x2 = nx(tn.col);
    const y2 = ny() + NODE_H / 2;
    const mx = (x1 + x2) / 2;
    // curved if same row
    const cy = y1 - 20;
    edgeSvg += `<path d="M${x1},${y1} Q${mx},${cy} ${x2},${y2}" fill="none" stroke="#475569" stroke-width="1.5" marker-end="url(#arrow)"/>`;
    if (e.label) {
      edgeSvg += `<text x="${mx}" y="${cy - 4}" text-anchor="middle" font-size="9" fill="#64748b">${escSvg(e.label)}</text>`;
    }
  });

  let nodeSvg = '';
  nodes.forEach(n => {
    const x = nx(n.col), y = ny();
    const c = nodeColor[n.kind] || nodeColor.literal;
    const rx = n.kind === 'start' || n.kind === 'end' ? 18 : 6;
    let displayLabel = n.label;
    if (n.quant) displayLabel += n.quant;
    nodeSvg += `
      <rect x="${x}" y="${y}" width="${NODE_W}" height="${NODE_H}" rx="${rx}"
        fill="${c.fill}" stroke="${c.stroke}" stroke-width="1.5"/>
      <text x="${x + NODE_W/2}" y="${y + NODE_H/2 + 4}" text-anchor="middle"
        font-family="Courier New,monospace" font-size="11" fill="#e2e8f0">${escSvg(displayLabel)}</text>
    `;
  });

  return `
  <svg width="${totalW}" height="${totalH}" xmlns="http://www.w3.org/2000/svg" style="max-width:100%">
    <defs>
      <marker id="arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="#475569"/>
      </marker>
    </defs>
    ${edgeSvg}
    ${nodeSvg}
  </svg>`;
}

// ======= HIGHLIGHT =======
function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function highlightMatches(text, re) {
  if (!re) return { html: escHtml(text), count: 0, groups: [] };
  const matches = [];
  let m;
  const safeRe = new RegExp(re.source, re.flags.replace('g','') + 'g');
  while ((m = safeRe.exec(text)) !== null) {
    matches.push({ start: m.index, end: m.index + m[0].length, text: m[0] });
    if (m[0].length === 0) safeRe.lastIndex++;
  }
  if (matches.length === 0) return { html: escHtml(text), count: 0 };

  let html = '', pos = 0, idx = 0;
  matches.forEach((match, i) => {
    if (pos < match.start) html += escHtml(text.slice(pos, match.start));
    const cls = i === 0 ? 'match-hl first' : 'match-hl';
    html += `<mark class="${cls}">${escHtml(match.text)}</mark>`;
    pos = match.end;
    idx++;
  });
  if (pos < text.length) html += escHtml(text.slice(pos));
  return { html, count: matches.length, matches };
}

// ======= MAIN UPDATE =======
function update() {
  const patternRaw = document.getElementById('regex-input').value;
  const flags = document.getElementById('flags-input').value.replace(/[^gimsuy]/g,'');
  const testStr = document.getElementById('test-input').value;
  const errEl = document.getElementById('error-msg');

  // parse regex
  let re = null;
  try {
    re = new RegExp(patternRaw, flags);
    document.getElementById('regex-input').classList.remove('error');
    errEl.textContent = '';
  } catch(e) {
    document.getElementById('regex-input').classList.add('error');
    errEl.textContent = '⚠️ ' + e.message;
  }

  // highlight
  const { html, count, matches } = re
    ? highlightMatches(testStr, re)
    : { html: escHtml(testStr), count: 0 };
  document.getElementById('highlight-area').innerHTML = html;

  // stats
  const statsEl = document.getElementById('match-stats');
  if (re) {
    let statsHtml = `<span class="stat-chip ${count > 0 ? 'found' : ''}">${count > 0 ? `✅ ${count}件マッチ` : '❌ マッチなし'}</span>`;
    if (matches && matches.length > 0) {
      statsHtml += `<span class="stat-chip">最初: "${escHtml(matches[0].text.slice(0,30))}"</span>`;
      if (matches.length > 1) {
        statsHtml += `<span class="stat-chip">位置: ${matches.map(m => m.start).slice(0,5).join(', ')}${matches.length > 5 ? '...' : ''}</span>`;
      }
    }
    statsEl.innerHTML = statsHtml;
  } else {
    statsEl.innerHTML = '';
  }

  // tokenize
  let tokens = [];
  try { tokens = tokenize(patternRaw); } catch(e) {}
  renderTokens(tokens);

  // diagram
  try {
    if (patternRaw && tokens.length > 0) {
      const { nodes, edges } = buildNFAGraph(tokens);
      document.getElementById('svg-container').innerHTML = renderSVG(nodes, edges);
    } else {
      document.getElementById('svg-container').innerHTML = '<p style="color:#475569;padding:20px;text-align:center">正規表現を入力すると状態遷移図が表示されます</p>';
    }
  } catch(e) {
    document.getElementById('svg-container').innerHTML = '<p style="color:#475569;padding:20px;text-align:center">図を生成できませんでした</p>';
  }
}

function renderTokens(tokens) {
  const list = document.getElementById('token-list');
  if (tokens.length === 0) {
    list.innerHTML = '<span style="color:#475569;font-size:.85rem">パターンを入力するとここにトークン解析が表示されます</span>';
    return;
  }
  list.innerHTML = tokens.map(tok => {
    const tc = TOKEN_COLORS[tok.type] || TOKEN_COLORS.literal;
    return `<div class="token ${tc.cls}">${escHtml(tok.text)}<span class="token-desc">${tok.desc}</span></div>`;
  }).join('');

  // legend
  const usedTypes = [...new Set(tokens.map(t => t.type))];
  document.getElementById('legend').innerHTML = usedTypes.map(t => {
    const tc = TOKEN_COLORS[t];
    if (!tc) return '';
    return `<div class="legend-item"><div class="legend-dot" style="background:${getComputedStyle(document.documentElement).getPropertyValue('--tw') || '#334155'};border:1px solid"></div>${tc.label}</div>`;
  }).join('');
}

// ======= QUICK PATTERNS =======
function buildQuick() {
  document.getElementById('quick-row').innerHTML = QUICK.map(q =>
    `<button class="quick-btn" onclick="applyQuick('${q.pattern.replace(/'/g,"\\'")}','${q.flags}')">${q.label}</button>`
  ).join('');
}

function applyQuick(pattern, flags) {
  document.getElementById('regex-input').value = pattern;
  document.getElementById('flags-input').value = flags;
  update();
}

// ======= EVENTS =======
document.getElementById('regex-input').addEventListener('input', update);
document.getElementById('flags-input').addEventListener('input', update);
document.getElementById('test-input').addEventListener('input', update);

buildQuick();
update();
</script>

