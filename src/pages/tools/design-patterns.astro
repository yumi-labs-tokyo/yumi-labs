---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="デザインパターン学習カード（GoF 23種）" description="GoF 23種のデザインパターンをUML図＋TypeScriptコード例＋使うべき場面で学習。1日1パターン習得。">
<style>
  .container { max-width: 900px; margin: 0 auto; padding: 24px 16px; }
  .hero { text-align: center; margin-bottom: 24px; }
  .hero-title { font-size: 2rem; font-weight: 800; color: #e2e8f0; margin-bottom: 6px; }
  .hero-sub { color: #94a3b8; font-size: 0.92rem; }

  /* category tabs */
  .cat-row { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; margin-bottom: 16px; }
  .cat-btn {
    padding: 7px 16px; border-radius: 20px; border: 1px solid #334155;
    background: #1e293b; color: #64748b; cursor: pointer; font-size: 0.82rem; font-weight: 700;
    transition: all .2s;
  }
  .cat-btn.creational { color: #86efac; }
  .cat-btn.structural  { color: #93c5fd; }
  .cat-btn.behavioral  { color: #c4b5fd; }
  .cat-btn.active      { border-color: currentColor; background: #0f172a; }

  /* pattern grid */
  .pattern-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 8px; margin-bottom: 24px; }
  .pattern-chip {
    padding: 8px 10px; border-radius: 10px; border: 2px solid #334155;
    background: #1e293b; cursor: pointer; text-align: center; transition: all .2s;
  }
  .pattern-chip:hover { border-color: #6366f1; }
  .pattern-chip.active { border-color: #6366f1; background: #1e1b4b; }
  .pattern-chip.learned { border-color: #4ade80; background: #052e16; }
  .chip-name { font-size: 0.8rem; font-weight: 700; color: #e2e8f0; }
  .chip-cat  { font-size: 0.65rem; color: #64748b; margin-top: 2px; }
  .chip-check{ font-size: 0.7rem; }

  /* today badge */
  .today-row { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; }
  .today-badge {
    padding: 5px 14px; border-radius: 99px; background: #1c1407; border: 1px solid #f59e0b;
    color: #fbbf24; font-size: 0.78rem; font-weight: 700;
  }
  .progress-label { font-size: 0.8rem; color: #64748b; }
  .progress-bar-wrap { flex: 1; background: #1e293b; border-radius: 99px; height: 6px; overflow: hidden; min-width: 100px; }
  .progress-bar-fill { height: 100%; background: linear-gradient(90deg,#4ade80,#22d3ee); border-radius: 99px; transition: width .4s; }

  /* card */
  .card { background: #1e293b; border: 1px solid #334155; border-radius: 16px; overflow: hidden; }
  .card-header { padding: 18px 20px; border-bottom: 1px solid #334155; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .card-cat-badge {
    padding: 3px 10px; border-radius: 99px; font-size: 0.72rem; font-weight: 700;
  }
  .cat-creational { background: #052e16; color: #4ade80; border: 1px solid #4ade80; }
  .cat-structural  { background: #0c1a2e; color: #38bdf8; border: 1px solid #38bdf8; }
  .cat-behavioral  { background: #1c0533; color: #c4b5fd; border: 1px solid #a78bfa; }
  .card-name { font-size: 1.4rem; font-weight: 800; color: #e2e8f0; }
  .card-en   { font-size: 0.85rem; color: #64748b; }
  .card-learn-btn {
    margin-left: auto; padding: 6px 16px; border-radius: 8px; border: 1px solid #4ade80;
    background: transparent; color: #4ade80; cursor: pointer; font-size: 0.8rem; font-weight: 700;
    transition: all .2s;
  }
  .card-learn-btn.learned { background: #052e16; }
  .card-learn-btn:hover { background: #052e16; }

  .card-body { padding: 20px; }

  /* intent */
  .intent-box { background: #0f172a; border-left: 3px solid #6366f1; border-radius: 0 8px 8px 0; padding: 12px 16px; margin-bottom: 16px; color: #94a3b8; font-size: 0.9rem; line-height: 1.7; }

  /* UML */
  .uml-section { margin-bottom: 16px; }
  .section-title { font-size: 0.78rem; font-weight: 700; color: #64748b; letter-spacing: .06em; margin-bottom: 8px; text-transform: uppercase; }
  .uml-wrap { background: #0f172a; border-radius: 10px; padding: 16px; overflow-x: auto; }
  .uml-svg-wrap { min-height: 80px; display: flex; align-items: center; justify-content: center; }

  /* code */
  .code-section { margin-bottom: 16px; }
  .code-block {
    background: #0f172a; border-radius: 10px; padding: 16px;
    font-family: 'Courier New', monospace; font-size: 0.82rem; line-height: 1.7;
    overflow-x: auto; position: relative; color: #e2e8f0;
  }
  .copy-btn {
    position: absolute; top: 8px; right: 8px;
    padding: 3px 10px; border-radius: 6px; border: 1px solid #334155;
    background: #1e293b; color: #94a3b8; cursor: pointer; font-size: 0.7rem;
  }
  .copy-btn:hover { border-color: #6366f1; color: #a5b4fc; }
  /* syntax */
  .kw  { color: #c4b5fd; }
  .ty  { color: #38bdf8; }
  .st  { color: #86efac; }
  .cm  { color: #475569; font-style: italic; }
  .fn  { color: #fbbf24; }

  /* when to use */
  .when-section { margin-bottom: 8px; }
  .when-list { list-style: none; padding: 0; margin: 0; }
  .when-list li { display: flex; gap: 8px; color: #94a3b8; font-size: 0.88rem; line-height: 1.6; margin-bottom: 6px; }
  .when-list li::before { content: '✅'; flex-shrink: 0; }

  /* pros cons */
  .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 14px; }
  @media(max-width:500px){ .pros-cons { grid-template-columns: 1fr; } }
  .pros-box { background: #052e16; border: 1px solid #4ade80; border-radius: 10px; padding: 12px; }
  .cons-box { background: #450a0a; border: 1px solid #f87171; border-radius: 10px; padding: 12px; }
  .pc-title { font-size: 0.75rem; font-weight: 700; margin-bottom: 6px; }
  .pc-title.pro { color: #4ade80; }
  .pc-title.con { color: #f87171; }
  .pc-item { font-size: 0.8rem; color: #94a3b8; margin-bottom: 4px; line-height: 1.5; }

  /* related */
  .related-row { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 12px; }
  .related-chip {
    padding: 3px 10px; border-radius: 6px; background: #1e293b; border: 1px solid #334155;
    color: #64748b; font-size: 0.75rem; cursor: pointer; transition: all .15s;
  }
  .related-chip:hover { border-color: #6366f1; color: #a5b4fc; }

  /* nav */
  .nav-row { display: flex; gap: 8px; justify-content: center; margin-top: 16px; flex-wrap: wrap; }
  .nav-btn {
    padding: 9px 20px; border-radius: 10px; border: 1px solid #334155;
    background: #1e293b; color: #94a3b8; cursor: pointer; font-size: 0.88rem; font-weight: 700;
    transition: all .2s;
  }
  .nav-btn:hover { border-color: #6366f1; color: #a5b4fc; }
  .nav-btn.primary { background: linear-gradient(135deg,#6366f1,#8b5cf6); color: #fff; border: none; }

  .empty-state { text-align: center; padding: 40px; color: #475569; }
</style>

<div class="container">
  <div class="hero">
    <div class="hero-title">🧩 デザインパターン学習カード</div>
    <div class="hero-sub">GoF 23種 — UML図 + TypeScriptコード + 使うべき場面</div>
  </div>

  <!-- progress -->
  <div class="today-row">
    <div class="today-badge" id="today-badge">📅 今日のパターン</div>
    <div class="progress-label" id="progress-label">0 / 23 習得</div>
    <div class="progress-bar-wrap"><div class="progress-bar-fill" id="progress-fill" style="width:0%"></div></div>
  </div>

  <!-- category filter -->
  <div class="cat-row">
    <button class="cat-btn active" onclick="filterCat('all')" id="cat-all">すべて</button>
    <button class="cat-btn creational" onclick="filterCat('creational')" id="cat-creational">生成 (5)</button>
    <button class="cat-btn structural"  onclick="filterCat('structural')"  id="cat-structural">構造 (7)</button>
    <button class="cat-btn behavioral"  onclick="filterCat('behavioral')"  id="cat-behavioral">振る舞い (11)</button>
  </div>

  <!-- pattern chips -->
  <div class="pattern-grid" id="pattern-grid"></div>

  <!-- main card -->
  <div class="card" id="main-card">
    <div id="card-inner"></div>
  </div>

  <!-- nav -->
  <div class="nav-row">
    <button class="nav-btn" onclick="prevPattern()">← 前へ</button>
    <button class="nav-btn primary" onclick="markLearned()">✅ 習得済みにする</button>
    <button class="nav-btn" onclick="nextPattern()">次へ →</button>
  </div>
</div>

<script is:inline>
// ======= PATTERNS DATA =======
const PATTERNS = [
  // ── 生成パターン ──
  {
    id: 'singleton', name: 'Singleton', ja: 'シングルトン', cat: 'creational',
    intent: 'クラスのインスタンスが必ずひとつだけ存在することを保証し、そのインスタンスへのグローバルなアクセスポイントを提供する。',
    uml: `<svg viewBox="0 0 320 100" width="100%" style="max-width:320px" xmlns="http://www.w3.org/2000/svg">
      <rect x="80" y="10" width="160" height="80" rx="4" fill="#1e293b" stroke="#6366f1" stroke-width="1.5"/>
      <text x="160" y="32" text-anchor="middle" font-size="13" font-weight="700" fill="#e2e8f0">Singleton</text>
      <line x1="80" y1="40" x2="240" y2="40" stroke="#334155"/>
      <text x="90" y="58" font-size="10" fill="#94a3b8">- instance: Singleton</text>
      <line x1="80" y1="65" x2="240" y2="65" stroke="#334155"/>
      <text x="90" y="82" font-size="10" fill="#fbbf24">+ getInstance(): Singleton</text>
    </svg>`,
    code: `<span class="kw">class</span> <span class="ty">Singleton</span> {
  <span class="kw">private static</span> instance: <span class="ty">Singleton</span>;

  <span class="kw">private constructor</span>() {} <span class="cm">// 外部からnew不可</span>

  <span class="kw">static</span> <span class="fn">getInstance</span>(): <span class="ty">Singleton</span> {
    <span class="kw">if</span> (!<span class="ty">Singleton</span>.instance) {
      <span class="ty">Singleton</span>.instance = <span class="kw">new</span> <span class="ty">Singleton</span>();
    }
    <span class="kw">return</span> <span class="ty">Singleton</span>.instance;
  }
}

<span class="cm">// 使い方</span>
<span class="kw">const</span> a = <span class="ty">Singleton</span>.<span class="fn">getInstance</span>();
<span class="kw">const</span> b = <span class="ty">Singleton</span>.<span class="fn">getInstance</span>();
console.<span class="fn">log</span>(a === b); <span class="cm">// true</span>`,
    when: ['設定管理クラス（AppConfig）を1つだけ持ちたい', 'DBコネクションプールを共有したい', 'ロガーをグローバルに1つ管理したい'],
    pros: ['インスタンスが1つに保証される', 'グローバルアクセスポイントが明確'],
    cons: ['テストが難しくなる（モック困難）', 'グローバル状態による副作用リスク'],
    related: ['Factory Method', 'Prototype'],
  },
  {
    id: 'factory-method', name: 'Factory Method', ja: 'ファクトリーメソッド', cat: 'creational',
    intent: 'オブジェクトを生成するためのインターフェースを定義するが、どのクラスをインスタンス化するかはサブクラスに決めさせる。',
    uml: `<svg viewBox="0 0 340 130" width="100%" style="max-width:340px" xmlns="http://www.w3.org/2000/svg">
      <rect x="10" y="10" width="140" height="55" rx="4" fill="#1e293b" stroke="#4ade80" stroke-width="1.5"/>
      <text x="80" y="30" text-anchor="middle" font-size="11" fill="#86efac">«interface»</text>
      <text x="80" y="46" text-anchor="middle" font-size="12" font-weight="700" fill="#e2e8f0">Creator</text>
      <text x="20" y="58" font-size="10" fill="#fbbf24">+ createProduct()</text>
      <rect x="190" y="10" width="140" height="55" rx="4" fill="#1e293b" stroke="#4ade80" stroke-width="1.5"/>
      <text x="260" y="30" text-anchor="middle" font-size="11" fill="#86efac">«interface»</text>
      <text x="260" y="46" text-anchor="middle" font-size="12" font-weight="700" fill="#e2e8f0">Product</text>
      <rect x="30" y="90" width="100" height="35" rx="4" fill="#1e293b" stroke="#334155" stroke-width="1.5"/>
      <text x="80" y="112" text-anchor="middle" font-size="11" fill="#94a3b8">ConcreteCreator</text>
      <rect x="210" y="90" width="100" height="35" rx="4" fill="#1e293b" stroke="#334155" stroke-width="1.5"/>
      <text x="260" y="112" text-anchor="middle" font-size="11" fill="#94a3b8">ConcreteProduct</text>
      <line x1="80" y1="65" x2="80" y2="90" stroke="#4ade80" stroke-dasharray="4"/>
      <line x1="260" y1="65" x2="260" y2="90" stroke="#4ade80" stroke-dasharray="4"/>
      <line x1="150" y1="37" x2="190" y2="37" stroke="#6366f1" stroke-dasharray="4" marker-end="url(#arr)"/>
      <defs><marker id="arr" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto"><path d="M0,0 L0,6 L6,3 z" fill="#6366f1"/></marker></defs>
    </svg>`,
    code: `<span class="kw">interface</span> <span class="ty">Button</span> { <span class="fn">render</span>(): <span class="ty">void</span>; }

<span class="kw">class</span> <span class="ty">WindowsButton</span> <span class="kw">implements</span> <span class="ty">Button</span> {
  <span class="fn">render</span>() { console.<span class="fn">log</span>(<span class="st">"Windows ボタン"</span>); }
}
<span class="kw">class</span> <span class="ty">MacButton</span> <span class="kw">implements</span> <span class="ty">Button</span> {
  <span class="fn">render</span>() { console.<span class="fn">log</span>(<span class="st">"Mac ボタン"</span>); }
}

<span class="kw">abstract class</span> <span class="ty">Dialog</span> {
  <span class="kw">abstract</span> <span class="fn">createButton</span>(): <span class="ty">Button</span>; <span class="cm">// Factory Method</span>
  <span class="fn">render</span>() { <span class="kw">this</span>.<span class="fn">createButton</span>().<span class="fn">render</span>(); }
}

<span class="kw">class</span> <span class="ty">WindowsDialog</span> <span class="kw">extends</span> <span class="ty">Dialog</span> {
  <span class="fn">createButton</span>() { <span class="kw">return new</span> <span class="ty">WindowsButton</span>(); }
}`,
    when: ['生成するオブジェクトの型を事前に確定できない', 'サブクラスにオブジェクト生成を委譲したい', 'プラグインや拡張可能なフレームワークを作る'],
    pros: ['生成と利用を分離できる', 'Open/Closed 原則に従いやすい'],
    cons: ['クラス数が増える', 'シンプルな場合は過剰設計になりがち'],
    related: ['Abstract Factory', 'Template Method'],
  },
  {
    id: 'abstract-factory', name: 'Abstract Factory', ja: 'アブストラクトファクトリー', cat: 'creational',
    intent: '関連するオブジェクト群を、具体的なクラスを指定せずに生成するためのインターフェースを提供する。',
    uml: `<svg viewBox="0 0 320 80" width="100%" style="max-width:320px" xmlns="http://www.w3.org/2000/svg">
      <rect x="10" y="10" width="130" height="60" rx="4" fill="#1e293b" stroke="#4ade80" stroke-width="1.5"/>
      <text x="75" y="32" text-anchor="middle" font-size="10" fill="#86efac">«interface»</text>
      <text x="75" y="48" text-anchor="middle" font-size="12" font-weight="700" fill="#e2e8f0">AbstractFactory</text>
      <text x="20" y="64" font-size="9" fill="#fbbf24">+createA() +createB()</text>
      <rect x="180" y="10" width="130" height="60" rx="4" fill="#1e293b" stroke="#334155" stroke-width="1.5"/>
      <text x="245" y="36" text-anchor="middle" font-size="12" font-weight="700" fill="#94a3b8">ConcreteFactory</text>
      <text x="190" y="54" font-size="9" fill="#94a3b8">overrides createA, createB</text>
      <line x1="140" y1="40" x2="180" y2="40" stroke="#4ade80" stroke-dasharray="4" marker-end="url(#arr2)"/>
      <defs><marker id="arr2" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto"><path d="M0,0 L0,6 L6,3 z" fill="#4ade80"/></marker></defs>
    </svg>`,
    code: `<span class="kw">interface</span> <span class="ty">UIFactory</span> {
  <span class="fn">createButton</span>(): <span class="ty">Button</span>;
  <span class="fn">createCheckbox</span>(): <span class="ty">Checkbox</span>;
}

<span class="kw">class</span> <span class="ty">MacFactory</span> <span class="kw">implements</span> <span class="ty">UIFactory</span> {
  <span class="fn">createButton</span>()   { <span class="kw">return new</span> <span class="ty">MacButton</span>(); }
  <span class="fn">createCheckbox</span>() { <span class="kw">return new</span> <span class="ty">MacCheckbox</span>(); }
}

<span class="kw">class</span> <span class="ty">WinFactory</span> <span class="kw">implements</span> <span class="ty">UIFactory</span> {
  <span class="fn">createButton</span>()   { <span class="kw">return new</span> <span class="ty">WinButton</span>(); }
  <span class="fn">createCheckbox</span>() { <span class="kw">return new</span> <span class="ty">WinCheckbox</span>(); }
}

<span class="cm">// 使い方</span>
<span class="kw">const</span> factory: <span class="ty">UIFactory</span> = isMac ? <span class="kw">new</span> <span class="ty">MacFactory</span>() : <span class="kw">new</span> <span class="ty">WinFactory</span>();
factory.<span class="fn">createButton</span>().<span class="fn">render</span>();`,
    when: ['OS/テーマ別に一貫したUIコンポーネント群を切り替えたい', '製品ファミリー全体を交換したい', 'DB種別ごとにDAOの実装を切り替えたい'],
    pros: ['製品ファミリーの一貫性が保てる', '具体クラスへの依存を排除できる'],
    cons: ['新製品追加時にインターフェース変更が必要', 'クラス数が多くなる'],
    related: ['Factory Method', 'Builder', 'Prototype'],
  },
  {
    id: 'builder', name: 'Builder', ja: 'ビルダー', cat: 'creational',
    intent: '複雑なオブジェクトの構築をその表現から分離し、同じ構築プロセスで異なる表現を生成できるようにする。',
    uml: `<svg viewBox="0 0 320 90" width="100%" style="max-width:320px" xmlns="http://www.w3.org/2000/svg">
      <rect x="10" y="20" width="100" height="55" rx="4" fill="#1e293b" stroke="#4ade80" stroke-width="1.5"/>
      <text x="60" y="40" text-anchor="middle" font-size="11" fill="#86efac">Director</text>
      <text x="20" y="58" font-size="9" fill="#fbbf24">+construct()</text>
      <rect x="150" y="10" width="120" height="70" rx="4" fill="#1e293b" stroke="#4ade80" stroke-width="1.5"/>
      <text x="210" y="30" text-anchor="middle" font-size="10" fill="#86efac">«interface»</text>
      <text x="210" y="46" text-anchor="middle" font-size="12" font-weight="700" fill="#e2e8f0">Builder</text>
      <text x="160" y="62" font-size="9" fill="#fbbf24">+buildStep1()</text>
      <text x="160" y="74" font-size="9" fill="#fbbf24">+buildStep2()</text>
      <line x1="110" y1="47" x2="150" y2="47" stroke="#6366f1" marker-end="url(#arr3)"/>
      <defs><marker id="arr3" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto"><path d="M0,0 L0,6 L6,3 z" fill="#6366f1"/></marker></defs>
    </svg>`,
    code: `<span class="kw">class</span> <span class="ty">QueryBuilder</span> {
  <span class="kw">private</span> query = <span class="st">""</span>;

  <span class="fn">select</span>(cols: <span class="ty">string</span>) { <span class="kw">this</span>.query += <span class="st">`SELECT \${cols} `</span>; <span class="kw">return this</span>; }
  <span class="fn">from</span>(tbl: <span class="ty">string</span>)   { <span class="kw">this</span>.query += <span class="st">`FROM \${tbl} `</span>;   <span class="kw">return this</span>; }
  <span class="fn">where</span>(cond: <span class="ty">string</span>) { <span class="kw">this</span>.query += <span class="st">`WHERE \${cond}`</span>; <span class="kw">return this</span>; }
  <span class="fn">build</span>() { <span class="kw">return this</span>.query.trim(); }
}

<span class="cm">// メソッドチェーンで直感的に構築</span>
<span class="kw">const</span> sql = <span class="kw">new</span> <span class="ty">QueryBuilder</span>()
  .<span class="fn">select</span>(<span class="st">"*"</span>)
  .<span class="fn">from</span>(<span class="st">"users"</span>)
  .<span class="fn">where</span>(<span class="st">"age > 18"</span>)
  .<span class="fn">build</span>();`,
    when: ['オプションパラメータが多いオブジェクトを生成したい', 'SQLビルダー・HTTPリクエストビルダーなど段階的構築が必要', '同じ構築手順で異なる表現を作りたい'],
    pros: ['コンストラクタの引数爆発を防げる', 'メソッドチェーンで可読性が高い', 'オブジェクトの構築を段階的に制御できる'],
    cons: ['Builderクラスが必要になりコード量が増える'],
    related: ['Abstract Factory', 'Composite'],
  },
  {
    id: 'prototype', name: 'Prototype', ja: 'プロトタイプ', cat: 'creational',
    intent: 'コピー可能なプロトタイプとして既存オブジェクトを指定し、それをクローンして新しいオブジェクトを生成する。',
    uml: `<svg viewBox="0 0 280 80" width="100%" style="max-width:280px" xmlns="http://www.w3.org/2000/svg">
      <rect x="80" y="10" width="140" height="60" rx="4" fill="#1e293b" stroke="#4ade80" stroke-width="1.5"/>
