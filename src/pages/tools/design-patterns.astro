// ======= STATE =======
let currentIdx = 0;
let catFilter = 'all';
let learned = JSON.parse(localStorage.getItem('dp_learned_v1') || '[]');

// ======= TODAY PATTERN =======
function getTodayIdx() {
  const day = Math.floor(Date.now() / 86400000);
  return day % PATTERNS.length;
}

// ======= BUILD GRID =======
function buildGrid() {
  const filtered = catFilter === 'all' ? PATTERNS : PATTERNS.filter(p => p.cat === catFilter);
  document.getElementById('pattern-grid').innerHTML = filtered.map(p => {
    const isLearned = learned.includes(p.id);
    const isActive = PATTERNS[currentIdx].id === p.id;
    return `<div class="pattern-chip${isActive ? ' active' : ''}${isLearned ? ' learned' : ''}"
      onclick="selectById('${p.id}')">
      <div class="chip-name">${p.name}</div>
      <div class="chip-cat">${p.ja}</div>
      ${isLearned ? '<div class="chip-check">✅</div>' : ''}
    </div>`;
  }).join('');
}

function filterCat(cat) {
  catFilter = cat;
  document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('cat-' + cat).classList.add('active');
  buildGrid();
}

function selectById(id) {
  const idx = PATTERNS.findIndex(p => p.id === id);
  if (idx >= 0) { currentIdx = idx; renderCard(); buildGrid(); }
}

// ======= RENDER CARD =======
function renderCard() {
  const p = PATTERNS[currentIdx];
  const isLearned = learned.includes(p.id);
  const catLabel = { creational: '生成', structural: '構造', behavioral: '振る舞い' };
  const catCls   = { creational: 'cat-creational', structural: 'cat-structural', behavioral: 'cat-behavioral' };

  const whenItems = p.when.map(w => `<li>${w}</li>`).join('');
  const prosItems = p.pros.map(pr => `<div class="pc-item">• ${pr}</div>`).join('');
  const consItems = p.cons.map(co => `<div class="pc-item">• ${co}</div>`).join('');
  const related   = p.related.map(r => `<span class="related-chip" onclick="selectByName('${r}')">${r}</span>`).join('');

  document.getElementById('card-inner').innerHTML = `
    <div class="card-header">
      <div class="card-cat-badge ${catCls[p.cat]}">${catLabel[p.cat]}</div>
      <div>
        <div class="card-name">${p.name}</div>
        <div class="card-en">${p.ja}</div>
      </div>
      <button class="card-learn-btn${isLearned ? ' learned' : ''}" onclick="toggleLearned('${p.id}')">
        ${isLearned ? '✅ 習得済み' : '○ 未習得'}
      </button>
    </div>
    <div class="card-body">
      <div class="section-title">意図</div>
      <div class="intent-box">${p.intent}</div>

      <div class="uml-section">
        <div class="section-title">UML 構造図</div>
        <div class="uml-wrap"><div class="uml-svg-wrap">${p.uml}</div></div>
      </div>

      <div class="code-section">
        <div class="section-title">TypeScript コード例</div>
        <div class="code-block">
          <button class="copy-btn" onclick="copyCode(${currentIdx})">コピー</button>
          ${p.code}
        </div>
      </div>

      <div class="when-section">
        <div class="section-title">使うべき場面</div>
        <ul class="when-list">${whenItems}</ul>
      </div>

      <div class="pros-cons">
        <div class="pros-box">
          <div class="pc-title pro">👍 メリット</div>
          ${prosItems}
        </div>
        <div class="cons-box">
          <div class="pc-title con">👎 デメリット</div>
          ${consItems}
        </div>
      </div>

      <div class="section-title" style="margin-top:14px">関連パターン</div>
      <div class="related-row">${related}</div>
    </div>`;

  updateProgress();
}

function selectByName(name) {
  const idx = PATTERNS.findIndex(p => p.name === name);
  if (idx >= 0) { currentIdx = idx; catFilter = 'all'; filterCat('all'); renderCard(); }
}

function prevPattern() {
  currentIdx = (currentIdx - 1 + PATTERNS.length) % PATTERNS.length;
  renderCard(); buildGrid();
  document.getElementById('main-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
}
function nextPattern() {
  currentIdx = (currentIdx + 1) % PATTERNS.length;
  renderCard(); buildGrid();
  document.getElementById('main-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
}
function markLearned() {
  const id = PATTERNS[currentIdx].id;
  if (!learned.includes(id)) {
    learned.push(id);
    localStorage.setItem('dp_learned_v1', JSON.stringify(learned));
    renderCard(); buildGrid();
  }
}
function toggleLearned(id) {
  if (learned.includes(id)) {
    learned = learned.filter(l => l !== id);
  } else {
    learned.push(id);
  }
  localStorage.setItem('dp_learned_v1', JSON.stringify(learned));
  renderCard(); buildGrid();
}

function updateProgress() {
  const pct = Math.round(learned.length / PATTERNS.length * 100);
  document.getElementById('progress-label').textContent = `${learned.length} / ${PATTERNS.length} 習得`;
  document.getElementById('progress-fill').style.width = pct + '%';

  const todayIdx = getTodayIdx();
  const todayP = PATTERNS[todayIdx];
  document.getElementById('today-badge').textContent = `📅 今日: ${todayP.name}`;
}

function copyCode(idx) {
  // strip HTML tags
  const raw = PATTERNS[idx].code.replace(/<[^>]+>/g, '');
  navigator.clipboard.writeText(raw).then(() => {
    const btn = document.querySelector('.copy-btn');
    if (btn) { btn.textContent = '✓ コピー済'; setTimeout(() => btn.textContent = 'コピー', 1500); }
  });
}

// init: start with today's pattern
currentIdx = getTodayIdx();
buildGrid();
renderCard();
</script>
