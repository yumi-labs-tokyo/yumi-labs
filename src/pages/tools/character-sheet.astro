<script is:inline>
  const TEXT_FIELDS = [
    ['inWork',        'pvWork',        '作品名'],
    ['inFurigana',    'pvFurigana',    'よみがな'],
    ['inAge',         'pvAge',         '―'],
    ['inBirthday',    'pvBirthday',    '―'],
    ['inGender',      'pvGender',      '―'],
    ['inBlood',       'pvBlood',       '―'],
    ['inHeight',      'pvHeight',      '―'],
    ['inWeight',      'pvWeight',      '―'],
    ['inHair',        'pvHair',        '―'],
    ['inEyes',        'pvEyes',        '―'],
    ['inFeature',     'pvFeature',     '―'],
    ['inJob',         'pvJob',         '―'],
    ['inOrigin',      'pvOrigin',      '―'],
    ['inFamily',      'pvFamily',      '―'],
    ['inPersonality', 'pvPersonality', '―'],
    ['inHobby',       'pvHobby',       '―'],
    ['inLikes',       'pvLikes',       '―'],
    ['inDislikes',    'pvDislikes',    '―'],
    ['inSkills',      'pvSkills',      '―'],
    ['inBackground',  'pvBackground',  '―'],
    ['inRelations',   'pvRelations',   '―'],
    ['inNotes',       'pvNotes',       '―'],
  ];

  function updatePreview() {
    // Name (special: larger placeholder)
    const nameVal = document.getElementById('inName').value.trim();
    document.getElementById('pvName').textContent = nameVal || 'キャラクター名';

    // Catchphrase (add quotes)
    const cp = document.getElementById('inCatchphrase').value.trim();
    document.getElementById('pvCatchphrase').textContent = cp ? `「${cp}」` : '―';

    // All other fields
    TEXT_FIELDS.forEach(([inputId, previewId, placeholder]) => {
      const val = document.getElementById(inputId)?.value.trim() || '';
      const el = document.getElementById(previewId);
      if (el) el.textContent = val || placeholder;
    });
  }

  function handlePortrait(input) {
    const file = input.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      const img = document.getElementById('pvPortrait');
      const ph  = document.getElementById('pvPortraitPH');
      img.src = e.target.result;
      img.style.display = 'block';
      if (ph) ph.style.display = 'none';
    };
    reader.readAsDataURL(file);
  }

  const THEMES = {
    purple: { cls: 'theme-purple', accent: '#7c3aed' },
    blue:   { cls: 'theme-blue',   accent: '#2563eb' },
    rose:   { cls: 'theme-rose',   accent: '#e11d48' },
    dark:   { cls: 'theme-dark',   accent: '#374151' },
  };

  function setTheme(name) {
    const sheet = document.getElementById('charSheet');
    Object.values(THEMES).forEach(t => sheet.classList.remove(t.cls));
    sheet.classList.add(THEMES[name].cls);

    // Update button ring
    Object.keys(THEMES).forEach(k => {
      const btn = document.getElementById('th-' + k);
      if (!btn) return;
      btn.style.outline = k === name ? `2px solid ${THEMES[k].accent}` : 'none';
      btn.style.outlineOffset = k === name ? '2px' : '0';
    });
  }

  // Init
  setTheme('purple');
  updatePreview();
</script>
