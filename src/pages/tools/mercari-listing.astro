---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="メルカリ出品文最適化ツール — yumi-Labs"
  description="商品名・状態・サイズを入れると検索に強いタイトル＋説明文＋ハッシュタグをAIが生成します。"
>
  <div class="wrapper page-wrap">
    <nav class="breadcrumb"><a href="/">← ツール一覧</a></nav>

    <header class="tool-header">
      <span class="tool-icon">🛍️</span>
      <div>
        <h1 class="tool-title">メルカリ出品文最適化ツール</h1>
        <p class="tool-sub">商品情報を入れるだけで売れる出品文一式をAIが生成</p>
      </div>
    </header>

    <div class="main-layout">

      <!-- INPUT -->
      <section class="card">
        <h2 class="card-title">📦 商品情報を入力</h2>

        <div class="form-grid">

          <div class="field required-field">
            <label class="field-label" for="product-name">商品名 <span class="required">必須</span></label>
            <input id="product-name" type="text" class="text-input" placeholder="例: ユニクロ フリースジャケット" maxlength="80" />
          </div>

          <div class="field">
            <label class="field-label" for="brand">ブランド</label>
            <input id="brand" type="text" class="text-input" placeholder="例: UNIQLO、無印良品、Nike" maxlength="40" />
          </div>

          <div class="field">
            <label class="field-label" for="condition">状態</label>
            <div class="select-wrap">
              <select id="condition" class="select-input">
                <option value="new">新品・未使用</option>
                <option value="likenew">未使用に近い</option>
                <option value="good" selected>目立った傷や汚れなし</option>
                <option value="fair">やや傷や汚れあり</option>
                <option value="poor">傷や汚れあり</option>
                <option value="bad">全体的に状態が悪い</option>
              </select>
            </div>
          </div>

          <div class="field">
            <label class="field-label" for="size">サイズ</label>
            <input id="size" type="text" class="text-input" placeholder="例: M、XL、23cm、A4" maxlength="20" />
          </div>

          <div class="field">
            <label class="field-label" for="color">カラー</label>
            <input id="color" type="text" class="text-input" placeholder="例: ネイビー、オフホワイト" maxlength="30" />
          </div>

          <div class="field full-width">
            <label class="field-label" for="notes">補足・アピールポイント</label>
            <textarea id="notes" class="textarea-input" placeholder="例: 1回のみ着用、洗濯済み、タグあり、箱あり" maxlength="200" rows="3"></textarea>
          </div>

        </div>

        <button class="generate-btn" id="generate-btn" onclick="generate()">
          <span id="btn-text">✨ 出品文を生成する</span>
          <span id="btn-loader" class="loader" hidden></span>
        </button>
      </section>

      <!-- ERROR -->
      <div class="error-banner" id="error-banner" hidden></div>

      <!-- RESULT -->
      <section class="card result-card" id="result-section" hidden>
        <h2 class="card-title">📝 生成された出品文</h2>

        <!-- タイトル -->
        <div class="result-block">
          <div class="result-block-header">
            <span class="result-block-label">📌 タイトル</span>
            <span class="char-count" id="title-count"></span>
            <button class="copy-btn" onclick="copyField('title-text', this)">コピー</button>
          </div>
          <div class="title-output" id="title-text"></div>
        </div>

        <!-- 説明文 -->
        <div class="result-block">
          <div class="result-block-header">
            <span class="result-block-label">📄 説明文</span>
            <button class="copy-btn" onclick="copyField('desc-text', this)">コピー</button>
          </div>
          <div class="desc-output" id="desc-text"></div>
        </div>

        <!-- ハッシュタグ -->
        <div class="result-block">
          <div class="result-block-header">
            <span class="result-block-label">🏷️ ハッシュタグ</span>
            <button class="copy-btn" onclick="copyField('tags-text', this)">コピー</button>
          </div>
          <div class="tags-output" id="tags-display"></div>
          <div id="tags-text" style="display:none"></div>
        </div>

        <button class="copy-all-btn" id="copy-all-btn" onclick="copyAll()">📋 全部まとめてコピー</button>
      </section>

    </div>
  </div>

<section class="tool-seo">
  <div class="seo-inner">
    <div class="seo-block">
      <div class="seo-h2">📌 ツールの概要・特徴</div>
      <p class="seo-p">このツールは、メルカリなどのフリマアプリへの商品出品文を素早く作成できる無料Webアプリです。カテゴリー・状態・付属品などを選択入力するだけで、売れやすい商品説明文・タイトルが自動生成されます。検索で引っかかりやすいキーワードの提案機能も搭載しています。</p>
    </div>
    <div class="seo-block">
      <div class="seo-h2">📖 詳しい使い方・手順</div>
      <ol class="seo-ol">
        <li>カテゴリー（衣類・家電・本・ゲームなど）と商品名を入力します。</li>
        <li>商品の状態（未使用・美品・傷あり等）を選択します。</li>
        <li>付属品・購入時期・使用期間・特記事項を入力します。</li>
        <li>「説明文を生成」を押すと売れやすい商品説明が自動作成されます。</li>
        <li>生成されたテキストをコピーしてフリマアプリに貼り付けます。</li>
      </ol>
    </div>
    <div class="seo-block">
      <div class="seo-h2">👤 こんな人におすすめ</div>
      <p class="seo-p">フリマアプリで出品に慣れていない方、商品説明を書くのが苦手な方に最適です。断捨離・引越しで大量出品したい方、副業としてせどりを行っている方、商品説明のワンパターン化を防ぎたいリピート出品者にもおすすめします。</p>
    </div>
    <div class="seo-block">
      <div class="seo-h2">🛠️ 制作の背景・こだわり</div>
      <p class="seo-p">フリマアプリの出品は写真撮影以上に「文章作成」が時間のかかる作業です。売れている商品の説明文を分析すると、キーワードの選び方・状態説明の具体性・購入者への配慮の書き方に共通パターンがあることがわかりました。そのパターンを抽出し、誰でも「売れる文章」が書けるテンプレートエンジンを開発しています。</p>
    </div>
  </div>
</section>
</BaseLayout>

<script is:inline>
async function generate() {
  const productName = document.getElementById('product-name').value.trim();
  const brand = document.getElementById('brand').value.trim();
  const condition = document.getElementById('condition').value;
  const size = document.getElementById('size').value.trim();
  const color = document.getElementById('color').value.trim();
  const notes = document.getElementById('notes').value.trim();

  const errorBanner = document.getElementById('error-banner');
  errorBanner.hidden = true;

  if (!productName) {
    showError('商品名を入力してください。');
    document.getElementById('product-name').focus();
    return;
  }

  setLoading(true);

  try {
    const res = await fetch('/api/mercari-listing', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ productName, brand, condition, size, color, notes }),
    });
    const data = await res.json();
    if (!res.ok || data.error) {
      showError(data.error || '生成に失敗しました。');
      return;
    }
    renderResult(data);
  } catch (e) {
    showError('通信エラーが発生しました。');
  } finally {
    setLoading(false);
  }
}

function renderResult(data) {
  const { title, description, hashtags } = data;

  // タイトル
  const titleEl = document.getElementById('title-text');
  titleEl.textContent = title || '';
  const countEl = document.getElementById('title-count');
  const len = (title || '').length;
  countEl.textContent = `${len}/40字`;
  countEl.className = 'char-count' + (len > 40 ? ' over' : '');

  // 説明文
  const descEl = document.getElementById('desc-text');
  descEl.textContent = '';
  const lines = (description || '').split('\n');
  lines.forEach((line, i) => {
    descEl.appendChild(document.createTextNode(line));
    if (i < lines.length - 1) descEl.appendChild(document.createElement('br'));
  });

  // ハッシュタグ
  const tagsDisplay = document.getElementById('tags-display');
  const tagsText = document.getElementById('tags-text');
  tagsDisplay.innerHTML = '';
  const tagArr = Array.isArray(hashtags) ? hashtags : [];
  tagArr.forEach(tag => {
    const span = document.createElement('span');
    span.className = 'tag-chip';
    span.textContent = '#' + tag.replace(/^#/, '');
    tagsDisplay.appendChild(span);
  });
  tagsText.textContent = tagArr.map(t => '#' + t.replace(/^#/, '')).join(' ');

  document.getElementById('result-section').hidden = false;
  document.getElementById('result-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function copyField(id, btn) {
  const el = document.getElementById(id);
  const text = el.textContent || el.innerText || '';
  navigator.clipboard.writeText(text.trim()).then(() => {
    btn.textContent = '✓';
    setTimeout(() => btn.textContent = 'コピー', 1500);
  });
}

function copyAll() {
  const title = document.getElementById('title-text').textContent.trim();
  const descEl = document.getElementById('desc-text');
  const desc = descEl.innerText || descEl.textContent || '';
  const tags = document.getElementById('tags-text').textContent.trim();

  const text = [
    '【タイトル】',
    title,
    '',
    '【説明文】',
    desc.trim(),
    '',
    '【ハッシュタグ】',
    tags,
  ].join('\n');

  navigator.clipboard.writeText(text).then(() => {
    const btn = document.getElementById('copy-all-btn');
    btn.textContent = '✓ コピーしました！';
    setTimeout(() => btn.textContent = '📋 全部まとめてコピー', 2000);
  });
}

function showError(msg) {
  const el = document.getElementById('error-banner');
  el.textContent = msg;
  el.hidden = false;
}

function setLoading(on) {
  document.getElementById('generate-btn').disabled = on;
  document.getElementById('btn-text').hidden = on;
  document.getElementById('btn-loader').hidden = !on;
}
</script>

<style>
  .page-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
    overflow-x: hidden;
    box-sizing: border-box;
  }

  .breadcrumb { margin-bottom: 1.5rem; font-size: 0.875rem; }
  .breadcrumb a { color: var(--accent-regular); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .tool-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .tool-icon { font-size: 2.5rem; line-height: 1; flex-shrink: 0; }
  .tool-title {
    font-size: clamp(1.1rem, 4vw, 1.5rem);
    font-weight: 700;
    margin: 0 0 0.25rem;
    word-break: break-word;
  }
  .tool-sub { margin: 0; color: var(--gray-400); font-size: 0.9rem; }

  .main-layout { display: flex; flex-direction: column; gap: 1.5rem; }

  .card {
    background: var(--gray-999);
    border: 1px solid var(--gray-800);
    border-radius: 1rem;
    padding: 1.5rem;
    box-sizing: border-box;
    min-width: 0;
  }
  .card-title { font-size: 1rem; font-weight: 700; margin: 0 0 1.25rem; }

  /* Form */
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 520px) {
    .form-grid { grid-template-columns: 1fr; }
  }

  .field {}
  .full-width { grid-column: 1 / -1; }
  .required-field { grid-column: 1 / -1; }

  .field-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--gray-300);
    margin-bottom: 0.4rem;
  }
  .required {
    display: inline-block;
    background: var(--accent-regular);
    color: #fff;
    font-size: 0.7rem;
    padding: 0.05rem 0.4rem;
    border-radius: 0.25rem;
    margin-left: 0.3rem;
    vertical-align: middle;
  }

  .text-input,
  .select-input,
  .textarea-input {
    width: 100%;
    box-sizing: border-box;
    padding: 0.65rem 0.875rem;
    font-size: 0.95rem;
    border: 2px solid var(--gray-700);
    border-radius: 0.625rem;
    background: var(--gray-950);
    color: var(--gray-0);
    font-family: inherit;
    transition: border-color 0.2s;
  }
  .text-input:focus,
  .select-input:focus,
  .textarea-input:focus {
    outline: none;
    border-color: var(--accent-regular);
  }
  .textarea-input { resize: vertical; min-height: 72px; }

  .select-wrap { position: relative; }
  .select-input { appearance: none; cursor: pointer; padding-right: 2rem; }
  .select-wrap::after {
    content: '▾';
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--gray-400);
    font-size: 0.9rem;
  }

  /* Generate button */
  .generate-btn {
    width: 100%;
    padding: 0.875rem;
    background: var(--accent-regular);
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    border: none;
    border-radius: 0.75rem;
    cursor: pointer;
    transition: opacity 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: inherit;
    box-sizing: border-box;
  }
  .generate-btn:hover { opacity: 0.88; }
  .generate-btn:disabled { opacity: 0.55; cursor: not-allowed; }

  .loader {
    width: 1.2rem;
    height: 1.2rem;
    border: 3px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    display: inline-block;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Error */
  .error-banner {
    background: color-mix(in srgb, #ef4444 15%, transparent);
    border: 1px solid #ef4444;
    color: #fca5a5;
    padding: 0.875rem 1rem;
    border-radius: 0.75rem;
    font-size: 0.9rem;
  }

  /* Result blocks */
  .result-block {
    margin-bottom: 1.25rem;
    border: 1px solid var(--gray-800);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .result-block:last-of-type { margin-bottom: 1.5rem; }

  .result-block-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.875rem;
    background: var(--gray-950);
    border-bottom: 1px solid var(--gray-800);
    flex-wrap: wrap;
  }
  .result-block-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--gray-300);
    flex: 1;
    min-width: 0;
  }
  .char-count {
    font-size: 0.78rem;
    color: var(--gray-400);
    flex-shrink: 0;
  }
  .char-count.over { color: #f87171; font-weight: 700; }

  .copy-btn {
    padding: 0.2rem 0.65rem;
    border: 1px solid var(--gray-700);
    border-radius: 1rem;
    background: transparent;
    color: var(--gray-400);
    font-size: 0.75rem;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .copy-btn:hover { border-color: var(--accent-regular); color: var(--accent-regular); }

  .title-output {
    padding: 0.875rem 1rem;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.6;
    word-break: break-all;
    color: var(--gray-0);
  }

  .desc-output {
    padding: 0.875rem 1rem;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--gray-100);
    word-break: break-word;
    white-space: pre-line;
  }

  .tags-output {
    padding: 0.75rem 0.875rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag-chip {
    display: inline-block;
    padding: 0.25rem 0.7rem;
    background: color-mix(in srgb, var(--accent-regular) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-regular) 40%, transparent);
    color: var(--accent-regular);
    border-radius: 2rem;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .copy-all-btn {
    width: 100%;
    padding: 0.75rem;
    background: transparent;
    border: 2px solid var(--accent-regular);
    color: var(--accent-regular);
    font-size: 0.95rem;
    font-weight: 700;
    border-radius: 0.75rem;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
    box-sizing: border-box;
  }
  .copy-all-btn:hover {
    background: color-mix(in srgb, var(--accent-regular) 12%, transparent);
  }
</style>
