// ─── UI ロジック ─────────────────────────────────────────────

function setEventCat(btn) {
  document.querySelectorAll('.event-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const cat = btn.dataset.cat;
  document.getElementById('events-celebration').hidden = (cat !== 'celebration');
  document.getElementById('events-condolence').hidden  = (cat !== 'condolence');
  document.getElementById('religion-group').hidden = (cat !== 'condolence');
  // デフォルト選択
  const first = document.querySelector(`#events-${cat} input[type=radio]`);
  if (first) first.checked = true;
}

function judge() {
  const event    = document.querySelector('input[name=event]:checked')?.value || 'wedding';
  const relation = document.getElementById('relation').value;
  const age      = document.querySelector('input[name=age]:checked')?.value || '20s';
  const region   = document.getElementById('region').value;
  const religion = document.getElementById('religion').value;

  // 金額
  const amount = AMOUNTS[event]?.[relation]?.[age] || '——';

  // 表書き
  let noshiList = [];
  const n = NOSHI[event];
  if (Array.isArray(n)) {
    noshiList = n;
  } else if (n && typeof n === 'object') {
    noshiList = n[religion] || n['buddhist'] || [];
  }

  // 新札
  const bill = NEW_BILL[event] || { use: null, label: '——', reason: '' };

  // 地域メモ
  const regionNote = REGION_NOTE[region];

  // マナーTips
  const tips = MANNER_TIPS[event] || '';

  // イベント表示名
  const eventLabel = {
    wedding:'結婚式・披露宴', birth:'出産・誕生', graduation:'入学・卒業・就職',
    longevity:'還暦・長寿祝い', funeral:'葬儀・告別式', memorial:'法要',
  }[event] || event;

  const relationLabel = document.getElementById('relation').options[document.getElementById('relation').selectedIndex].text;
  const ageLabel = { '20s':'20代', '30s':'30代', '40plus':'40代以上' }[age];

  renderResult({ amount, noshiList, bill, regionNote, tips, eventLabel, relationLabel, ageLabel });
}

function renderResult({ amount, noshiList, bill, regionNote, tips, eventLabel, relationLabel, ageLabel }) {
  const billIcon = bill.use === true ? '✅' : bill.use === false ? '❌' : 'ℹ️';
  const billColor = bill.use === true ? '#34d399' : bill.use === false ? '#f87171' : '#94a3b8';

  const noshiHTML = noshiList.map(t =>
    `<span class="noshi-chip">${t}</span>`
  ).join('');

  const tipsHTML = tips
    ? tips.split('\n').filter(Boolean).map(l =>
        `<li>${l.replace(/^• /, '')}</li>`
      ).join('')
    : '';

  document.getElementById('result-content').innerHTML = `
    <p class="result-meta">${eventLabel} × ${relationLabel}（${ageLabel}）</p>

    <div class="result-amount-block">
      <span class="result-amount-label">💴 相場金額</span>
      <span class="result-amount">${amount}</span>
    </div>

    <div class="result-section">
      <div class="result-section-title">📜 表書き</div>
      <div class="noshi-list">${noshiHTML || '<span class="muted">——</span>'}</div>
    </div>

    <div class="result-section">
      <div class="result-section-title">
        ${billIcon} 新札ルール：<span style="color:${billColor};font-weight:700">${bill.label}</span>
      </div>
      <p class="result-sub-text">${bill.reason}</p>
    </div>

    ${tipsHTML ? `
    <div class="result-section">
      <div class="result-section-title">💡 マナーポイント</div>
      <ul class="tips-list">${tipsHTML}</ul>
    </div>` : ''}

    ${regionNote ? `
    <div class="region-note">
      <span class="region-note-icon">🗾</span>
      <span>${regionNote}</span>
    </div>` : ''}
  `;
}

// ─── Init ─────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  judge(); // 初期値で即表示
});
</script>

