---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="縦列駐車シミュレーター" description="車サイズ・駐車スペース寸法でハンドル切り角度をSVGアニメ表示。">
<main class="pp-wrap">
  <div class="pp-header">
    <div class="pp-title">🅿️ 縦列駐車シミュレーター</div>
    <div class="pp-sub">車のサイズと駐車スペースを入力して駐車手順を確認</div>
  </div>

  <div class="pp-body">
    <div class="pp-left">
      <div class="pp-card">
        <div class="pp-card-title">車のサイズ</div>
        <div class="pp-form-grid">
          <div class="pp-fg">
            <label class="pp-label">全長（cm）</label>
            <input type="number" id="carLen" class="pp-input" value="450" min="300" max="600" step="5" oninput="update()" />
          </div>
          <div class="pp-fg">
            <label class="pp-label">全幅（cm）</label>
            <input type="number" id="carWidth" class="pp-input" value="175" min="130" max="220" step="5" oninput="update()" />
          </div>
          <div class="pp-fg">
            <label class="pp-label">最小回転半径（m）</label>
            <input type="number" id="turnR" class="pp-input" value="5.2" min="3.5" max="8.0" step="0.1" oninput="update()" />
          </div>
        </div>

        <div class="pp-card-title" style="margin-top:.8rem">駐車スペース</div>
        <div class="pp-form-grid">
          <div class="pp-fg">
            <label class="pp-label">スペース長（cm）</label>
            <input type="number" id="spaceLen" class="pp-input" value="600" min="400" max="900" step="10" oninput="update()" />
          </div>
          <div class="pp-fg">
            <label class="pp-label">スペース幅（cm）</label>
            <input type="number" id="spaceWidth" class="pp-input" value="250" min="180" max="400" step="5" oninput="update()" />
          </div>
          <div class="pp-fg">
            <label class="pp-label">道路幅（cm）</label>
            <input type="number" id="roadWidth" class="pp-input" value="350" min="200" max="700" step="10" oninput="update()" />
          </div>
        </div>

        <div class="pp-quick">
          <div class="pp-card-title">よくある車サイズ</div>
          <div class="pp-quick-grid">
            <button class="pp-qbtn" onclick="setCar(340,148,4.5)">軽自動車<br><small>340×148cm</small></button>
            <button class="pp-qbtn" onclick="setCar(420,170,5.0)">コンパクト<br><small>420×170cm</small></button>
            <button class="pp-qbtn" onclick="setCar(450,175,5.2)">セダン<br><small>450×175cm</small></button>
            <button class="pp-qbtn" onclick="setCar(475,185,5.7)">ミニバン<br><small>475×185cm</small></button>
            <button class="pp-qbtn" onclick="setCar(490,190,6.0)">SUV<br><small>490×190cm</small></button>
          </div>
        </div>
      </div>
    </div>

    <div class="pp-right">
      <div class="pp-result-card" id="resultCard">
        <div class="pp-card-title">判定結果</div>
        <div id="resultBadge" class="result-badge"></div>
        <div id="resultDetail" class="result-detail"></div>
      </div>

      <div class="pp-svg-card">
        <div class="pp-card-title">駐車スペース俯瞰図</div>
        <svg id="parkSvg" viewBox="0 0 400 500" style="width:100%;max-height:480px;background:var(--gray-900);border-radius:8px"></svg>
      </div>

      <div class="pp-steps-card">
        <div class="pp-card-title">駐車手順</div>
        <div id="stepsContent" class="steps-list"></div>
      </div>
    </div>
  </div>
</main>

<script is:inline>
function setCar(len, width, r) {
  document.getElementById('carLen').value = len;
  document.getElementById('carWidth').value = width;
  document.getElementById('turnR').value = r;
  update();
}

function update() {
  const carLen = parseFloat(document.getElementById('carLen').value) || 450;
  const carWidth = parseFloat(document.getElementById('carWidth').value) || 175;
  const turnR = parseFloat(document.getElementById('turnR').value) || 5.2;
  const spaceLen = parseFloat(document.getElementById('spaceLen').value) || 600;
  const spaceWidth = parseFloat(document.getElementById('spaceWidth').value) || 250;
  const roadWidth = parseFloat(document.getElementById('roadWidth').value) || 350;

  // Required space = car length * 1.3 (rule of thumb) for comfortable parking
  const minSpaceLen = carLen * 1.3;
  const minSpaceWidth = carWidth + 60; // 60cm clearance
  const minRoadWidth = turnR * 100 * 0.8; // simplified

  const canPark = spaceLen >= minSpaceLen && spaceWidth >= minSpaceWidth && roadWidth >= minRoadWidth;
  const tight = spaceLen >= carLen * 1.15 && spaceLen < minSpaceLen;
  const spaceFactor = ((spaceLen - carLen) / carLen * 100).toFixed(0);

  const badge = document.getElementById('resultBadge');
  const detail = document.getElementById('resultDetail');

  if (canPark) {
    badge.innerHTML = '<span class="badge ok">✅ 駐車可能</span>';
    detail.innerHTML = `
      <div class="rd-row"><span>余裕</span><span class="rd-green">+${spaceFactor}%（${(spaceLen - carLen).toFixed(0)}cm）</span></div>
      <div class="rd-row"><span>幅の余裕</span><span class="rd-green">+${(spaceWidth - carWidth).toFixed(0)}cm</span></div>
      <div class="rd-row"><span>最小必要長</span><span>${minSpaceLen.toFixed(0)} cm</span></div>
      <div class="rd-row"><span>切り返し回数（目安）</span><span>${spaceLen >= carLen * 1.5 ? '0〜1回' : '1〜2回'}</span></div>
    `;
  } else if (tight) {
    badge.innerHTML = '<span class="badge warn">⚠️ 上級者向け</span>';
    detail.innerHTML = `
      <div class="rd-row"><span>スペース長</span><span class="rd-orange">${spaceLen}cm（推奨: ${minSpaceLen.toFixed(0)}cm）</span></div>
      <div class="rd-row"><span>不足</span><span class="rd-orange">${(minSpaceLen - spaceLen).toFixed(0)}cm 不足</span></div>
      <div class="rd-row"><span>切り返し回数</span><span>2〜3回必要</span></div>
    `;
  } else {
    badge.innerHTML = '<span class="badge ng">❌ 困難</span>';
    detail.innerHTML = `
      <div class="rd-row"><span>スペース長</span><span class="rd-red">${spaceLen}cm（最低: ${(carLen * 1.15).toFixed(0)}cm必要）</span></div>
      <div class="rd-row"><span>不足</span><span class="rd-red">${(carLen * 1.15 - spaceLen).toFixed(0)}cm 不足</span></div>
      <div class="rd-row"><span>対処法</span><span>別のスペースを探す</span></div>
    `;
  }

  drawSvg(carLen, carWidth, spaceLen, spaceWidth, roadWidth, canPark, tight);
  showSteps(canPark, tight, spaceLen, carLen, turnR);
}

function drawSvg(carLen, carWidth, spaceLen, spaceWidth, roadWidth, canPark, tight) {
  const svg = document.getElementById('parkSvg');
  svg.innerHTML = '';
  const VW = 400, VH = 500, pad = 30;
  const totalH = spaceWidth + roadWidth;
  const scaleX = (VW - 2 * pad) / Math.max(spaceLen * 1.3, carLen * 1.5);
  const scaleY = (VH - 2 * pad) / totalH;
  const scale = Math.min(scaleX, scaleY, 0.8);

  const sw = spaceLen * scale, sh = spaceWidth * scale;
  const rw = roadWidth * scale;
  const ox = pad, oy = pad;

  const ns = 'http://www.w3.org/2000/svg';
  function el(tag, attrs, txt) {
    const e = document.createElementNS(ns, tag);
    for (const [k,v] of Object.entries(attrs)) e.setAttribute(k, v);
    if (txt !== undefined) e.textContent = txt;
    return e;
  }

  // Road
  svg.appendChild(el('rect', {x:ox, y:oy, width:VW-2*pad, height:rw, fill:'#374151', rx:'4'}));
  // Road center line
  for (let x = ox; x < VW - pad; x += 30) {
    svg.appendChild(el('rect', {x, y: oy + rw/2 - 2, width:20, height:4, fill:'#fbbf24', opacity:'.6'}));
  }

  // Parking space
  const spaceY = oy + rw;
  svg.appendChild(el('rect', {x:ox, y:spaceY, width:sw, height:sh, fill:'#1f2937', stroke:'#ffffff', 'stroke-width':'2', 'stroke-dasharray':'8,4'}));

  // Cars beside (context)
  const cw2 = carWidth * scale, cl2 = carLen * scale;
  if (ox + sw + cl2 < VW - pad) {
    svg.appendChild(el('rect', {x:ox+sw, y:spaceY+(sh-cw2)/2, width:cl2, height:cw2, fill:'#374151', stroke:'#6b7280', 'stroke-width':'1.5', rx:'4'}));
  }

  // Target car (parked)
  const carColor = canPark ? '#3b82f6' : (tight ? '#f97316' : '#ef4444');
  const cMarginX = (sw - cl2) / 2;
  const cMarginY = (sh - cw2) / 2;
  svg.appendChild(el('rect', {x:ox+cMarginX, y:spaceY+cMarginY, width:cl2, height:cw2, fill:carColor, rx:'4', opacity:'0.85'}));
  svg.appendChild(el('text', {x:ox+sw/2, y:spaceY+sh/2+4, 'font-size':'10', fill:'#fff', 'text-anchor':'middle'}, '自車'));

  // Labels
  svg.appendChild(el('text', {x:ox+sw/2, y:spaceY+sh+16, 'font-size':'10', fill:'#9ca3af', 'text-anchor':'middle'}, spaceLen+'cm'));
  svg.appendChild(el('text', {x:ox-8, y:spaceY+sh/2, 'font-size':'10', fill:'#9ca3af', 'text-anchor':'end', 'dominant-baseline':'middle'}, spaceWidth+'cm'));
  svg.appendChild(el('text', {x:ox+40, y:oy+rw/2+4, 'font-size':'10', fill:'#fbbf24', 'text-anchor':'middle'}, '道路 '+roadWidth+'cm'));
}

function showSteps(canPark, tight, spaceLen, carLen, turnR) {
  const steps = canPark ? [
    '① 駐車スペースの前の車と並んで停車（車体を平行に）',
    '② 自分の車の後部がスペース前端を過ぎたところで停止',
    '③ ハンドルを右に大きく切りながらゆっくりバック',
    '④ 車体が45°になったらハンドルを左に切り返し',
    '⑤ 車体が道路と平行になったら真っすぐバック',
    '⑥ 前後均等になるよう微調整して完了',
  ] : tight ? [
    '① スペースが狭いため慎重に操作が必要です',
    '② 前の車ギリギリまで前進して停車',
    '③ 素早くハンドルを右に切ってバック開始',
    '④ こまめに切り返しを繰り返す（2〜3回）',
    '⑤ 周囲の車との距離を常に確認',
    '⑥ 無理と判断したら別のスペースを探す',
  ] : [
    '❌ このスペースへの縦列駐車は非常に困難です',
    '・スペースの長さが車長の115%を下回っています',
    '・無理に駐車しようとすると接触事故のリスクがあります',
    '・別の駐車スペースを探すことを強くお勧めします',
  ];

  document.getElementById('stepsContent').innerHTML = steps.map((s, i) =>
    `<div class="step-row ${!canPark && !tight ? 'step-danger' : ''}">${s}</div>`
  ).join('');
}

update();
</script>

<style>
.pp-wrap { max-width: 960px; margin: 0 auto; padding: 2rem 1rem 4rem; }
.pp-header { text-align: center; margin-bottom: 2rem; }
.pp-title { font-size: 1.8rem; font-weight: 800; color: var(--gray-0); }
.pp-sub { color: var(--gray-400); margin-top: .3rem; }
.pp-body { display: grid; grid-template-columns: 1fr 360px; gap: 1.5rem; }
@media (max-width: 780px) { .pp-body { grid-template-columns: 1fr; } }
.pp-card, .pp-result-card, .pp-svg-card, .pp-steps-card { background: var(--gray-800); border: 1.5px solid var(--gray-700); border-radius: 14px; padding: 1.2rem; margin-bottom: 1rem; }
.pp-card-title { font-weight: 700; color: var(--gray-200); margin-bottom: .8rem; font-size: .9rem; }
.pp-form-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: .6rem; margin-bottom: .8rem; }
.pp-fg { display: flex; flex-direction: column; gap: .3rem; }
.pp-label { font-size: .75rem; color: var(--gray-400); }
.pp-input { background: var(--gray-900); border: 1.5px solid var(--gray-700); border-radius: 8px; color: var(--gray-100); padding: .5rem .7rem; font-size: .95rem; width: 100%; box-sizing: border-box; }
.pp-quick { margin-top: .5rem; }
.pp-quick-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: .4rem; }
.pp-qbtn { background: var(--gray-900); border: 1.5px solid var(--gray-700); border-radius: 8px; padding: .35rem .2rem; font-size: .7rem; cursor: pointer; color: var(--gray-300); line-height: 1.4; }
.pp-qbtn:hover { border-color: #7c3aed; }
.pp-qbtn small { color: var(--gray-500); }
.result-badge { margin-bottom: .8rem; }
.badge { padding: .4rem 1rem; border-radius: 8px; font-weight: 700; font-size: 1rem; }
.badge.ok { background: #14532d; color: #4ade80; }
.badge.warn { background: #7c2d12; color: #fb923c; }
.badge.ng { background: #7f1d1d; color: #f87171; }
.rd-row { display: flex; justify-content: space-between; font-size: .85rem; padding: .3rem 0; border-bottom: 1px solid var(--gray-700); color: var(--gray-300); }
.rd-row:last-child { border-bottom: none; }
.rd-green { color: #4ade80; font-weight: 700; }
.rd-orange { color: #fb923c; font-weight: 700; }
.rd-red { color: #f87171; font-weight: 700; }
.steps-list { display: flex; flex-direction: column; gap: .4rem; }
.step-row { background: var(--gray-900); border-radius: 8px; padding: .5rem .8rem; font-size: .85rem; color: var(--gray-200); }
.step-danger { color: #f87171; }
</style>
</BaseLayout>
