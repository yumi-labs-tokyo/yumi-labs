---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="英単語「忘却曲線」復習アプリ | yumi Labs">
  <style>
    @keyframes card-flip {
      0%   { transform: rotateY(0deg); }
      50%  { transform: rotateY(90deg); }
      100% { transform: rotateY(0deg); }
    }
    .flip-anim { animation: card-flip 0.35s ease-in-out; }
    .retention-bar { transition: width 0.6s cubic-bezier(0.34,1.56,0.64,1); }
    .word-card {
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .word-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
    .stage-dot {
      width: 10px; height: 10px; border-radius: 50%; display: inline-block;
    }
    /* Ebbinghaus curve SVG gradient */
    .curve-area { fill: url(#curveGrad); opacity: 0.3; }
  </style>

  <div class="max-w-2xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="text-center mb-8">
      <div class="text-5xl mb-3">🔁</div>
      <div style="font-size:1.8rem;font-weight:800;color:var(--gray-0);margin-bottom:0.3rem">英単語「忘却曲線」復習アプリ</div>
      <div class="text-gray-400 text-sm">エビングハウスの忘却曲線に基づく最適タイミングで復習。ブラウザ通知で復習日をお知らせ</div>
    </div>

    <!-- Tabs -->
    <div class="flex gap-1 bg-white/5 rounded-xl p-1 mb-5">
      <button onclick="setTab('add')" data-tab="add"
        class="tab-btn flex-1 py-2 rounded-lg text-sm font-medium transition-all bg-purple-600/40 text-white border border-purple-400/30">
        ＋ 単語追加
      </button>
      <button onclick="setTab('review')" data-tab="review"
        class="tab-btn flex-1 py-2 rounded-lg text-sm font-medium transition-all text-gray-400">
        📖 復習
        <span id="reviewBadge" class="ml-1 hidden px-1.5 py-0.5 rounded-full text-xs bg-red-500 text-white"></span>
      </button>
      <button onclick="setTab('list')" data-tab="list"
        class="tab-btn flex-1 py-2 rounded-lg text-sm font-medium transition-all text-gray-400">
        📋 単語帳
      </button>
      <button onclick="setTab('curve')" data-tab="curve"
        class="tab-btn flex-1 py-2 rounded-lg text-sm font-medium transition-all text-gray-400">
        📈 曲線
      </button>
    </div>

    <!-- ===== TAB: Add ===== -->
    <div id="tab-add" class="space-y-4">

      <!-- Notification permission -->
      <div id="notifBanner" class="bg-blue-500/10 border border-blue-500/20 rounded-xl p-3 flex items-center justify-between gap-3">
        <div class="text-xs text-blue-300">🔔 ブラウザ通知をONにすると復習タイミングをお知らせします</div>
        <button onclick="requestNotification()"
          class="px-3 py-1.5 rounded-lg text-xs font-medium bg-blue-500/30 text-blue-200 hover:bg-blue-500/50 border border-blue-400/30 transition-all flex-shrink-0">
          通知を許可
        </button>
      </div>

      <!-- Add word form -->
      <div class="bg-white/5 rounded-2xl p-5">
        <div class="text-xs text-purple-400 font-semibold uppercase tracking-wider mb-4">新しい単語を追加</div>
        <div class="space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <div class="text-xs text-gray-400 mb-1">英単語 <span class="text-red-400">*</span></div>
              <input id="inWord" type="text" placeholder="例: ephemeral" maxlength="60"
                class="w-full bg-white/10 rounded-xl px-3 py-2.5 text-white placeholder-gray-500 border border-white/10 focus:border-purple-400 focus:outline-none text-sm font-mono" />
            </div>
            <div>
              <div class="text-xs text-gray-400 mb-1">発音記号（任意）</div>
              <input id="inPhonetic" type="text" placeholder="例: /ɪˈfem.ər.əl/" maxlength="60"
                class="w-full bg-white/10 rounded-xl px-3 py-2.5 text-white placeholder-gray-500 border border-white/10 focus:border-purple-400 focus:outline-none text-sm font-mono" />
            </div>
          </div>
          <div>
            <div class="text-xs text-gray-400 mb-1">意味・訳 <span class="text-red-400">*</span></div>
            <input id="inMeaning" type="text" placeholder="例: 束の間の、はかない" maxlength="100"
              class="w-full bg-white/10 rounded-xl px-3 py-2.5 text-white placeholder-gray-500 border border-white/10 focus:border-purple-400 focus:outline-none text-sm" />
          </div>
          <div>
            <div class="text-xs text-gray-400 mb-1">例文（任意）</div>
            <input id="inExample" type="text" placeholder="例: Life is ephemeral." maxlength="200"
              class="w-full bg-white/10 rounded-xl px-3 py-2.5 text-white placeholder-gray-500 border border-white/10 focus:border-purple-400 focus:outline-none text-sm" />
          </div>
          <div>
            <div class="text-xs text-gray-400 mb-1">タグ（カテゴリ）</div>
            <input id="inTag" type="text" placeholder="例: TOEIC / 大学受験 / 日常会話" maxlength="30"
              class="w-full bg-white/10 rounded-xl px-3 py-2.5 text-white placeholder-gray-500 border border-white/10 focus:border-purple-400 focus:outline-none text-sm" />
          </div>
          <button onclick="addWord()"
            class="w-full py-3 rounded-xl font-bold text-white text-sm transition-all"
            style="background: linear-gradient(135deg, #9333ea, #ec4899);">
            ＋ 単語を追加して復習スケジュールを設定
          </button>
        </div>
      </div>

      <!-- Ebbinghaus info -->
      <div class="bg-white/5 rounded-2xl p-4 text-xs text-gray-400 leading-relaxed">
        <div class="font-semibold text-gray-300 mb-2">📊 エビングハウスの忘却曲線とは？</div>
        <div>人は覚えた内容を <strong class="text-white">20分後に42%</strong>、<strong class="text-white">1日後に67%</strong>、<strong class="text-white">1週間後に77%</strong> 忘れてしまいます。最適なタイミングで復習することで、長期記憶への定着が3〜5倍効率化します。</div>
        <div class="mt-2 flex flex-wrap gap-2">
          <span class="px-2 py-0.5 rounded bg-purple-500/20 text-purple-300">1回目: 翌日</span>
          <span class="px-2 py-0.5 rounded bg-blue-500/20 text-blue-300">2回目: 3日後</span>
          <span class="px-2 py-0.5 rounded bg-green-500/20 text-green-300">3回目: 7日後</span>
          <span class="px-2 py-0.5 rounded bg-yellow-500/20 text-yellow-300">4回目: 14日後</span>
          <span class="px-2 py-0.5 rounded bg-orange-500/20 text-orange-300">5回目: 30日後</span>
          <span class="px-2 py-0.5 rounded bg-red-500/20 text-red-300">6回目: 長期記憶✓</span>
        </div>
      </div>
    </div>

    <!-- ===== TAB: Review ===== -->
    <div id="tab-review" class="hidden space-y-4">
      <div id="reviewEmpty" class="bg-white/5 rounded-2xl p-10 text-center hidden">
        <div class="text-4xl mb-3">🎉</div>
        <div class="text-white font-semibold mb-1">今日の復習は全て完了！</div>
        <div class="text-gray-400 text-sm">お疲れさまでした。次の復習予定を確認してください。</div>
      </div>
      <div id="reviewCard" class="hidden">
        <div class="text-xs text-gray-500 text-center mb-2" id="reviewProgress"></div>
        <!-- Flashcard -->
        <div class="bg-white/5 rounded-2xl p-8 text-center border border-white/10 word-card" id="flashCard">
          <div class="text-xs text-purple-400 font-semibold uppercase tracking-wider mb-4" id="cardStage"></div>
          <div class="text-4xl font-black text-white font-mono mb-2" id="cardWord"></div>
          <div class="text-sm text-gray-500 font-mono mb-4" id="cardPhonetic"></div>
          <div id="cardAnswer" class="hidden">
            <div class="h-px bg-white/10 mb-4"></div>
            <div class="text-xl font-bold text-purple-200 mb-2" id="cardMeaning"></div>
            <div class="text-sm text-gray-400 italic" id="cardExample"></div>
          </div>
          <button onclick="toggleAnswer()"
            id="showAnswerBtn"
            class="mt-4 px-6 py-2 rounded-xl text-sm font-medium bg-white/10 text-gray-300 hover:bg-white/20 border border-white/10 transition-all">
            答えを見る
          </button>
        </div>
        <!-- Rating -->
        <div id="ratingRow" class="hidden mt-4 grid grid-cols-3 gap-3">
          <button onclick="rate('again')"
            class="py-3 rounded-xl text-sm font-bold bg-red-500/20 text-red-300 border border-red-500/30 hover:bg-red-500/30 transition-all">
            😖 もう一度
          </button>
          <button onclick="rate('hard')"
            class="py-3 rounded-xl text-sm font-bold bg-orange-500/20 text-orange-300 border border-orange-500/30 hover:bg-orange-500/30 transition-all">
            😅 難しい
          </button>
          <button onclick="rate('good')"
            class="py-3 rounded-xl text-sm font-bold bg-green-500/20 text-green-300 border border-green-500/30 hover:bg-green-500/30 transition-all">
            😊 覚えた！
          </button>
        </div>
      </div>
    </div>

    <!-- ===== TAB: List ===== -->
    <div id="tab-list" class="hidden space-y-3">
      <div class="flex gap-2">
        <input id="searchInput" type="text" placeholder="単語・意味で検索..." oninput="renderList()"
          class="flex-1 bg-white/10 rounded-xl px-3 py-2 text-white placeholder-gray-500 border border-white/10 focus:border-purple-400 focus:outline-none text-sm" />
        <select id="tagFilter" onchange="renderList()"
          class="bg-white/10 rounded-xl px-3 py-2 text-white border border-white/10 focus:outline-none text-sm appearance-none">
          <option value="">全タグ</option>
        </select>
      </div>
      <div class="text-xs text-gray-500 flex justify-between px-1">
        <span id="listCount">0 単語</span>
        <button onclick="exportWords()" class="hover:text-gray-300 transition-all">📤 エクスポート</button>
      </div>
      <div id="wordList" class="space-y-2"></div>
    </div>

    <!-- ===== TAB: Curve ===== -->
    <div id="tab-curve" class="hidden space-y-4">
      <div class="bg-white/5 rounded-2xl p-5">
        <div class="text-xs text-purple-400 font-semibold uppercase tracking-wider mb-3">忘却曲線と復習効果</div>
        <svg viewBox="0 0 400 200" class="w-full" style="height:180px;">
          <defs>
            <linearGradient id="curveGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#9333ea" stop-opacity="0.6"/>
              <stop offset="100%" stop-color="#9333ea" stop-opacity="0"/>
            </linearGradient>
            <linearGradient id="curveGrad2" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#4ade80" stop-opacity="0.5"/>
              <stop offset="100%" stop-color="#4ade80" stop-opacity="0"/>
            </linearGradient>
          </defs>
          <!-- Grid -->
          <line x1="40" y1="10" x2="40" y2="160" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
          <line x1="40" y1="160" x2="390" y2="160" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
          <line x1="40" y1="10" x2="390" y2="10" stroke="rgba(255,255,255,0.05)" stroke-width="1" stroke-dasharray="4"/>
          <line x1="40" y1="85" x2="390" y2="85" stroke="rgba(255,255,255,0.05)" stroke-width="1" stroke-dasharray="4"/>
          <!-- Labels -->
          <text x="38" y="14" fill="rgba(255,255,255,0.4)" font-size="9" text-anchor="end">100%</text>
          <text x="38" y="89" fill="rgba(255,255,255,0.4)" font-size="9" text-anchor="end">50%</text>
          <text x="38" y="164" fill="rgba(255,255,255,0.4)" font-size="9" text-anchor="end">0%</text>
          <!-- Ebbinghaus decay curve (no review) -->
          <!-- R = e^(-t/S), S≈1 for new learning. Points: t=0→100%, t=1→37%, t=3→22%, t=7→14%, t=14→9%, t=30→5% -->
          <path d="M40,10 C80,10 100,95 130,120 C160,140 200,148 250,152 C300,156 350,158 390,159"
            fill="none" stroke="rgba(239,68,68,0.7)" stroke-width="2.5" stroke-linecap="round"/>
          <text x="230" y="148" fill="rgba(239,68,68,0.8)" font-size="9">復習なし</text>

          <!-- With spaced repetition (higher retention) -->
          <path d="M40,10 L40,10 C55,10 60,35 70,45 C80,55 90,50 100,45 C110,42 115,20 125,22
            C135,24 140,35 150,38 C160,41 165,30 175,30 C185,30 190,10 200,12
            C210,14 215,22 225,24 C235,26 240,20 250,20 C260,20 265,10 275,11
            C285,12 290,18 300,18 C320,18 340,16 390,15"
            fill="none" stroke="rgba(74,222,128,0.8)" stroke-width="2.5" stroke-linecap="round"/>
          <text x="295" y="13" fill="rgba(74,222,128,0.9)" font-size="9">復習あり</text>

          <!-- Vertical review markers -->
          <line x1="70" y1="45" x2="70" y2="160" stroke="rgba(74,222,128,0.3)" stroke-width="1" stroke-dasharray="3"/>
          <line x1="125" y1="22" x2="125" y2="160" stroke="rgba(74,222,128,0.3)" stroke-width="1" stroke-dasharray="3"/>
          <line x1="175" y1="30" x2="175" y2="160" stroke="rgba(74,222,128,0.3)" stroke-width="1" stroke-dasharray="3"/>
          <line x1="225" y1="24" x2="225" y2="160" stroke="rgba(74,222,128,0.3)" stroke-width="1" stroke-dasharray="3"/>
          <line x1="275" y1="11" x2="275" y2="160" stroke="rgba(74,222,128,0.3)" stroke-width="1" stroke-dasharray="3"/>
          <!-- X axis labels -->
          <text x="40" y="174" fill="rgba(255,255,255,0.35)" font-size="8" text-anchor="middle">0</text>
          <text x="70" y="174" fill="rgba(74,222,128,0.7)" font-size="8" text-anchor="middle">1日</text>
          <text x="125" y="174" fill="rgba(74,222,128,0.7)" font-size="8" text-anchor="middle">3日</text>
          <text x="175" y="174" fill="rgba(74,222,128,0.7)" font-size="8" text-anchor="middle">7日</text>
          <text x="225" y="174" fill="rgba(74,222,128,0.7)" font-size="8" text-anchor="middle">14日</text>
          <text x="275" y="174" fill="rgba(74,222,128,0.7)" font-size="8" text-anchor="middle">30日</text>
          <text x="390" y="174" fill="rgba(255,255,255,0.35)" font-size="8" text-anchor="middle">60日</text>
          <!-- Review dots -->
          <circle cx="70" cy="45" r="4" fill="#4ade80"/>
          <circle cx="125" cy="22" r="4" fill="#4ade80"/>
          <circle cx="175" cy="30" r="4" fill="#4ade80"/>
          <circle cx="225" cy="24" r="4" fill="#4ade80"/>
          <circle cx="275" cy="11" r="4" fill="#4ade80"/>
        </svg>
        <div class="text-xs text-gray-500 text-center mt-1">緑の点：復習タイミング。復習のたびに記憶が強化されます</div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-3">
        <div class="bg-white/5 rounded-2xl p-4 text-center">
          <div class="text-2xl font-black text-white" id="statTotal">0</div>
          <div class="text-xs text-gray-400">総単語数</div>
        </div>
        <div class="bg-white/5 rounded-2xl p-4 text-center">
          <div class="text-2xl font-black text-green-300" id="statMastered">0</div>
          <div class="text-xs text-gray-400">習得済み</div>
        </div>
        <div class="bg-white/5 rounded-2xl p-4 text-center">
          <div class="text-2xl font-black text-purple-300" id="statDueToday">0</div>
          <div class="text-xs text-gray-400">今日の復習</div>
        </div>
      </div>

      <!-- Stage distribution -->
      <div class="bg-white/5 rounded-2xl p-5">
        <div class="text-xs text-purple-400 font-semibold uppercase tracking-wider mb-3">ステージ分布</div>
        <div id="stageDistribution" class="space-y-2"></div>
      </div>
    </div>

  </div>

<section class="tool-seo">
  <div class="seo-inner">
    <div class="seo-block">
      <div class="seo-h2">📌 ツールの概要・特徴</div>
      <p class="seo-p">このツールは、エビングハウスの忘却曲線に基づいて語彙・単語の復習タイミングを最適化する間隔反復学習ツールです。新しく覚えた単語を入力すると、1日後・3日後・7日後・14日後…と忘れる直前のタイミングで復習リマインダーを生成します。</p>
    </div>
    <div class="seo-block">
      <div class="seo-h2">📖 詳しい使い方・手順</div>
      <ol class="seo-ol">
        <li>覚えたい単語・語彙と意味を入力します（外国語・専門用語・古文単語等に対応）。</li>
        <li>初回テストを受けて記憶の定着度を評価します。</li>
        <li>忘却曲線に基づいた次回復習日がカレンダーに表示されます。</li>
        <li>復習日にテストを受けて「覚えている」「あいまい」「忘れた」を選択します。</li>
        <li>結果に応じて次の復習間隔が自動調整されます（SRS：間隔反復システム）。</li>
      </ol>
    </div>
    <div class="seo-block">
      <div class="seo-h2">👤 こんな人におすすめ</div>
      <p class="seo-p">TOEICや英検などの語彙を効率よく覚えたい方、外国語の単語を大量に暗記する必要がある語学学習者に最適です。資格試験の専門用語を短期間で習得したい方、忘れやすい知識を長期記憶に定着させたい学生・社会人にもおすすめします。</p>
    </div>
    <div class="seo-block">
      <div class="seo-h2">🛠️ 制作の背景・こだわり</div>
      <p class="seo-p">単語学習で「覚えたはずなのに忘れる」を繰り返す根本原因は、復習タイミングの非効率さにあります。エビングハウスの忘却曲線に基づく間隔反復学習はAnkiなどで実証されていますが、日本語UIで手軽に使えるシンプルなツールが少ないと感じました。登録した瞬間から忘却曲線を計算し始める設計で、学習の初日から最適化されます。</p>
    </div>
  </div>
</section>
</BaseLayout>

<script is:inline>
  // ---- Ebbinghaus review intervals (days) ----
  const INTERVALS = [1, 3, 7, 14, 30, 90]; // stage 0→1, 1→2, ..., 5→mastered
  const STAGE_LABELS = ['新規', '1回目', '2回目', '3回目', '4回目', '5回目', '習得済み'];
  const STAGE_COLORS = ['#a78bfa','#60a5fa','#34d399','#facc15','#fb923c','#f87171','#4ade80'];

  const STORAGE_KEY = 'vocab_curve_v2';
  let words = [];
  let currentTab = 'add';
  let reviewQueue = [];
  let reviewIdx = 0;
  let showingAnswer = false;

  // ---- Storage ----
  function load() {
    try { words = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { words = []; }
  }
  function save() { localStorage.setItem(STORAGE_KEY, JSON.stringify(words)); }

  function todayStr() {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  }
  function addDays(dateStr, days) {
    const d = new Date(dateStr);
    d.setDate(d.getDate() + days);
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  }
  function formatDate(dateStr) {
    const d = new Date(dateStr);
    return `${d.getMonth()+1}/${d.getDate()}`;
  }

  // ---- Due words ----
  function getDueWords() {
    const today = todayStr();
    return words.filter(w => w.stage < INTERVALS.length && w.nextReview <= today);
  }

  // ---- Notifications ----
  async function requestNotification() {
    if (!('Notification' in window)) { alert('このブラウザは通知をサポートしていません'); return; }
    const perm = await Notification.requestPermission();
    if (perm === 'granted') {
      document.getElementById('notifBanner').classList.add('hidden');
      new Notification('📚 英単語復習アプリ', { body: '通知が有効になりました！復習タイミングをお知らせします。' });
    }
  }

  function scheduleNotification(word, dateStr) {
    if (!('Notification' in window) || Notification.permission !== 'granted') return;
    // Store scheduled notifications in localStorage for ServiceWorker-less approach
    // On page load, we check due words and fire notifications
  }

  function checkAndNotify() {
    if (!('Notification' in window) || Notification.permission !== 'granted') return;
    const due = getDueWords();
    if (due.length > 0) {
      new Notification(`📚 ${due.length}単語の復習時間です！`, {
        body: due.slice(0,3).map(w => w.word).join('、') + (due.length > 3 ? `…他${due.length-3}単語` : ''),
        tag: 'vocab-review',
      });
    }
  }

  // ---- Add word ----
  function addWord() {
    const word = document.getElementById('inWord').value.trim();
    const meaning = document.getElementById('inMeaning').value.trim();
    if (!word || !meaning) { alert('英単語と意味は必須です'); return; }

    const entry = {
      id: Date.now().toString(),
      word, meaning,
      phonetic: document.getElementById('inPhonetic').value.trim(),
      example: document.getElementById('inExample').value.trim(),
      tag: document.getElementById('inTag').value.trim(),
      stage: 0,
      nextReview: todayStr(), // review immediately on first add? or tomorrow
      addedAt: todayStr(),
      history: [],
    };
    // Set first review to tomorrow
    entry.nextReview = addDays(todayStr(), 1);

    words.unshift(entry);
    save();

    // Clear form
    ['inWord','inPhonetic','inMeaning','inExample','inTag'].forEach(id => document.getElementById(id).value = '');

    // Success flash
    const btn = document.querySelector('[onclick="addWord()"]');
    const orig = btn.textContent;
    btn.textContent = `✅ "${entry.word}" を追加しました！`;
    btn.style.background = 'linear-gradient(135deg,#059669,#10b981)';
    setTimeout(() => { btn.textContent = orig; btn.style.background = 'linear-gradient(135deg,#9333ea,#ec4899)'; }, 2000);

    updateReviewBadge();
    renderCurveTab();
  }

  // ---- Review ----
  function startReview() {
    reviewQueue = getDueWords().sort(() => Math.random() - 0.5);
    reviewIdx = 0;
    showNextCard();
  }

  function showNextCard() {
    if (reviewIdx >= reviewQueue.length) {
      document.getElementById('reviewCard').classList.add('hidden');
      document.getElementById('reviewEmpty').classList.remove('hidden');
      return;
    }
    document.getElementById('reviewEmpty').classList.add('hidden');
    document.getElementById('reviewCard').classList.remove('hidden');

    const w = reviewQueue[reviewIdx];
    document.getElementById('reviewProgress').textContent = `${reviewIdx + 1} / ${reviewQueue.length} 単語`;
    document.getElementById('cardStage').textContent = `ステージ ${w.stage} → ${STAGE_LABELS[w.stage]}`;
    document.getElementById('cardStage').style.color = STAGE_COLORS[w.stage];
    document.getElementById('cardWord').textContent = w.word;
    document.getElementById('cardPhonetic').textContent = w.phonetic || '';
    document.getElementById('cardMeaning').textContent = w.meaning;
    document.getElementById('cardExample').textContent = w.example || '';
    document.getElementById('cardAnswer').classList.add('hidden');
    document.getElementById('ratingRow').classList.add('hidden');
    document.getElementById('showAnswerBtn').classList.remove('hidden');
    showingAnswer = false;

    // Flip animation
    document.getElementById('flashCard').classList.add('flip-anim');
    setTimeout(() => document.getElementById('flashCard').classList.remove('flip-anim'), 350);
  }

  function toggleAnswer() {
    if (showingAnswer) return;
    showingAnswer = true;
    document.getElementById('cardAnswer').classList.remove('hidden');
    document.getElementById('ratingRow').classList.remove('hidden');
    document.getElementById('showAnswerBtn').classList.add('hidden');
  }

  function rate(result) {
    const w = reviewQueue[reviewIdx];
    const entry = words.find(x => x.id === w.id);
    if (!entry) { reviewIdx++; showNextCard(); return; }

    const today = todayStr();
    entry.history.push({ date: today, result });

    if (result === 'again') {
      // Stay at same stage, review again today
      entry.nextReview = today;
    } else if (result === 'hard') {
      // Advance stage but slower
      if (entry.stage < INTERVALS.length) {
        entry.nextReview = addDays(today, INTERVALS[entry.stage]);
      }
      // Don't advance stage
    } else {
      // 'good' - advance stage
      if (entry.stage < INTERVALS.length) {
        entry.nextReview = addDays(today, INTERVALS[entry.stage]);
        entry.stage++;
      }
    }

    save();
    reviewIdx++;
    showNextCard();
    updateReviewBadge();
    renderCurveTab();
  }

  // ---- List ----
  function renderList() {
    const query = document.getElementById('searchInput').value.toLowerCase();
    const tagF   = document.getElementById('tagFilter').value;

    let filtered = words.filter(w => {
      const matchQ = !query || w.word.toLowerCase().includes(query) || w.meaning.toLowerCase().includes(query);
      const matchT = !tagF || w.tag === tagF;
      return matchQ && matchT;
    });

    // Update tag filter options
    const allTags = [...new Set(words.map(w => w.tag).filter(Boolean))];
    const tagSel = document.getElementById('tagFilter');
    const curVal = tagSel.value;
    tagSel.innerHTML = '<option value="">全タグ</option>' + allTags.map(t => `<option value="${t}">${t}</option>`).join('');
    tagSel.value = curVal;

    document.getElementById('listCount').textContent = `${filtered.length} 単語`;

    if (filtered.length === 0) {
      document.getElementById('wordList').innerHTML = `<div class="bg-white/5 rounded-xl p-6 text-center text-gray-500 text-sm">${words.length === 0 ? '単語を追加してください' : '該当なし'}</div>`;
      return;
    }

    const today = todayStr();
    document.getElementById('wordList').innerHTML = filtered.map(w => {
      const isDue = w.stage < INTERVALS.length && w.nextReview <= today;
      const isMastered = w.stage >= INTERVALS.length;
      const retentionPct = calcRetention(w);
      return `
        <div class="bg-white/5 rounded-xl p-4 border ${isDue ? 'border-purple-400/30' : 'border-white/5'} hover:border-white/10 transition-all">
          <div class="flex items-start justify-between gap-2">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="font-bold text-white font-mono">${escHtml(w.word)}</span>
                ${w.phonetic ? `<span class="text-xs text-gray-500 font-mono">${escHtml(w.phonetic)}</span>` : ''}
                <span class="stage-dot" style="background:${STAGE_COLORS[w.stage]};"></span>
                <span class="text-xs" style="color:${STAGE_COLORS[w.stage]};">${STAGE_LABELS[w.stage]}</span>
                ${isDue ? '<span class="px-1.5 py-0.5 rounded text-xs bg-red-500/20 text-red-300 border border-red-500/30">復習時期！</span>' : ''}
                ${isMastered ? '<span class="px-1.5 py-0.5 rounded text-xs bg-green-500/20 text-green-300 border border-green-500/30">✓ 習得</span>' : ''}
              </div>
              <div class="text-sm text-gray-300 mt-1">${escHtml(w.meaning)}</div>
              ${w.example ? `<div class="text-xs text-gray-500 italic mt-0.5">${escHtml(w.example)}</div>` : ''}
              <div class="flex items-center gap-3 mt-2">
                <div class="flex-1 h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="retention-bar h-full rounded-full" style="width:${retentionPct}%;background:${retentionPct > 60 ? '#4ade80' : retentionPct > 30 ? '#facc15' : '#f87171'};"></div>
                </div>
                <span class="text-xs text-gray-500 flex-shrink-0">定着度${retentionPct}%</span>
                ${!isMastered ? `<span class="text-xs text-gray-600 flex-shrink-0">次回: ${formatDate(w.nextReview)}</span>` : ''}
              </div>
            </div>
            <button onclick="deleteWord('${w.id}')" class="text-gray-600 hover:text-red-400 transition-all text-xs flex-shrink-0 mt-0.5">✕</button>
          </div>
        </div>
      `;
    }).join('');
  }

  function calcRetention(w) {
    // Simple: stage/maxStage * 100
    return Math.min(100, Math.round((w.stage / INTERVALS.length) * 100));
  }

  function deleteWord(id) {
    if (!confirm('この単語を削除しますか？')) return;
    words = words.filter(w => w.id !== id);
    save();
    renderList();
    updateReviewBadge();
    renderCurveTab();
  }

  function exportWords() {
    const blob = new Blob([JSON.stringify(words, null, 2)], { type: 'application/json' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `vocab_${new Date().toISOString().slice(0,10)}.json`;
    a.click();
  }

  // ---- Curve tab ----
  function renderCurveTab() {
    const today = todayStr();
    const due = getDueWords().length;
    const mastered = words.filter(w => w.stage >= INTERVALS.length).length;
    document.getElementById('statTotal').textContent = words.length;
    document.getElementById('statMastered').textContent = mastered;
    document.getElementById('statDueToday').textContent = due;

    // Stage distribution
    const stageCounts = Array(STAGE_LABELS.length).fill(0);
    words.forEach(w => stageCounts[Math.min(w.stage, STAGE_LABELS.length - 1)]++);
    const maxCount = Math.max(...stageCounts, 1);
    document.getElementById('stageDistribution').innerHTML = STAGE_LABELS.map((label, i) =>
      `<div class="flex items-center gap-2">
        <div class="w-16 text-xs text-gray-400 flex-shrink-0">${label}</div>
        <div class="flex-1 h-4 bg-white/10 rounded-full overflow-hidden">
          <div class="h-full rounded-full transition-all" style="width:${(stageCounts[i]/maxCount)*100}%;background:${STAGE_COLORS[i]};"></div>
        </div>
        <div class="w-6 text-xs text-gray-400 text-right">${stageCounts[i]}</div>
      </div>`
    ).join('');
  }

  // ---- Tab switching ----
  function setTab(tab) {
    currentTab = tab;
    ['add','review','list','curve'].forEach(t => {
      document.getElementById(`tab-${t}`).classList.toggle('hidden', t !== tab);
    });
    document.querySelectorAll('.tab-btn').forEach(b => {
      const active = b.dataset.tab === tab;
      b.style.background = active ? 'rgba(147,51,234,0.4)' : 'transparent';
      b.style.color = active ? 'white' : 'rgb(156,163,175)';
      b.style.borderColor = active ? 'rgba(147,51,234,0.3)' : 'transparent';
      b.style.border = active ? '1px solid rgba(147,51,234,0.3)' : 'none';
    });
    if (tab === 'review') startReview();
    if (tab === 'list') renderList();
    if (tab === 'curve') renderCurveTab();
  }

  function updateReviewBadge() {
    const due = getDueWords().length;
    const badge = document.getElementById('reviewBadge');
    if (due > 0) { badge.textContent = due; badge.classList.remove('hidden'); }
    else badge.classList.add('hidden');
  }

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ---- Init ----
  load();
  updateReviewBadge();
  renderCurveTab();

  // Check notification permission state
  if ('Notification' in window && Notification.permission === 'granted') {
    document.getElementById('notifBanner').classList.add('hidden');
    checkAndNotify();
  }

  // Tab button dataset init
  document.querySelectorAll('.tab-btn').forEach(b => {
    const text = b.textContent.trim();
    if (text.includes('単語追加')) b.dataset.tab = 'add';
    else if (text.includes('復習')) b.dataset.tab = 'review';
    else if (text.includes('単語帳')) b.dataset.tab = 'list';
    else if (text.includes('曲線')) b.dataset.tab = 'curve';
  });

  // Enter key on word input
  document.getElementById('inWord').addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('inMeaning').focus(); });
  document.getElementById('inMeaning').addEventListener('keydown', e => { if (e.key === 'Enter') addWord(); });
</script>
