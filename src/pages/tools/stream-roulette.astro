---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="配信用枠決め豪華ルーレット | yumi Labs">
  <style>
    @keyframes winner-glow {
      0%, 100% { box-shadow: 0 0 20px rgba(251,191,36,0.4); }
      50%       { box-shadow: 0 0 60px rgba(251,191,36,0.9), 0 0 100px rgba(251,191,36,0.4); }
    }
    @keyframes confetti-fall {
      0%   { transform: translateY(-20px) rotate(0deg); opacity: 1; }
      100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
    }
    @keyframes winner-pop {
      0%   { transform: scale(0.5); opacity: 0; }
      70%  { transform: scale(1.1); }
      100% { transform: scale(1); opacity: 1; }
    }
    @keyframes shimmer {
      0%   { background-position: -200% center; }
      100% { background-position: 200% center; }
    }
    .winner-glow { animation: winner-glow 1s ease-in-out infinite; }
    .winner-pop  { animation: winner-pop 0.6s cubic-bezier(0.34,1.56,0.64,1) forwards; }
    .shimmer-text {
      background: linear-gradient(90deg, #fbbf24 0%, #fff 40%, #fbbf24 60%, #f59e0b 100%);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 2s linear infinite;
    }
    .confetti-piece {
      position: fixed;
      width: 10px; height: 10px;
      border-radius: 2px;
      pointer-events: none;
      z-index: 9999;
      animation: confetti-fall linear forwards;
    }
    canvas { touch-action: none; }
    #spinBtn:not(:disabled):hover { transform: scale(1.04); }
    #spinBtn { transition: transform 0.15s, opacity 0.2s; }
  </style>

  <div class="max-w-3xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="text-center mb-8">
      <div class="text-5xl mb-3">🎡</div>
      <div style="font-size:1.8rem;font-weight:800;color:var(--gray-0);margin-bottom:0.3rem">配信用枠決め豪華ルーレット</div>
      <div class="text-gray-400 text-sm">ゲームタイトル候補を入れて視聴者と一緒に豪華演出で枠を決定！</div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">

      <!-- Left: Entry list -->
      <div class="lg:col-span-2 space-y-4">
        <div class="bg-white/5 rounded-2xl p-5">
          <div class="text-xs text-purple-400 font-semibold uppercase tracking-wider mb-3">候補タイトルを入力</div>

          <div class="flex gap-2 mb-3">
            <input id="entryInput" type="text" placeholder="ゲーム名を入力…" maxlength="30"
              class="flex-1 bg-white/10 rounded-xl px-3 py-2 text-white placeholder-gray-500 border border-white/10 focus:border-purple-400 focus:outline-none text-sm" />
            <button onclick="addEntry()"
              class="px-4 py-2 rounded-xl text-sm font-bold text-white flex-shrink-0 transition-all"
              style="background:linear-gradient(135deg,#9333ea,#ec4899);">追加</button>
          </div>

          <!-- Quick adds -->
          <div class="mb-3">
            <div class="text-xs text-gray-500 mb-1.5">クイック追加</div>
            <div class="flex flex-wrap gap-1.5" id="quickTags">
              <!-- rendered by JS -->
            </div>
          </div>

          <!-- Entry list -->
          <div id="entryList" class="space-y-1.5 max-h-72 overflow-y-auto pr-1"></div>

          <div class="mt-3 flex gap-2">
            <button onclick="clearAll()"
              class="flex-1 py-1.5 rounded-lg text-xs text-gray-400 hover:text-gray-200 border border-white/10 hover:border-white/20 transition-all">
              全クリア
            </button>
            <button onclick="shuffleEntries()"
              class="flex-1 py-1.5 rounded-lg text-xs text-gray-400 hover:text-gray-200 border border-white/10 hover:border-white/20 transition-all">
              シャッフル
            </button>
          </div>
        </div>

        <!-- Options -->
        <div class="bg-white/5 rounded-2xl p-5 space-y-3">
          <div class="text-xs text-purple-400 font-semibold uppercase tracking-wider">オプション</div>

          <div>
            <div class="text-xs text-gray-400 mb-1.5">テーマ</div>
            <div class="flex gap-2 flex-wrap" id="themeButtons">
              <button onclick="setTheme('galaxy')" data-t="galaxy" class="theme-btn px-3 py-1.5 rounded-lg text-xs border border-purple-400/60 bg-purple-500/20 text-white transition-all">🌌 ギャラクシー</button>
              <button onclick="setTheme('fire')" data-t="fire" class="theme-btn px-3 py-1.5 rounded-lg text-xs border border-white/10 bg-white/5 text-gray-300 transition-all">🔥 ファイア</button>
              <button onclick="setTheme('neon')" data-t="neon" class="theme-btn px-3 py-1.5 rounded-lg text-xs border border-white/10 bg-white/5 text-gray-300 transition-all">💡 ネオン</button>
              <button onclick="setTheme('pastel')" data-t="pastel" class="theme-btn px-3 py-1.5 rounded-lg text-xs border border-white/10 bg-white/5 text-gray-300 transition-all">🌸 パステル</button>
            </div>
          </div>

          <div>
            <div class="text-xs text-gray-400 mb-1.5">スピード</div>
            <div class="flex gap-2">
              <button onclick="setSpeed('slow')" data-s="slow" class="speed-btn flex-1 py-1.5 rounded-lg text-xs border border-white/10 bg-white/5 text-gray-300 transition-all">🐢 ゆっくり</button>
              <button onclick="setSpeed('normal')" data-s="normal" class="speed-btn flex-1 py-1.5 rounded-lg text-xs border border-purple-400/60 bg-purple-500/20 text-white transition-all">⚡ 普通</button>
              <button onclick="setSpeed('fast')" data-s="fast" class="speed-btn flex-1 py-1.5 rounded-lg text-xs border border-white/10 bg-white/5 text-gray-300 transition-all">🚀 爆速</button>
            </div>
          </div>

          <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
            <input type="checkbox" id="optSound" checked class="accent-purple-400" />
            効果音あり（クリック音・ファンファーレ）
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
            <input type="checkbox" id="optConfetti" checked class="accent-purple-400" />
            紙吹雪演出
          </label>
        </div>
      </div>

      <!-- Right: Wheel -->
      <div class="lg:col-span-3 flex flex-col items-center gap-4">

        <!-- Canvas wheel -->
        <div class="relative w-full max-w-sm mx-auto">
          <!-- Pointer -->
          <div class="absolute right-0 top-1/2 -translate-y-1/2 z-10 translate-x-3" style="filter:drop-shadow(0 0 8px rgba(251,191,36,0.8));">
            <svg width="36" height="36" viewBox="0 0 36 36">
              <polygon points="36,18 0,6 8,18 0,30" fill="#fbbf24" stroke="#f59e0b" stroke-width="1.5"/>
            </svg>
          </div>
          <!-- Wheel canvas -->
          <canvas id="wheelCanvas" width="500" height="500"
            class="w-full rounded-full border-4"
            style="border-color:rgba(255,255,255,0.1);"></canvas>
          <!-- Center cap -->
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="w-14 h-14 rounded-full border-4 border-white/20 flex items-center justify-center text-xl"
              style="background:rgba(15,10,30,0.95);box-shadow:0 0 20px rgba(0,0,0,0.8);">
              🎡
            </div>
          </div>
        </div>

        <!-- Spin button -->
        <button id="spinBtn" onclick="spin()"
          class="w-full max-w-sm py-4 rounded-2xl text-xl font-black text-white"
          style="background:linear-gradient(135deg,#7c3aed,#ec4899);box-shadow:0 0 30px rgba(147,51,234,0.5);">
          🎰 スピン！
        </button>

        <!-- Winner display -->
        <div id="winnerBox" class="hidden w-full max-w-sm">
          <div class="winner-glow winner-pop rounded-2xl p-5 text-center"
            style="background:linear-gradient(135deg,rgba(251,191,36,0.15),rgba(249,115,22,0.15));border:2px solid rgba(251,191,36,0.5);">
            <div class="text-xs text-yellow-400/80 font-semibold uppercase tracking-widest mb-1">🏆 決定！</div>
            <div id="winnerText" class="shimmer-text text-2xl font-black leading-tight mb-1"></div>
            <div class="text-xs text-gray-400 mt-2">おめでとうございます！🎊</div>
          </div>
          <button onclick="reroll()"
            class="mt-2 w-full py-2 rounded-xl text-xs text-gray-400 hover:text-white border border-white/10 hover:border-purple-400/30 transition-all">
            🔄 もう一度回す
          </button>
        </div>

        <!-- History -->
        <div id="historyBox" class="hidden w-full max-w-sm">
          <div class="text-xs text-gray-500 mb-1.5">過去の結果</div>
          <div id="historyList" class="flex flex-wrap gap-1.5"></div>
        </div>
      </div>
    </div>
  </div>

<section class="tool-seo">
  <div class="seo-inner">
    <div class="seo-block">
      <h2 class="seo-h2">📌 ツールの概要・特徴</h2>
      <p class="seo-p">このツールは、ゲーム配信・Vtuber配信で使えるルーレット機能を提供する無料Webアプリです。視聴者からのゲームリクエスト・挑戦内容・キャラクター選択などをリスト化してルーレットで決定でき、配信の盛り上がりを演出するアニメーションエフェクト付きです。</p>
    </div>
    <div class="seo-block">
      <h2 class="seo-h2">📖 詳しい使い方・手順</h2>
      <ol class="seo-ol">
        <li>ルーレットの項目（ゲームタイトル・挑戦内容・キャラクター名等）を入力します。</li>
        <li>項目の重みづけ（特定の項目が出やすい確率設定）もできます。</li>
        <li>「ルーレットを回す」ボタンを押すとアニメーションが始まります。</li>
        <li>結果が画面に大きく表示され、効果音も鳴ります（OBSのブラウザソースとして使用可）。</li>
        <li>過去の結果履歴を記録し、同じ項目が連続して出ないフィルターも設定できます。</li>
      </ol>
    </div>
    <div class="seo-block">
      <h2 class="seo-h2">👤 こんな人におすすめ</h2>
      <p class="seo-p">ゲーム配信者・Vtuberとして配信のコンテンツを充実させたい方に最適です。視聴者参加型の企画でリクエストをフェアに決めたい方、雑談配信でトークテーマをルーレットで決めたい方、グループゲームで担当を決めたい方にもおすすめします。</p>
    </div>
    <div class="seo-block">
      <h2 class="seo-h2">🛠️ 制作の背景・こだわり</h2>
      <p class="seo-p">配信でのルーレット演出は視聴者の盛り上がりに直結しますが、OBSに統合できるシンプルなルーレットツールは意外と少ない状況でした。OBSのブラウザソースとして組み込める軽量設計にし、配信画面に直接オーバーレイできる透過背景対応も実装しています。配信の「やり込み感」を高める演出にこだわっています。</p>
    </div>
  </div>
</section>
</BaseLayout>

<script is:inline>
  // ---- Config ----
  const QUICK_ITEMS = [
    'マインクラフト','エルデンリング','スプラトゥーン3','原神','Apex Legends',
    'ポケモン','ストリートファイター6','ゼルダ','FF16','DbD',
    '雑談','歌枠','お絵描き','視聴者参加','企画枠',
  ];

  const THEMES = {
    galaxy: {
      bg: '#0a0520',
      slices: ['#7c3aed','#9333ea','#a855f7','#c084fc','#ec4899','#f43f5e','#3b82f6','#6366f1','#8b5cf6','#d946ef'],
      border: 'rgba(255,255,255,0.15)',
      text: '#ffffff',
      glowColor: '#9333ea',
    },
    fire: {
      bg: '#1c0a00',
      slices: ['#dc2626','#ea580c','#f97316','#ef4444','#fb923c','#c2410c','#b91c1c','#f59e0b','#d97706','#ff6b35'],
      border: 'rgba(255,200,100,0.3)',
      text: '#fff8e7',
      glowColor: '#f97316',
    },
    neon: {
      bg: '#050510',
      slices: ['#06b6d4','#0ea5e9','#22d3ee','#67e8f9','#7c3aed','#8b5cf6','#ec4899','#f43f5e','#10b981','#34d399'],
      border: 'rgba(6,182,212,0.4)',
      text: '#e0fdf4',
      glowColor: '#06b6d4',
    },
    pastel: {
      bg: '#1a0f1f',
      slices: ['#f9a8d4','#fbcfe8','#c4b5fd','#ddd6fe','#a5f3fc','#bae6fd','#86efac','#bbf7d0','#fde68a','#fca5a5'],
      border: 'rgba(249,168,212,0.3)',
      text: '#1a0a20',
      glowColor: '#f9a8d4',
    },
  };

  const SPEEDS = { slow: 6, normal: 10, fast: 16 };

  // ---- State ----
  let entries = ['マインクラフト','エルデンリング','スプラトゥーン3','原神','Apex Legends'];
  let currentTheme = 'galaxy';
  let currentSpeed = 'normal';
  let spinning = false;
  let angle = 0;
  let targetAngle = 0;
  let velocity = 0;
  let animFrame = null;
  let history = [];

  // Audio context for sounds
  let audioCtx = null;
  function getAudio() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    return audioCtx;
  }

  function playClick(freq = 600) {
    if (!document.getElementById('optSound').checked) return;
    try {
      const ctx = getAudio();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.frequency.value = freq;
      osc.type = 'square';
      gain.gain.setValueAtTime(0.08, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.04);
      osc.start(); osc.stop(ctx.currentTime + 0.04);
    } catch {}
  }

  function playFanfare() {
    if (!document.getElementById('optSound').checked) return;
    try {
      const ctx = getAudio();
      const notes = [523, 659, 784, 1047, 1319];
      notes.forEach((freq, i) => {
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.frequency.value = freq;
        osc.type = 'triangle';
        const t = ctx.currentTime + i * 0.12;
        gain.gain.setValueAtTime(0, t);
        gain.gain.linearRampToValueAtTime(0.2, t + 0.05);
        gain.gain.exponentialRampToValueAtTime(0.001, t + 0.35);
        osc.start(t); osc.stop(t + 0.4);
      });
    } catch {}
  }

  // ---- Entry management ----
  function addEntry() {
    const val = document.getElementById('entryInput').value.trim();
    if (!val || entries.includes(val)) { document.getElementById('entryInput').value = ''; return; }
    entries.push(val);
    document.getElementById('entryInput').value = '';
    renderEntries();
    drawWheel();
  }

  function removeEntry(i) {
    entries.splice(i, 1);
    renderEntries();
    drawWheel();
  }

  function clearAll() { entries = []; renderEntries(); drawWheel(); }

  function shuffleEntries() {
    for (let i = entries.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [entries[i], entries[j]] = [entries[j], entries[i]];
    }
    renderEntries();
    drawWheel();
  }

  function addQuick(item) {
    if (!entries.includes(item)) { entries.push(item); renderEntries(); drawWheel(); }
  }

  function renderEntries() {
    const el = document.getElementById('entryList');
    if (entries.length === 0) {
      el.innerHTML = '<div class="text-xs text-gray-600 py-2 text-center">候補を追加してください</div>';
      return;
    }
    el.innerHTML = entries.map((e, i) => `
      <div class="flex items-center gap-2 py-1 px-2 rounded-lg hover:bg-white/5 group">
        <div class="w-3 h-3 rounded-full flex-shrink-0" style="background:${getSliceColor(i)};"></div>
        <span class="flex-1 text-sm text-gray-300 truncate">${escHtml(e)}</span>
        <button onclick="removeEntry(${i})" class="text-gray-600 hover:text-red-400 transition-all opacity-0 group-hover:opacity-100 text-xs">✕</button>
      </div>
    `).join('');
  }

  function renderQuickTags() {
    document.getElementById('quickTags').innerHTML = QUICK_ITEMS.map(item =>
      `<button onclick="addQuick('${escHtml(item)}')"
        class="px-2 py-1 rounded-lg text-xs bg-white/5 border border-white/10 text-gray-400 hover:bg-purple-500/20 hover:text-purple-300 hover:border-purple-400/30 transition-all">
        ${escHtml(item)}
      </button>`
    ).join('');
  }

  function getSliceColor(i) {
    const theme = THEMES[currentTheme];
    return theme.slices[i % theme.slices.length];
  }

  // ---- Theme / Speed ----
  function setTheme(t) {
    currentTheme = t;
    document.querySelectorAll('.theme-btn').forEach(b => {
      const active = b.dataset.t === t;
      b.style.borderColor = active ? 'rgba(147,51,234,0.6)' : 'rgba(255,255,255,0.1)';
      b.style.background  = active ? 'rgba(147,51,234,0.2)' : 'rgba(255,255,255,0.05)';
      b.style.color = active ? 'white' : 'rgb(156,163,175)';
    });
    drawWheel();
  }

  function setSpeed(s) {
    currentSpeed = s;
    document.querySelectorAll('.speed-btn').forEach(b => {
      const active = b.dataset.s === s;
      b.style.borderColor = active ? 'rgba(147,51,234,0.6)' : 'rgba(255,255,255,0.1)';
      b.style.background  = active ? 'rgba(147,51,234,0.2)' : 'rgba(255,255,255,0.05)';
      b.style.color = active ? 'white' : 'rgb(156,163,175)';
    });
  }

  // ---- Draw wheel ----
  function drawWheel(currentAngle) {
    const canvas = document.getElementById('wheelCanvas');
    const ctx = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;
    const cx = W / 2, cy = H / 2;
    const r = W / 2 - 8;
    const theme = THEMES[currentTheme];

    ctx.clearRect(0, 0, W, H);

    // Background
    const bgGrad = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
    bgGrad.addColorStop(0, theme.bg.replace('#','') === theme.bg ? theme.bg : theme.bg + 'ff');
    bgGrad.addColorStop(1, '#000000');
    ctx.fillStyle = bgGrad;
    ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2); ctx.fill();

    if (entries.length === 0) {
      ctx.fillStyle = 'rgba(255,255,255,0.2)';
      ctx.font = 'bold 24px sans-serif';
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('候補を追加してください', cx, cy);
      return;
    }

    const n = entries.length;
    const sliceAngle = (Math.PI * 2) / n;
    const rot = (currentAngle !== undefined ? currentAngle : angle);

    entries.forEach((entry, i) => {
      const startA = rot + i * sliceAngle;
      const endA   = startA + sliceAngle;
      const midA   = startA + sliceAngle / 2;
      const color  = getSliceColor(i);

      // Slice
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.arc(cx, cy, r, startA, endA);
      ctx.closePath();
      ctx.fillStyle = color;
      ctx.fill();

      // Slice border
      ctx.strokeStyle = 'rgba(0,0,0,0.35)';
      ctx.lineWidth = 2;
      ctx.stroke();

      // Shine overlay
      const shineGrad = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
      shineGrad.addColorStop(0, 'rgba(255,255,255,0.12)');
      shineGrad.addColorStop(0.6, 'rgba(255,255,255,0)');
      shineGrad.addColorStop(1, 'rgba(0,0,0,0.2)');
      ctx.fillStyle = shineGrad;
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.arc(cx, cy, r, startA, endA);
      ctx.closePath();
      ctx.fill();

      // Text
      const textR = r * 0.6;
      const tx = cx + Math.cos(midA) * textR;
      const ty = cy + Math.sin(midA) * textR;

      ctx.save();
      ctx.translate(tx, ty);
      ctx.rotate(midA + Math.PI / 2);
      const fontSize = Math.max(11, Math.min(20, Math.floor(r * 0.1 * (6 / Math.max(n, 3)))));
      ctx.font = `bold ${fontSize}px sans-serif`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';

      // Text shadow
      ctx.fillStyle = 'rgba(0,0,0,0.6)';
      ctx.fillText(entry.length > 10 ? entry.slice(0,10)+'…' : entry, 2, 2);
      ctx.fillStyle = '#ffffff';
      ctx.fillText(entry.length > 10 ? entry.slice(0,10)+'…' : entry, 0, 0);
      ctx.restore();
    });

    // Outer ring
    const ringGrad = ctx.createLinearGradient(0, 0, W, H);
    ringGrad.addColorStop(0, theme.glowColor + '80');
    ringGrad.addColorStop(0.5, '#ffffff40');
    ringGrad.addColorStop(1, theme.glowColor + '80');
    ctx.strokeStyle = ringGrad;
    ctx.lineWidth = 6;
    ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2); ctx.stroke();

    // Glow effect
    ctx.shadowColor = theme.glowColor;
    ctx.shadowBlur = 20;
    ctx.strokeStyle = theme.glowColor + '60';
    ctx.lineWidth = 3;
    ctx.beginPath(); ctx.arc(cx, cy, r + 2, 0, Math.PI * 2); ctx.stroke();
    ctx.shadowBlur = 0;
  }

  // ---- Spin ----
  let lastClickedSlice = -1;

  function spin() {
    if (spinning || entries.length < 2) return;
    spinning = true;
    document.getElementById('winnerBox').classList.add('hidden');
    document.getElementById('spinBtn').disabled = true;
    document.getElementById('spinBtn').style.opacity = '0.6';

    const n = entries.length;
    const minSpins = SPEEDS[currentSpeed];
    const extraAngle = Math.random() * Math.PI * 2;
    const totalRotation = Math.PI * 2 * minSpins + extraAngle;
    targetAngle = angle + totalRotation;

    // Calculate winner
    const finalAngle = ((targetAngle % (Math.PI * 2)) + Math.PI * 2) % (Math.PI * 2);
    // pointer is at right (angle 0 = right), slices start from current angle
    // Winner slice: the slice under the pointer (right side, angle=0 relative to wheel)
    const normalizedAngle = ((Math.PI * 2) - finalAngle) % (Math.PI * 2);
    const sliceAngle = (Math.PI * 2) / n;
    const winnerIdx = Math.floor(normalizedAngle / sliceAngle) % n;

    const startTime = performance.now();
    const duration = (minSpins * 1000) + 2000;
    let lastSlice = -1;

    function animate(now) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      // ease out quintic
      const eased = 1 - Math.pow(1 - progress, 5);
      angle = angle + (targetAngle - angle) * (eased - (lastClickedSlice >= 0 ? 0 : 0));

      // smoother: just lerp based on time
      const currentPos = ((targetAngle - (targetAngle - angle) * (1 - eased)));
      const displayAngle = angle + (targetAngle - angle) * eased;

      // play click sound on slice change
      const curSlice = Math.floor((((Math.PI * 2) - (displayAngle % (Math.PI * 2)) + Math.PI * 2) % (Math.PI * 2)) / sliceAngle) % n;
      if (curSlice !== lastSlice) {
        playClick(400 + progress * 400);
        lastSlice = curSlice;
      }

      drawWheel(displayAngle);

      if (progress < 1) {
        animFrame = requestAnimationFrame(animate);
      } else {
        angle = targetAngle % (Math.PI * 2);
        drawWheel(angle);
        spinning = false;
        document.getElementById('spinBtn').disabled = false;
        document.getElementById('spinBtn').style.opacity = '1';
        showWinner(winnerIdx);
      }
    }

    animFrame = requestAnimationFrame(animate);
  }

  function showWinner(idx) {
    const winner = entries[idx];
    history.unshift(winner);
    if (history.length > 5) history.pop();

    // Winner box
    const box = document.getElementById('winnerBox');
    box.classList.remove('hidden');
    document.getElementById('winnerText').textContent = winner;

    // Confetti
    if (document.getElementById('optConfetti').checked) launchConfetti();

    // Fanfare
    playFanfare();

    // History
    const hbox = document.getElementById('historyBox');
    hbox.classList.remove('hidden');
    document.getElementById('historyList').innerHTML = history.map((h, i) =>
      `<span class="px-2.5 py-1 rounded-lg text-xs border ${i === 0 ? 'border-yellow-400/50 bg-yellow-400/10 text-yellow-300' : 'border-white/10 bg-white/5 text-gray-400'}">${escHtml(h)}</span>`
    ).join('');
  }

  function reroll() {
    document.getElementById('winnerBox').classList.add('hidden');
    spin();
  }

  // ---- Confetti ----
  function launchConfetti() {
    const colors = ['#fbbf24','#ec4899','#9333ea','#3b82f6','#10b981','#f97316','#06b6d4','#ffffff'];
    for (let i = 0; i < 80; i++) {
      setTimeout(() => {
        const piece = document.createElement('div');
        piece.className = 'confetti-piece';
        piece.style.cssText = `
          left: ${Math.random() * 100}vw;
          top: -10px;
          background: ${colors[Math.floor(Math.random() * colors.length)]};
          width: ${6 + Math.random() * 10}px;
          height: ${6 + Math.random() * 10}px;
          border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
          animation-duration: ${1.5 + Math.random() * 2}s;
          animation-delay: 0s;
        `;
        document.body.appendChild(piece);
        setTimeout(() => piece.remove(), 4000);
      }, Math.random() * 800);
    }
  }

  // ---- Enter key ----
  document.getElementById('entryInput').addEventListener('keydown', e => {
    if (e.key === 'Enter') addEntry();
  });

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ---- Init ----
  renderQuickTags();
  renderEntries();
  drawWheel();
  setTheme('galaxy');
  setSpeed('normal');
</script>
