// ======= STATE =======
let foundTerms = [];
let alwaysShow = false;

// ======= SAMPLES =======
function loadSample(i) {
  document.getElementById('text-area').value = SAMPLES[i];
}

function clearAll() {
  document.getElementById('text-area').value = '';
  document.getElementById('result-card').style.display = 'none';
  document.getElementById('glossary-card').style.display = 'none';
  document.getElementById('stats-row').style.display = 'none';
}

function toggleAlways() {
  alwaysShow = document.getElementById('always-show').checked;
}

// ======= ANALYZE =======
function analyze() {
  const text = document.getElementById('text-area').value.trim();
  if (!text) { alert('テキストを入力してください'); return; }

  // Find all matching terms (longest match first)
  const sortedDict = [...DICT].sort((a, b) => b.term.length - a.term.length);
  foundTerms = [];
  const foundSet = new Set();

  // Build annotated HTML
  let html = '';
  let i = 0;
  const chars = [...text];

  while (i < chars.length) {
    // Try longest match
    let matched = false;
    for (const entry of sortedDict) {
      const term = entry.term;
      const slice = chars.slice(i, i + term.length).join('');
      if (slice === term) {
        // Found a match
        const tid = 'term-' + i;
        html += `<span class="term-hl" id="${tid}" data-term="${escHtml(term)}" onclick="showTooltip(this, event)">`
              + `<ruby>${escHtml(term)}<rt>${entry.reading}</rt></ruby>`
              + `</span>`;
        if (!foundSet.has(term)) {
          foundSet.add(term);
          foundTerms.push(entry);
        }
        i += term.length;
        matched = true;
        break;
      }
    }
    if (!matched) {
      const ch = chars[i];
      if (ch === '\n') html += '<br>';
      else html += escHtml(ch);
      i++;
    }
  }

  document.getElementById('ruby-text').innerHTML = html;
  document.getElementById('result-card').style.display = 'block';

  // stats
  document.getElementById('st-terms').textContent = foundTerms.length;
  document.getElementById('st-chars').textContent = text.replace(/\s/g,'').length;
  document.getElementById('stats-row').style.display = 'flex';

  // glossary
  renderGlossary(foundTerms);
  document.getElementById('glossary-card').style.display = 'block';

  document.getElementById('result-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ======= TOOLTIP =======
function showTooltip(el, e) {
  const term = el.dataset.term;
  const entry = DICT.find(d => d.term === term);
  if (!entry) return;

  // toggle active
  document.querySelectorAll('.term-hl.active').forEach(t => { if (t !== el) t.classList.remove('active'); });
  el.classList.toggle('active');

  const box = document.getElementById('tooltip-box');
  if (!el.classList.contains('active')) { box.classList.remove('show'); return; }

  document.getElementById('tt-term').textContent = entry.term;
  document.getElementById('tt-reading').textContent = '読み：' + entry.reading;
  document.getElementById('tt-meaning').textContent = entry.meaning;
  document.getElementById('tt-law').textContent = '根拠：' + (entry.law || '');

  box.classList.add('show');
  // position
  const r = el.getBoundingClientRect();
  let top = r.bottom + window.scrollY + 6;
  let left = r.left + window.scrollX;
  const bw = box.offsetWidth || 300;
  if (left + bw > window.innerWidth - 12) left = window.innerWidth - bw - 12;
  if (left < 8) left = 8;
  box.style.top = top + 'px';
  box.style.left = left + 'px';
}

document.addEventListener('click', function(e) {
  if (!e.target.closest('.term-hl') && !e.target.closest('.tooltip-box')) {
    document.getElementById('tooltip-box').classList.remove('show');
    document.querySelectorAll('.term-hl.active').forEach(t => t.classList.remove('active'));
  }
});

// ======= GLOSSARY =======
function renderGlossary(terms) {
  if (!terms.length) {
    document.getElementById('glossary-list').innerHTML = '<div class="empty-note">法律用語が見つかりませんでした</div>';
    return;
  }
  document.getElementById('glossary-list').innerHTML = terms.map(e =>
    `<div class="glossary-item" onclick="highlightInText('${escHtml(e.term)}')">
      <div>
        <div class="gl-term">${escHtml(e.term)}</div>
        <div class="gl-reading">${e.reading}</div>
      </div>
      <div class="gl-meaning">${escHtml(e.meaning)}<br><span style="font-size:.72rem;color:#475569">${escHtml(e.law||'')}</span></div>
    </div>`
  ).join('');
}

function filterGlossary() {
  const q = document.getElementById('glossary-search').value.trim().toLowerCase();
  const filtered = q ? foundTerms.filter(e =>
    e.term.includes(q) || e.reading.includes(q) || e.meaning.includes(q)
  ) : foundTerms;
  renderGlossary(filtered);
}

function highlightInText(term) {
  // scroll to first occurrence in ruby-text
  const spans = document.querySelectorAll('.term-hl');
  for (const s of spans) {
    if (s.dataset.term === term) {
      s.scrollIntoView({ behavior: 'smooth', block: 'center' });
      s.classList.add('active');
      // show tooltip
      showTooltip(s, null);
      setTimeout(() => s.classList.remove('active'), 2000);
      break;
    }
  }
}

// Enter to analyze
document.getElementById('text-area').addEventListener('keydown', e => {
  if (e.key === 'Enter' && e.ctrlKey) { e.preventDefault(); analyze(); }
});
</script>

