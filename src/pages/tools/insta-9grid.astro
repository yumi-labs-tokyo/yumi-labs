---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="インスタ9マス統一感シミュレーター | yumi Labs">
  <input type="file" id="fileInput" accept="image/*" multiple class="hidden">

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="text-center mb-8">
      <div class="text-5xl mb-3">📷</div>
      <div style="font-size:1.8rem;font-weight:800;color:var(--gray-0);margin-bottom:0.3rem">インスタ9マス統一感シミュレーター</div>
      <div class="text-gray-400 text-sm">9枚の写真にフィルターを一括適用してInstagramグリッドをプレビュー</div>
    </div>

    <div class="flex flex-col xl:flex-row gap-6">
      <!-- Left: Controls -->
      <div class="xl:w-80 flex-shrink-0">
        <div class="bg-white/5 rounded-2xl p-5 space-y-5">

          <!-- Filter presets -->
          <div>
            <div class="flex items-center justify-between mb-3">
              <div class="text-xs text-purple-400 font-semibold uppercase tracking-wider">フィルター</div>
              <span id="filterActiveLabel" class="text-xs font-medium text-purple-300 bg-purple-500/20 px-2 py-0.5 rounded-full">なし</span>
            </div>
            <div class="grid grid-cols-4 gap-2" id="presetGrid"></div>
          </div>

          <hr class="border-white/10">

          <!-- Adjustments -->
          <div>
            <div class="text-xs text-purple-400 font-semibold uppercase tracking-wider mb-3">カスタム調整</div>
            <div class="space-y-4">
              <div>
                <div class="flex justify-between text-xs text-gray-400 mb-1.5">
                  <span>☀️ 明るさ</span><span id="valBrightness" class="font-mono">1.0</span>
                </div>
                <input type="range" id="sliderBrightness" min="0.5" max="1.5" step="0.05" value="1" class="w-full accent-purple-500 cursor-pointer">
              </div>
              <div>
                <div class="flex justify-between text-xs text-gray-400 mb-1.5">
                  <span>◑ コントラスト</span><span id="valContrast" class="font-mono">1.0</span>
                </div>
                <input type="range" id="sliderContrast" min="0.5" max="1.5" step="0.05" value="1" class="w-full accent-purple-500 cursor-pointer">
              </div>
              <div>
                <div class="flex justify-between text-xs text-gray-400 mb-1.5">
                  <span>🎨 彩度</span><span id="valSaturation" class="font-mono">1.0</span>
                </div>
                <input type="range" id="sliderSaturation" min="0" max="2" step="0.05" value="1" class="w-full accent-purple-500 cursor-pointer">
              </div>
              <button onclick="resetAdjustments()" class="text-xs text-gray-600 hover:text-gray-400 transition-colors">↺ 調整をリセット</button>
            </div>
          </div>

          <hr class="border-white/10">

          <!-- Status -->
          <div>
            <div class="flex items-center justify-between mb-3">
              <span class="text-sm text-gray-400">アップロード済み</span>
              <span id="imgCount" class="text-sm font-bold text-white">0/9 枚</span>
            </div>
            <div class="text-xs text-gray-600 space-y-1 leading-relaxed">
              <div>• マスをクリックして画像を追加・変更</div>
              <div>• 複数ファイルをドロップで一括追加</div>
              <div>• マスにカーソルを乗せると削除ボタン表示</div>
            </div>
          </div>

          <hr class="border-white/10">

          <!-- Buttons -->
          <div class="space-y-2">
            <button onclick="downloadGrid(this)"
              class="w-full py-3 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 text-white rounded-xl font-bold text-sm transition-all">
              📥 グリッドをPNGで保存
            </button>
            <button onclick="clearAll()"
              class="w-full py-2 bg-white/5 hover:bg-white/10 text-gray-500 hover:text-white rounded-xl text-sm transition-all border border-white/10">
              🗑️ 全画像をリセット
            </button>
          </div>
        </div>
      </div>

      <!-- Right: Grid -->
      <div class="flex-1">
        <div class="bg-white/5 rounded-2xl p-5">
          <div class="flex items-center justify-between mb-4">
            <div class="text-sm text-gray-400">グリッドプレビュー</div>
            <div class="text-xs text-gray-600 hidden sm:block">複数ファイルをドロップして一括追加できます</div>
          </div>
          <div class="relative" id="gridWrapper">
            <div id="mainGrid" class="grid grid-cols-3 bg-gray-900 rounded-lg overflow-hidden" style="gap:2px"></div>
            <div id="dropOverlay"
              class="hidden absolute inset-0 bg-purple-500/20 border-2 border-dashed border-purple-400 rounded-lg flex items-center justify-center pointer-events-none">
              <div class="text-purple-200 text-xl font-bold">📂 ここにドロップ</div>
            </div>
          </div>
          <div class="mt-3 text-center text-xs text-gray-600">ダウンロード時: 1200×1200px（各400×400px）</div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const PRESETS = [
      { id: 'none',    label: 'なし',         css: '',                                                                  gradient: 'linear-gradient(135deg,#667eea,#764ba2)' },
      { id: 'warm',    label: '暖色',         css: 'sepia(0.25) saturate(1.4) hue-rotate(-12deg) brightness(1.06)',     gradient: 'linear-gradient(135deg,#f6d365,#fda085)' },
      { id: 'mono',    label: 'モノクロ',     css: 'grayscale(1)',                                                       gradient: 'linear-gradient(135deg,#4a4a4a,#b0b0b0)' },
      { id: 'pastel',  label: 'パステル',     css: 'saturate(0.5) brightness(1.22) contrast(0.85)',                      gradient: 'linear-gradient(135deg,#ffecd2,#fcb69f)' },
      { id: 'cool',    label: 'クール',       css: 'hue-rotate(22deg) saturate(1.1) brightness(1.03)',                   gradient: 'linear-gradient(135deg,#a1c4fd,#c2e9fb)' },
      { id: 'vintage', label: 'ヴィンテージ', css: 'sepia(0.5) contrast(0.88) brightness(0.92) saturate(0.88)',           gradient: 'linear-gradient(135deg,#b79891,#94716b)' },
      { id: 'matte',   label: 'マット',       css: 'contrast(0.82) brightness(1.06) saturate(0.68)',                     gradient: 'linear-gradient(135deg,#8e9eab,#eef2f3)' },
      { id: 'vivid',   label: 'ビビッド',     css: 'saturate(1.85) contrast(1.1) brightness(1.02)',                      gradient: 'linear-gradient(135deg,#f093fb,#f5576c)' },
    ];

    const state = {
      objectUrls: new Array(9).fill(null),
      filter: 'none',
      brightness: 1,
      contrast: 1,
      saturation: 1,
    };

    let pickerTarget = 0;

    function buildFilter() {
      const preset = PRESETS.find(p => p.id === state.filter);
      const presetCSS = preset?.css || '';
      const { brightness, contrast, saturation } = state;
      const adjDefault = brightness === 1 && contrast === 1 && saturation === 1;
      if (!presetCSS && adjDefault) return 'none';
      const parts = [];
      if (presetCSS) parts.push(presetCSS);
      if (!adjDefault) parts.push(`brightness(${brightness.toFixed(2)}) contrast(${contrast.toFixed(2)}) saturate(${saturation.toFixed(2)})`);
      return parts.join(' ');
    }

    function renderPresetGrid() {
      const container = document.getElementById('presetGrid');
      container.innerHTML = PRESETS.map(p => `
        <button data-filter-id="${p.id}"
          class="preset-btn flex flex-col items-center gap-1 p-1.5 rounded-xl border-2 transition-all ${p.id === state.filter ? 'border-white/60 bg-white/10' : 'border-transparent hover:border-white/20'}">
          <div class="chip-preview w-10 h-10 rounded-lg"
            style="background:${p.gradient};background-size:cover;background-position:center;filter:${p.css || 'none'}"></div>
          <span class="text-xs text-gray-400 truncate w-full text-center">${p.label}</span>
        </button>`).join('');
      container.querySelectorAll('.preset-btn').forEach(btn =>
        btn.addEventListener('click', () => selectFilter(btn.dataset.filterId))
      );
    }

    function selectFilter(id) {
      state.filter = id;
      document.querySelectorAll('.preset-btn').forEach(btn => {
        const active = btn.dataset.filterId === id;
        btn.classList.toggle('border-white/60', active);
        btn.classList.toggle('bg-white/10', active);
        btn.classList.toggle('border-transparent', !active);
      });
      document.getElementById('filterActiveLabel').textContent = PRESETS.find(p => p.id === id)?.label || 'なし';
      applyFiltersToGrid();
    }

    function applyFiltersToGrid() {
      const css = buildFilter();
      document.querySelectorAll('.grid-img').forEach(img => { img.style.filter = css; });
    }

    function updateChipPreviews() {
      const firstUrl = state.objectUrls.find(Boolean);
      PRESETS.forEach(p => {
        const el = document.querySelector(`[data-filter-id="${p.id}"] .chip-preview`);
        if (el) el.style.backgroundImage = firstUrl ? `url('${firstUrl}')` : p.gradient;
      });
    }

    function renderCell(index) {
      const cell = document.getElementById(`cell-${index}`);
      if (!cell) return;
      const url = state.objectUrls[index];
      if (url) {
        cell.innerHTML = `
          <img class="grid-img absolute inset-0 w-full h-full object-cover" src="${url}" style="filter:${buildFilter()}">
          <button class="absolute top-1 right-1 w-6 h-6 rounded-full bg-black/70 hover:bg-red-500/90 text-white text-sm leading-6 text-center opacity-0 group-hover:opacity-100 transition-all z-20"
            onclick="event.stopPropagation();removeImage(${index})">×</button>
          <div class="absolute inset-0 z-10 hover:bg-black/10 transition-colors cursor-pointer" onclick="openPicker(${index})"></div>`;
      } else {
        cell.innerHTML = `
          <div class="absolute inset-0 flex flex-col items-center justify-center gap-1.5 text-gray-700 hover:text-gray-500 transition-colors cursor-pointer"
            onclick="openPicker(${index})">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
            </svg>
            <span class="text-xs font-medium">${index + 1}</span>
          </div>`;
      }
    }

    function handleUpload(index, file) {
      if (!file || !file.type.startsWith('image/')) return;
      if (state.objectUrls[index]) URL.revokeObjectURL(state.objectUrls[index]);
      state.objectUrls[index] = URL.createObjectURL(file);
      renderCell(index);
      updateChipPreviews();
      updateCount();
    }

    function removeImage(index) {
      if (state.objectUrls[index]) URL.revokeObjectURL(state.objectUrls[index]);
      state.objectUrls[index] = null;
      renderCell(index);
      updateChipPreviews();
      updateCount();
    }

    function openPicker(index) {
      pickerTarget = index;
      document.getElementById('fileInput').click();
    }

    function clearAll() {
      if (!state.objectUrls.some(Boolean)) return;
      if (!confirm('全ての画像をリセットしますか？')) return;
      state.objectUrls.forEach(url => { if (url) URL.revokeObjectURL(url); });
      state.objectUrls.fill(null);
      for (let i = 0; i < 9; i++) renderCell(i);
      updateChipPreviews();
      updateCount();
    }

    function updateCount() {
      document.getElementById('imgCount').textContent = `${state.objectUrls.filter(Boolean).length}/9 枚`;
    }

    function resetAdjustments() {
      state.brightness = 1; state.contrast = 1; state.saturation = 1;
      ['Brightness','Contrast','Saturation'].forEach(k => {
        document.getElementById(`slider${k}`).value = k === 'Saturation' ? 1 : 1;
        document.getElementById(`val${k}`).textContent = '1.0';
      });
      applyFiltersToGrid();
    }

    async function downloadGrid(btn) {
      if (!state.objectUrls.some(Boolean)) { alert('画像をアップロードしてください'); return; }
      const orig = btn.textContent;
      btn.textContent = '⏳ 生成中...'; btn.disabled = true;
      try {
        const cellSize = 400, gap = 2, total = cellSize * 3 + gap * 2;
        const canvas = document.createElement('canvas');
        canvas.width = total; canvas.height = total;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#111111';
        ctx.fillRect(0, 0, total, total);
        const filterCSS = buildFilter();
        for (let i = 0; i < 9; i++) {
          const col = i % 3, row = Math.floor(i / 3);
          const x = col * (cellSize + gap), y = row * (cellSize + gap);
          if (!state.objectUrls[i]) {
            ctx.fillStyle = '#222222';
            ctx.fillRect(x, y, cellSize, cellSize);
            continue;
          }
          await new Promise(resolve => {
            const img = new Image();
            img.onload = () => {
              ctx.save();
              if (filterCSS !== 'none') ctx.filter = filterCSS;
              const sc = Math.max(cellSize / img.naturalWidth, cellSize / img.naturalHeight);
              const sw = cellSize / sc, sh = cellSize / sc;
              const sx = (img.naturalWidth - sw) / 2, sy = (img.naturalHeight - sh) / 2;
              ctx.drawImage(img, sx, sy, sw, sh, x, y, cellSize, cellSize);
              ctx.restore();
              resolve();
            };
            img.onerror = resolve;
            img.src = state.objectUrls[i];
          });
        }
        canvas.toBlob(blob => {
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url; a.download = `insta_grid_${Date.now()}.png`; a.click();
          URL.revokeObjectURL(url);
        }, 'image/png');
      } finally {
        btn.textContent = orig; btn.disabled = false;
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      renderPresetGrid();

      const grid = document.getElementById('mainGrid');
      for (let i = 0; i < 9; i++) {
        const cell = document.createElement('div');
        cell.id = `cell-${i}`;
        cell.className = 'relative group bg-gray-900 overflow-hidden';
        cell.dataset.index = i;
        cell.style.aspectRatio = '1/1';
        grid.appendChild(cell);
        renderCell(i);
      }

      document.getElementById('fileInput').addEventListener('change', e => {
        const files = Array.from(e.target.files).filter(f => f.type.startsWith('image/'));
        if (files.length === 1) {
          handleUpload(pickerTarget, files[0]);
        } else {
          const empty = state.objectUrls.map((u, i) => u ? -1 : i).filter(i => i >= 0);
          files.forEach((f, fi) => { if (fi < empty.length) handleUpload(empty[fi], f); });
        }
        e.target.value = '';
      });

      ['Brightness','Contrast','Saturation'].forEach(k => {
        document.getElementById(`slider${k}`).addEventListener('input', e => {
          state[k.toLowerCase()] = parseFloat(e.target.value);
          document.getElementById(`val${k}`).textContent = parseFloat(e.target.value).toFixed(1);
          applyFiltersToGrid();
        });
      });

      const wrapper = document.getElementById('gridWrapper');
      const overlay = document.getElementById('dropOverlay');
      wrapper.addEventListener('dragover', e => { e.preventDefault(); overlay.classList.remove('hidden'); });
      wrapper.addEventListener('dragleave', e => { if (!wrapper.contains(e.relatedTarget)) overlay.classList.add('hidden'); });
      wrapper.addEventListener('drop', e => {
        e.preventDefault(); overlay.classList.add('hidden');
        const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/'));
        if (!files.length) return;
        const targetCell = e.target.closest('[data-index]');
        if (targetCell && files.length === 1) { handleUpload(parseInt(targetCell.dataset.index), files[0]); return; }
        const empty = state.objectUrls.map((u, i) => u ? -1 : i).filter(i => i >= 0);
        files.forEach((f, fi) => { if (fi < empty.length) handleUpload(empty[fi], f); });
      });
    });
  </script>

<section class="tool-seo">
  <div class="seo-inner">
    <div class="seo-block">
      <h2 class="seo-h2">📌 ツールの概要・特徴</h2>
      <p class="seo-p">このツールは、Instagramの「9枚グリッド投稿」をデザインするための画像分割・プレビューツールです。1枚の大きな画像を3×3の9枚に自動分割し、Instagramのプロフィールグリッドで実際にどう見えるかをプレビューできます。ブランドアカウントや企業アカウントのグリッドデザインに最適です。</p>
    </div>
    <div class="seo-block">
      <h2 class="seo-h2">📖 詳しい使い方・手順</h2>
      <ol class="seo-ol">
        <li>「画像をアップロード」から大きな画像（正方形推奨）をアップします。</li>
        <li>グリッド分割数（3×3=9枚が標準）を選択します。</li>
        <li>プレビューエリアでInstagramプロフィールと同じ配置を確認します。</li>
        <li>各分割画像を番号付きでダウンロードします（1から順番に投稿）。</li>
        <li>投稿順の番号案内で、どの順番で投稿すれば正しく並ぶかがわかります。</li>
      </ol>
    </div>
    <div class="seo-block">
      <h2 class="seo-h2">👤 こんな人におすすめ</h2>
      <p class="seo-p">Instagramのプロフィールページをアート作品のようにデザインしたいクリエイターに最適です。ブランドの世界観を統一した大型グリッド投稿を企画している企業担当者、フォロワー獲得のためにプロフィールを印象的にしたいインフルエンサー志望の方にもおすすめです。</p>
    </div>
    <div class="seo-block">
      <h2 class="seo-h2">🛠️ 制作の背景・こだわり</h2>
      <p class="seo-p">Instagramの9枚グリッド投稿は視覚的インパクトが大きく、フォロワー増加に効果的と言われています。しかし分割ツールは有料アプリが多く、無料で高品質なWebツールがなかったため開発しました。投稿順のミスによる「グリッドが崩れる」失敗を防ぐナンバリング機能が特に好評です。</p>
    </div>
  </div>
</section>
</BaseLayout>
